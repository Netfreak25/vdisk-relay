def settings_context(label):
    return (
        '<div class="section-context">'
        '<a href="/settings">Settings</a>'
        '<span aria-hidden="true">/</span>'
        '<span>' + esc(label) + '</span>'
        '</div>'
    )


def nmcli_path():
    found = shutil.which("nmcli")
    if found:
        return found
    return "/usr/bin/nmcli" if os.path.exists("/usr/bin/nmcli") else ""


def nmcli_split(line):
    parts = []
    current = []
    escaped = False
    for char in line:
        if escaped:
            current.append(char)
            escaped = False
            continue
        if char == "\\":
            escaped = True
            continue
        if char == ":":
            parts.append("".join(current))
            current = []
            continue
        current.append(char)
    parts.append("".join(current))
    return parts


def nmcli_key_values(text):
    values = {}
    for line in (text or "").splitlines():
        parts = nmcli_split(line)
        if len(parts) >= 2:
            values[parts[0]] = ":".join(parts[1:])
    return values


def run_nmcli(args, timeout=8):
    nmcli = nmcli_path()
    if not nmcli:
        return 127, "nmcli not found"
    timeout_bin = shutil.which("timeout") or "/usr/bin/timeout"
    try:
        proc = subprocess.run(
            [timeout_bin, str(timeout) + "s", nmcli] + list(args),
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=timeout + 2,
            check=False,
        )
        return proc.returncode, proc.stdout.strip()
    except Exception as exc:
        return 1, "ERROR: " + str(exc)


def validate_wifi_text(value, name, max_len, allow_empty=False, strip_value=True):
    value = "" if value is None else str(value)
    if strip_value:
        value = value.strip()
    if ("\n" in value) or ("\r" in value) or ("\0" in value):
        raise ValueError("Invalid line break in " + name)
    if not value and not allow_empty:
        raise ValueError(name + " missing")
    if len(value) > max_len:
        raise ValueError(name + " is too long")
    return value


def validate_wifi_priority(value):
    try:
        priority = int(str(value).strip() or "0")
    except Exception:
        raise ValueError("Wi-Fi priority is invalid")
    if priority < -999 or priority > 999:
        raise ValueError("Wi-Fi priority must be between -999 and 999")
    return priority


def validate_wifi_ip_method(value):
    method = str(value or "").strip().lower()
    if method not in ("auto", "manual", "disabled"):
        raise ValueError("IPv4 method is invalid")
    return method


def validate_ipv4_interface_value(value, name, required=False):
    value = str(value or "").strip()
    if not value:
        if required:
            raise ValueError(name + " missing")
        return ""
    if "/" not in value:
        raise ValueError(name + " must be specified in address/prefix format")
    try:
        parsed = ipaddress.ip_interface(value)
    except Exception:
        raise ValueError(name + " is invalid")
    if parsed.version != 4:
        raise ValueError(name + " must be an IPv4 address")
    return str(parsed)


def validate_optional_ipv4_address(value, name):
    value = str(value or "").strip()
    if not value:
        return ""
    try:
        parsed = ipaddress.ip_address(value)
    except Exception:
        raise ValueError(name + " is invalid")
    if parsed.version != 4:
        raise ValueError(name + " must be an IPv4 address")
    return str(parsed)


def normalize_ipv4_dns(value):
    value = str(value or "").strip()
    if not value:
        return ""
    servers = [part for part in re.split(r"[\s,]+", value) if part]
    if len(servers) > 6:
        raise ValueError("Zu viele DNS-Server angegeben")
    return ",".join(validate_optional_ipv4_address(server, "DNS-Server") for server in servers)


def wifi_connection_exists(name):
    rc, out = run_nmcli(["-t", "-f", "NAME,TYPE", "connection", "show"], 8)
    if rc != 0:
        return False
    for line in out.splitlines():
        parts = nmcli_split(line)
        if len(parts) >= 2 and parts[0] == name:
            return True
    return False


def wifi_connection_detail(name):
    rc, out = run_nmcli(
        [
            "-t",
            "-f",
            "802-11-wireless.ssid,802-11-wireless-security.key-mgmt,connection.autoconnect,connection.autoconnect-priority,802-11-wireless.powersave,ipv4.method,ipv4.addresses,ipv4.gateway,ipv4.dns",
            "connection",
            "show",
            name,
        ],
        8,
    )
    if rc != 0:
        return {}
    return nmcli_key_values(out)


def wifi_cache_timestamp(epoch):
    try:
        return datetime.fromtimestamp(float(epoch), timezone.utc).astimezone().isoformat(timespec="seconds")
    except Exception:
        return ""


def wifi_status_with_cache_meta(status, source, generated_epoch):
    generated_epoch = float(generated_epoch or time.time())
    age = max(0, int(time.time() - generated_epoch))
    result = dict(status)
    result["cache"] = {
        "source": source,
        "generated_at": wifi_cache_timestamp(generated_epoch),
        "generated_at_epoch": generated_epoch,
        "age_seconds": age,
        "max_age_seconds": WIFI_STATUS_CACHE_MAX_AGE_SECONDS,
        "stale": age > WIFI_STATUS_CACHE_MAX_AGE_SECONDS,
    }
    return result


def load_wifi_status_cache():
    data = load_json_file(WIFI_STATUS_CACHE, {})
    if not isinstance(data, dict):
        return None
    cache = data.get("cache", {})
    generated_epoch = 0
    if isinstance(cache, dict):
        generated_epoch = cache.get("generated_at_epoch", 0)
    if not generated_epoch:
        try:
            generated_epoch = os.path.getmtime(WIFI_STATUS_CACHE)
        except Exception:
            generated_epoch = 0
    if not generated_epoch:
        return None
    return wifi_status_with_cache_meta(data, "cache", generated_epoch)


def write_wifi_status_cache(status):
    write_json_file_atomic(WIFI_STATUS_CACHE, wifi_status_with_cache_meta(status, "cache", time.time()))


def clear_wifi_status_cache():
    if not os.path.exists(WIFI_STATUS_CACHE):
        return ""
    try:
        os.unlink(WIFI_STATUS_CACHE)
        return ""
    except Exception as exc:
        return " Wi-Fi cache could not be cleared: " + str(exc)


def load_wifi_scan_cache():
    data = load_json_file(WIFI_SCAN_CACHE, {})
    return data if isinstance(data, dict) else {}


def write_wifi_scan_cache(data):
    write_json_file_atomic(WIFI_SCAN_CACHE, data)


def manual_wifi_scan():
    rc, out = run_nmcli(
        [
            "-t",
            "-f",
            "IN-USE,SSID,SIGNAL,BARS,CHAN,RATE,SECURITY",
            "device",
            "wifi",
            "list",
            "ifname",
            WIFI_DEFAULT_IFACE,
            "--rescan",
            "yes",
        ],
        20,
    )
    result = {
        "generated_at": datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds"),
        "interface": WIFI_DEFAULT_IFACE,
        "rc": rc,
        "error": "" if rc == 0 else out[:500],
        "items": [],
    }
    if rc != 0:
        write_wifi_scan_cache(result)
        return result

    for line in out.splitlines():
        parts = nmcli_split(line)
        if len(parts) < 7:
            continue
        ssid = parts[1].strip()
        signal = wifi_signal_percent_value(parts[2])
        result["items"].append(
            {
                "active": parts[0].strip() in ("*", "yes", "yes"),
                "ssid": ssid or "(versteckt)",
                "signal": "" if signal is None else str(signal),
                "bars": parts[3],
                "channel": parts[4],
                "rate": parts[5],
                "security": parts[6],
            }
        )

    result["items"].sort(key=lambda item: int(item.get("signal") or 0), reverse=True)
    write_wifi_scan_cache(result)
    return result


def active_wifi_signal():
    rc, out = run_nmcli(
        [
            "-t",
            "-f",
            "IN-USE,SSID,SIGNAL,BARS,CHAN,RATE,SECURITY",
            "device",
            "wifi",
            "list",
            "ifname",
            WIFI_DEFAULT_IFACE,
            "--rescan",
            "no",
        ],
        5,
    )
    signal = {
        "percent": "",
        "ssid": "",
        "bars": "",
        "channel": "",
        "rate": "",
        "security": "",
        "error": "" if rc == 0 else out[:240],
    }
    if rc != 0:
        return signal

    for line in out.splitlines():
        parts = nmcli_split(line)
        if len(parts) < 7:
            continue
        if parts[0].strip() not in ("*", "yes", "yes"):
            continue
        signal.update({
            "percent": parts[2].strip(),
            "ssid": parts[1],
            "bars": parts[3],
            "channel": parts[4],
            "rate": parts[5],
            "security": parts[6],
        })
        return signal
    return signal


def collect_wifi_status():
    status = {
        "nmcli": bool(nmcli_path()),
        "networkmanager": systemctl_active("NetworkManager.service"),
        "networkmanager_enabled": systemctl_enabled("NetworkManager.service"),
        "devices": [],
        "profiles": [],
        "device_detail": {},
        "signal": {},
        "error": "",
    }
    if not status["nmcli"]:
        status["error"] = "nmcli not found"
        return status

    rc, out = run_nmcli(["-t", "-f", "DEVICE,TYPE,STATE,CONNECTION", "device", "status"], 8)
    if rc != 0:
        status["error"] = out
    else:
        for line in out.splitlines():
            parts = nmcli_split(line)
            if len(parts) >= 4 and parts[1] in ("wifi", "wifi-p2p"):
                status["devices"].append(
                    {
                        "device": parts[0],
                        "type": parts[1],
                        "state": parts[2],
                        "connection": parts[3],
                    }
                )

    detail_rc, detail_out = run_nmcli(
        [
            "-t",
            "-f",
            "GENERAL.STATE,GENERAL.CONNECTION,GENERAL.HWADDR,IP4.ADDRESS,IP4.GATEWAY",
            "device",
            "show",
            WIFI_DEFAULT_IFACE,
        ],
        8,
    )
    if detail_rc == 0:
        status["device_detail"] = nmcli_key_values(detail_out)

    status["signal"] = active_wifi_signal()

    rc, out = run_nmcli(["-t", "-f", "NAME,UUID,TYPE,AUTOCONNECT,DEVICE", "connection", "show"], 8)
    if rc == 0:
        for line in out.splitlines():
            parts = nmcli_split(line)
            if len(parts) < 5 or parts[2] not in ("802-11-wireless", "wifi"):
                continue
            detail = wifi_connection_detail(parts[0])
            status["profiles"].append(
                {
                    "name": parts[0],
                    "uuid": parts[1],
                    "type": parts[2],
                    "autoconnect": parts[3],
                    "device": parts[4],
                    "ssid": detail.get("802-11-wireless.ssid", ""),
                    "key_mgmt": detail.get("802-11-wireless-security.key-mgmt", ""),
                    "priority": detail.get("connection.autoconnect-priority", ""),
                    "powersave": detail.get("802-11-wireless.powersave", ""),
                    "ipv4_method": detail.get("ipv4.method", ""),
                    "ipv4_addresses": detail.get("ipv4.addresses", ""),
                    "ipv4_gateway": detail.get("ipv4.gateway", ""),
                    "ipv4_dns": detail.get("ipv4.dns", ""),
                }
            )
    return status


def wifi_status(force_refresh=False):
    if not force_refresh:
        cached = load_wifi_status_cache()
        if cached:
            return cached

    status = collect_wifi_status()
    write_wifi_status_cache(status)
    return wifi_status_with_cache_meta(status, "live", time.time())


def wifi_signal_percent_value(value):
    raw = str(value or "").strip().rstrip("%")
    if not raw:
        return None
    try:
        percent = int(float(raw))
    except Exception:
        return None
    return max(0, min(100, percent))


def wifi_signal_quality_class(percent):
    if percent is None:
        return "signal-unknown"
    if percent >= 70:
        return "signal-ok"
    if percent >= 40:
        return "signal-warn"
    return "signal-bad"


def wifi_ipv4_method_label(method):
    return {
        "auto": "DHCP",
        "manual": "Manual",
        "disabled": "IPv4 off",
    }.get(method or "auto", method or "DHCP")


def wifi_autoconnect_badge(value):
    enabled = str(value or "").lower() in ("yes", "yes", "true", "1")
    cls = "ok" if enabled else "warn"
    label = "Auto" if enabled else "Manual"
    return '<span class="badge ' + cls + '">' + label + '</span>'


def wifi_powersave_badge(value):
    raw = str(value or "").strip()
    if raw == "2":
        return '<span class="badge ok">off</span>'
    if raw:
        return '<span class="badge warn">' + esc(raw) + '</span>'
    return "-"


def render_wifi_profile_rows(profiles, active_connection=""):
    rows = []
    for index, item in enumerate(profiles):
        name = item.get("name", "")
        dialog_id = "wifi-profile-edit-" + str(index)
        ipv4_method = item.get("ipv4_method") or "auto"
        ipv4_label = wifi_ipv4_method_label(ipv4_method)
        if item.get("ipv4_addresses"):
            ipv4_label += " / " + item.get("ipv4_addresses")
        active = name == active_connection or bool(item.get("device") and item.get("device") != "--")
        row_class = ' class="wifi-profile-row is-active"' if active else ' class="wifi-profile-row"'
        active_badge = ' <span class="badge ok">active</span>' if active else ""
        rows.append(
            "<tr" + row_class + ">"
            '<th data-label="Profile"><span class="wifi-profile-title">' + esc(name) + active_badge + '</span><br><small>' + esc(item.get("uuid", "")) + "</small></th>"
            '<td data-label="SSID">' + esc(item.get("ssid") or "-") + "</td>"
            '<td data-label="IPv4">' + esc(ipv4_label) + "</td>"
            '<td data-label="Autoconnect">' + wifi_autoconnect_badge(item.get("autoconnect")) + "</td>"
            '<td data-label="Priority">' + esc(item.get("priority") or "0") + "</td>"
            '<td data-label="Device">' + esc(item.get("device") or "-") + "</td>"
            '<td data-label="Powersave">' + wifi_powersave_badge(item.get("powersave")) + "</td>"
            '<td class="actions" data-label="Actions">'
            '<button type="button" class="secondary" data-open-dialog="' + esc(dialog_id) + '">Edit profile</button>'
            '<form method="post" action="/wifi/connect" class="inline" onsubmit="return confirm(\'Connect Wi-Fi profile: ' + esc(name) + '?\');">'
            '<input type="hidden" name="name" value="' + esc(name) + '">'
            '<button type="submit" data-icon="refresh">Connect Wi-Fi</button>'
            '</form>'
            '<form method="post" action="/wifi/powersave-off" class="inline">'
            '<input type="hidden" name="name" value="' + esc(name) + '">'
            '<button type="submit" class="secondary" data-icon="power">Disable powersave</button>'
            '</form>'
            "</td>"
            "</tr>"
        )
    if not rows:
        return '<tr><td colspan="8">No saved Wi-Fi profiles.</td></tr>'
    return "".join(rows)


def select_option(value, label, selected):
    attr = ' selected' if value == selected else ''
    return '<option value="' + esc(value) + '"' + attr + '>' + esc(label) + '</option>'


def render_wifi_profile_form(item=None):
    item = item or {}
    existing = bool(item.get("name"))
    name_value = item.get("name", "")
    ssid_value = item.get("ssid", "")
    priority_value = item.get("priority", "10") or "10"
    autoconnect = str(item.get("autoconnect", "yes")).lower() in ("yes", "yes", "true", "1")
    name_control = (
        '<input name="name" value="' + esc(name_value) + '" required readonly>'
        if existing
        else '<input name="name" placeholder="e.g. Workshop WiFi" required>'
    )
    return (
        '<form method="post" action="/wifi/save" class="form-grid">'
        + form_field(
            "Verbindungsname",
            name_control,
            "NetworkManager profile name. Existing profiles are updated through this name.",
        )
        + form_field(
            "SSID",
            '<input name="ssid" value="' + esc(ssid_value) + '" placeholder="Workshop-WiFi" required>',
            "SSID exactly as configured on the access point. No scan is started.",
        )
        + form_field(
            "Wi-Fi password",
            '<input type="password" name="psk" value="" autocomplete="off">',
            "Required for new profiles. Leave empty for existing profiles if it should remain unchanged.",
        )
        + form_field(
            "Priority",
            '<input type="number" name="priority" value="' + esc(priority_value) + '" min="-999" max="999" required>',
            "Higher priority prefers this profile when multiple are known.",
        )
        + '<div class="form-field field-inline"><label><input type="checkbox" name="autoconnect" value="1"'
        + (" checked" if autoconnect else "")
        + '> Connect automatically</label><div class="field-help">NetworkManager may choose this profile automatically.</div></div>'
        + '<button type="submit">Save Wi-Fi profile</button>'
        + '</form>'
    )


def render_wifi_ip_form(item):
    name = item.get("name", "")
    method = item.get("ipv4_method") or "auto"
    if method not in ("auto", "manual", "disabled"):
        method = "auto"
    return (
        '<form method="post" action="/wifi/ip-save" class="form-grid">'
        '<input type="hidden" name="name" value="' + esc(name) + '">'
        + form_field(
            "IPv4 method",
            '<select name="method">'
            + select_option("auto", "Automatic (DHCP)", method)
            + select_option("manual", "Manual", method)
            + select_option("disabled", "IPv4 disabled", method)
            + '</select>',
            "Use manual mode only when address, prefix and gateway are known.",
        )
        + form_field(
            "Address/prefix",
            '<input name="address" value="' + esc(item.get("ipv4_addresses", "")) + '" placeholder="198.51.100.25/24">',
            "Required only for manual mode. CIDR format with prefix, e.g. /24.",
        )
        + form_field(
            "Gateway",
            '<input name="gateway" value="' + esc(item.get("ipv4_gateway", "")) + '" placeholder="198.51.100.1">',
            "Optional, but usually required for internet/Git/Telegram.",
        )
        + form_field(
            "DNS",
            '<input name="dns" value="' + esc(item.get("ipv4_dns", "")) + '" placeholder="198.51.100.1, 1.1.1.1">',
            "Optional. Separate multiple DNS servers with commas or spaces.",
        )
        + '<button type="submit">Save IP settings</button>'
        + '</form>'
    )



    min_value, max_value = NETWORK_GUARDIAN_INTEGER_LIMITS[key]
    return (
        '<input type="number" name="' + esc(key) + '" value="' + esc(value) + '" '
        'min="' + esc(min_value) + '" max="' + esc(max_value) + '" required>'
    )



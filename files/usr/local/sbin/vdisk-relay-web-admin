def render_wifi_profile_dialogs(profiles):
    dialogs = []
    for index, item in enumerate(profiles):
        dialogs.append(
            render_wifi_dialog(
                "wifi-profile-edit-" + str(index),
                "Edit profile: " + item.get("name", ""),
                '<section class="subpanel"><h3>Profile</h3>'
                + render_wifi_profile_form(item)
                + '</section>'
                + '<section class="subpanel"><h3>IPv4</h3>'
                + '<p class="muted">IP settings become active on the next connection or reconnect.</p>'
                + render_wifi_ip_form(item)
                + '</section>',
            )
        )
    return "".join(dialogs)


def render_wifi_signal_cell(percent):
    value = wifi_signal_percent_value(percent)
    label = "-" if value is None else str(value) + " %"
    css_class = wifi_signal_quality_class(value)
    width = str(value if value is not None else 0)
    return (
        '<div class="wifi-scan-signal">'
        '<div class="wifi-signal-bar ' + esc(css_class) + '" role="img" aria-label="Signal strength ' + esc(label) + '">'
        '<span class="wifi-signal-fill" style="width:' + esc(width) + '%"></span>'
        '</div><b>' + esc(label) + '</b></div>'
    )


def render_wifi_scan_panel(show_scan=False):
    if not show_scan:
        return ""

    scan = load_wifi_scan_cache()
    rows = []
    for item in scan.get("items", []):
        active = '<span class="badge ok">active</span>' if item.get("active") else "-"
        rows.append(
            "<tr>"
            '<th data-label="SSID">' + esc(item.get("ssid") or "-") + "</th>"
            '<td data-label="Signal">' + render_wifi_signal_cell(item.get("signal")) + "</td>"
            '<td data-label="Kanal">' + esc(item.get("channel") or "-") + "</td>"
            '<td data-label="Rate">' + esc(item.get("rate") or "-") + "</td>"
            '<td data-label="Sicherheit">' + esc(item.get("security") or "-") + "</td>"
            '<td data-label="Active">' + active + "</td>"
            "</tr>"
        )
    if not rows:
        rows.append('<tr><td colspan="6">No scan results available.</td></tr>')

    error = scan.get("error", "")
    error_html = '<p class="bad">' + esc(error) + '</p>' if error else ""
    return (
        '<section class="panel">'
        '<h2>Wi-Fi-Scan</h2>'
        '<p class="muted">Last manual scan: ' + esc(scan.get("generated_at", "unknown")) + '. A scan may briefly affect the connection.</p>'
        + error_html
        + '<table class="responsive-table wifi-scan-table"><thead><tr><th>SSID</th><th>Signal</th><th>Channel</th><th>Rate</th><th>Security</th><th>Active</th></tr></thead><tbody>'
        + "".join(rows)
        + '</tbody></table>'
        + '</section>'
    )


def network_guardian_config_values():
    text = read_file(CONFIG)
    values = {}
    for key, _label, default in NETWORK_GUARDIAN_CONFIG_FIELDS:
        if isinstance(default, int):
            values[key] = parse_int_config_value(text, key, default)
        else:
            values[key] = parse_shell_var(text, key, default)
    return values



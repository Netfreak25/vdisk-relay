def render_videos_page_workstation(query=None, as_json=False):
    query = query or {}
    params = parse_video_page_params(query)
    selected = params["f"]
    page = params["page"]
    per = params["per"]
    search = params["q"]
    source = params["source"]
    day = params["day"]

    videos = list_recent_videos()
    catalog_meta = dict(VIDEO_CATALOG_META)
    delete_queue_status = load_video_delete_queue_status()
    root = data_root()
    search_lc = search.lower()

    def matches_search(video):
        if not search_lc:
            return True
        haystack = video.get("search_blob", "")
        if not haystack:
            haystack = (
                video["name"]
                + " "
                + video["rel"]
                + " "
                + video["label"]
                + " "
                + video["mtime"]
                + " "
                + video["date"]
            ).lower()
        return search_lc in haystack

    search_videos = [v for v in videos if matches_search(v)]
    if day:
        search_videos = [v for v in search_videos if v.get("date") == day]

    counts = {}
    labels = {}
    for v in search_videos:
        counts[v["label_key"]] = counts.get(v["label_key"], 0) + 1
        labels[v["label_key"]] = v["label"]

    if source != "all" and source not in counts:
        source = "all"

    if source == "all":
        filtered = search_videos
    else:
        filtered = [v for v in search_videos if v["label_key"] == source]

    total = len(filtered)
    total_pages = max(1, (total + per - 1) // per)
    if page > total_pages:
        page = total_pages
    if page < 1:
        page = 1
    start = (page - 1) * per
    end = start + per
    page_items = filtered[start:end]

    selected_rel = ""
    selected_index = -1
    selected_video = None
    if selected:
        for idx, v in enumerate(filtered):
            if v["rel"] == selected:
                selected_index = idx
                selected_rel = v["rel"]
                selected_video = v
                break
        if selected_index >= 0:
            target_page = (selected_index // per) + 1
            if target_page != page:
                page = target_page
                start = (page - 1) * per
                end = start + per
                page_items = filtered[start:end]
    else:
        if page_items:
            selected = page_items[0]["rel"]
            selected_rel = page_items[0]["rel"]
            selected_video = page_items[0]
            selected_index = start

    if selected and not selected_rel and page_items:
        selected = page_items[0]["rel"]
        selected_rel = page_items[0]["rel"]
        selected_video = page_items[0]
        selected_index = start

    if selected_rel:
        try:
            full, selected_rel = safe_video_path(selected_rel)
            if selected_video is None:
                st = os.stat(full)
                selected_info = video_time_info(full, st.st_mtime)
                selected_video = {
                    "label": source_label_from_name(os.path.basename(full)),
                    "mtime": selected_info["display"],
                    "size": human_bytes(st.st_size),
                }
            prev_button = ""
            next_button = ""
            if selected_index > 0:
                prev_video = filtered[selected_index - 1]
                prev_page = (selected_index - 1) // per + 1
                prev_url = esc(videos_page_url(prev_page, per, search, source, day, prev_video["rel"]))
                prev_button = (
                    '<a class="button secondary" data-icon="prev" data-video-load="'
                    + prev_url
                    + '" href="'
                    + prev_url
                    + '">' + esc(t("media.previous")) + '</a>'
                )
            if selected_index >= 0 and selected_index + 1 < len(filtered):
                next_video = filtered[selected_index + 1]
                next_page = (selected_index + 1) // per + 1
                next_url = esc(videos_page_url(next_page, per, search, source, day, next_video["rel"]))
                next_button = (
                    '<a class="button secondary" data-icon="next" data-video-load="'
                    + next_url
                    + '" href="'
                    + next_url
                    + '">' + esc(t("phrase.next")) + '</a>'
                )

            selected_label = esc(selected_video.get("label", "Data"))
            selected_time = esc(selected_video.get("mtime", ""))
            selected_size = esc(selected_video.get("size", ""))
            player = (
                '<section class="video-player">'
                '<h2>' + selected_label + '</h2>'
                '<p>' + selected_time + '</p>'
                + media_player_html(selected_rel, selected_video, defer_src=True)
                + '<div class="player-actions">'
                + prev_button
                + next_button
                + '<a class="button" href="/file?f=' + quote(selected_rel) + '">' + esc(t("phrase.open_direct")) + '</a>'
                + '<a class="button secondary" href="/file?f=' + quote(selected_rel) + '&download=1">' + esc(t("phrase.download")) + '</a>'
                + '</div>'
                + '<div class="stat"><span>' + esc(t("phrase.source")) + '</span><b>' + selected_label + '</b></div>'
                + '<div class="stat"><span>' + esc(t("media.recording_time")) + '</span><b>' + selected_time + '</b></div>'
                + '<div class="stat"><span>' + esc(t("phrase.auto.file_size_45d0df35")) + '</span><b>' + selected_size + '</b></div>'
                + '</section>'
            )
        except Exception as exc:
            player = '<section class="video-player"><h2>File cannot be opened</h2><pre>' + esc(exc) + '</pre></section>'
    else:
        player = '<section class="video-player"><h2>No file found</h2><p>No data found on the current page.</p></section>'

    source_options = ['<option value="all"' + (" selected" if source == "all" else "") + '>' + esc(t("media.all_sources")) + ' (' + str(len(search_videos)) + ')</option>']
    for key in sorted(counts):
        label = labels.get(key, key[:1].upper() + key[1:])
        source_options.append(
            '<option value="'
            + esc(key)
            + ('" selected>' if source == key else '">')
            + esc(label)
            + ' ('
            + str(counts[key])
            + ')</option>'
        )

    per_options = []
    for opt in [12, 24, 48]:
        per_options.append(
            '<option value="'
            + str(opt)
            + ('" selected>' if opt == per else '">')
            + str(opt)
            + '</option>'
        )

    extra_open = "1" if source != "all" or day or per != 24 else "0"
    search_form = (
        '<form class="video-filterbar" method="get" action="/data">'
        + '<div class="form-field field-search"><label>' + esc(t("phrase.search")) + '</label><input name="q" value="' + esc(search)
        + '" placeholder="' + esc(t("phrase.auto.date_time_or_source_d4b0a28c")) + '"></div>'
        + '<details class="video-filter-more" data-mobile-open="' + extra_open + '" open>'
        + '<summary>' + esc(t("phrase.filter")) + '</summary>'
        + '<div class="video-filter-extra">'
        + '<div class="form-field field-source"><label>' + esc(t("phrase.source")) + '</label><select name="source">' + ''.join(source_options) + '</select></div>'
        + '<div class="form-field"><label>' + esc(t("phrase.auto.date_eb9a4bc1")) + '</label><input name="day" value="'
        + esc(day) + '" inputmode="numeric" placeholder="DD.MM.YYYY"></div>'
        + '<div class="form-field"><label>' + esc(t("phrase.auto.per_page_e9a13832")) + '</label><select name="per">' + ''.join(per_options) + '</select></div>'
        + '</div></details>'
        + '<button type="submit">' + esc(t("phrase.apply")) + '</button>'
        + '</form>'
    )

    def page_link(label, target_page, kind=""):
        if target_page < 1 or target_page > total_pages:
            class_name = "page-link disabled" + (" " + kind if kind else "")
            return '<span class="' + class_name + '">' + esc(label) + '</span>'
        url = esc(videos_page_url(target_page, per, search, source, day))
        class_name = "page-link" + (" " + kind if kind else "") + (" active" if target_page == page else "")
        return (
            '<a class="' + class_name + '" data-video-load="'
            + url
            + '" href="'
            + url
            + '">'
            + esc(label)
            + '</a>'
        )

    page_links = []
    page_links.append(page_link("Back", page - 1, "page-prev"))
    window = sorted(set([1, total_pages, page - 2, page - 1, page, page + 1, page + 2]))
    last_page = 0
    for p in window:
        if p < 1 or p > total_pages:
            continue
        if last_page and p - last_page > 1:
            page_links.append('<span class="page-link disabled page-ellipsis">...</span>')
        page_links.append(page_link(str(p), p, "page-number"))
        last_page = p
    page_links.append(page_link("Next", page + 1, "page-next"))
    pagination = (
        '<nav class="pagination video-pagination" aria-label="' + esc(t("media.clip_pages_aria")) + '">'
        '<div class="pagination-controls">'
        + ''.join(page_links)
        + '</div><span class="page-status-mobile">Page '
        + str(page)
        + " / "
        + str(total_pages)
        + "</span></nav>"
    )

    cards = []
    for v in page_items:
        rel = v["rel"]
        rel_escaped = esc(rel)
        source_label = (v.get("label") or "Data")
        source_label_html = esc(source_label)
        status_entry = delete_queue_status.get(rel, {})
        delete_status = str((status_entry or {}).get("status", "") or "")
        delete_status_class = video_delete_queue_status_class(delete_status) if delete_status else ""
        delete_status_text = video_delete_queue_status_text(delete_status) if delete_status else ""
        item_open_cls = " is-opened" if rel == selected_rel else ""
        status_line = ""
        if delete_status_text:
            status_line = (

def captive_normal_response(path):
    if path in ("/generate_204", "/gen_204"):
        return {"code": 204, "content_type": "text/plain; charset=utf-8", "body": ""}
    content_type, body = CAPTIVE_NORMAL_RESPONSES.get(
        path,
        ("text/plain; charset=utf-8", "OK\n"),
    )
    return {"code": 200, "content_type": content_type, "body": body}


def write_emergency_heartbeat(route="", session_id="", source="heartbeat"):
    route = str(route or "/wifi").replace("\r", " ").replace("\n", " ").strip()[:240] or "/wifi"
    session_id = str(session_id or "").replace("\r", "").replace("\n", "").strip()[:120]
    payload = {
        "last_seen": local_iso_now(),
        "route": route,
        "session_id": session_id,
        "source": source,
    }
    json_write_atomic(EMERGENCY_UI_ACTIVITY, payload, 0o644)
    return payload



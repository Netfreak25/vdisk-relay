        + esc(t("bulkActions.clear"))
        + '</button>'
        + '<button type="button" class="button danger" data-video-bulk-action="delete">'
        + esc(t("bulkActions.delete_selected"))
        + '</button>'
        + '</div>'
        + '</div>'
        + '<div class="video-result-meta">'
        + '<div>Page <b>' + str(page) + '</b> of <b>' + str(total_pages) + '</b>, '
        + '<b>' + str(total) + '</b> ' + esc(t("phrase.data")) + '</div>'
        + '<div><b>' + str(per) + '</b> ' + esc(t("phrase.auto.per_page_e9a13832")) + '</div>'

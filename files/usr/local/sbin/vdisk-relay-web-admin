    selected_bot_var = query.get("bot_var", [notify["bot_var"]])[0]
    selected_chat_var = query.get("chat_var", [notify["chat_var"]])[0]

    status_value = "active" if notify["enabled"] else "inactive"
    status_badge_class = "ok" if notify["enabled"] else "off"
    last_event = recent.get("last_boot_notify", "-") if isinstance(recent, dict) else "-"
    can_test = bool(notify["enabled"] and notify["ready"])
    can_enable = notify["ready"]
    enable_action = "/boot-notify/disable" if notify["enabled"] else "/boot-notify/enable"
    enable_label = "Disable" if notify["enabled"] else "Enable"
    enable_disabled = "" if notify["enabled"] or can_enable else " disabled"
    enable_title = (
        "Disable service"
        if notify["enabled"]
        else "Cannot be enabled: Boot notify configuration missing"
    )

    body = f"""
{msg_html(message)}
{settings_tabs("telegram")}
{settings_context("Telegram")}
{telegram_tabs("boot-notify")}

<section class="panel">
  <div class="panel-head-inline"><h2>State</h2><button type="button" class="secondary" data-open-dialog="boot-notify-edit">Edit</button></div>
  <p>State: <span class="badge {status_badge_class}">{esc(status_value)}</span></p>
  {render_kv_table([
      ("Bot-Variable", notify["bot_var"] or "-"),
      ("Chat-Variable", notify["chat_var"] or "-"),
      ("Chat type", notify["chat_type"] or "-"),
      ("Configuration", "eigene Werte" if notify["configured_bot_var"] else "Source fallback"),
      ("Latest boot notify", last_event),
  ])}
  {render_boot_notify_dialog(bot_vars, chat_vars, selected_bot_var, selected_chat_var)}
</section>

<section class="panel">
  <h2>Actions</h2>
  <form method="post" action="{enable_action}" onsubmit="return confirm('{enable_label}: Boot notify?');">
    <button type="submit" class="secondary"{enable_disabled} title="{esc(enable_title)}">{enable_label}</button>
  </form>
  <form method="post" action="/boot-notify/test" class="inline" onsubmit="return confirm('Send test message now?');">
    <button type="submit" class="secondary"{' disabled' if not can_test else ''} title="Enable and configure boot notify so a test can be sent.">Send test</button>
  </form>
</section>
"""
    return html_page("Boot notify", body, active="settings", subtitle="Configure boot message after restart.")


def preview_entry_rows(entries, video_map, empty_label):
    rows = []
    for entry in entries:
        if not isinstance(entry, dict):
            continue
        try:
            rel = normalize_file_rel(entry.get("rel", ""))
        except ValueError:
            continue
        info = video_map.get(rel, {})
        size = human_bytes(info.get("size", 0)) if isinstance(info, dict) else ""
        rows.append(
            "<tr>"
            '<th data-label="File">' + esc(os.path.basename(rel)) + "<br><small>" + esc(rel) + "</small></th>"
            '<td data-label="Size">' + esc(size or "-") + "</td>"
            '<td data-label="Error">' + esc(str(entry.get("fail_count", 0))) + " / long " + esc(str(entry.get("long_fail_count", 0))) + "</td>"
            '<td data-label="Last attempt">' + esc(entry.get("last_failure_at", "-")) + "<br><small>" + esc(entry.get("last_mode", "-")) + " / rc=" + esc(entry.get("last_rc", "-")) + "</small></td>"
            '<td data-label="stderr"><small>' + esc(entry.get("last_stderr", "-")) + "</small></td>"
            '<td class="actions" data-label="Action">'
            '<form method="post" action="/previews/release" class="inline">'
            '<input type="hidden" name="rel" value="' + esc(rel) + '">'
            '<button type="submit" class="secondary">Wieder versuchen</button>'
            "</form>"
            "</td>"
            "</tr>"
        )
    if not rows:
        return '<tr><td colspan="6">' + esc(empty_label) + "</td></tr>"
    return "".join(rows)


def preview_recent_rows(videos, index, day="", limit=80):
    rows = []
    for item in videos:
        if not isinstance(item, dict):
            continue
        if day and item.get("date") != day:
            continue
        rel = str(item.get("rel", ""))
        if rel not in index:
            continue
        try:
            rel = normalize_file_rel(rel)
        except ValueError:
            continue
        rows.append(
            "<tr>"
            '<th data-label="File">' + esc(os.path.basename(rel)) + "<br><small>" + esc(rel) + "</small></th>"
            '<td data-label="Date">' + esc(item.get("display", "-")) + "</td>"
            '<td data-label="Size">' + esc(human_bytes(item.get("size", 0))) + "</td>"
            '<td class="actions" data-label="Action">'
            '<form method="post" action="/previews/delete-preview" class="inline" onsubmit="return confirm(\'Delete preview and regenerate it?\');">'
            '<input type="hidden" name="rel" value="' + esc(rel) + '">'
            '<button type="submit" class="secondary">Delete preview</button>'
            "</form>"
            "</td>"
            "</tr>"
        )
        if len(rows) >= limit:
            break
    if not rows:
        return '<tr><td colspan="4">No existing previews in the current catalog.</td></tr>'
    return "".join(rows)


def default_preview_day(videos, index):
    for item in videos:
        if not isinstance(item, dict):
            continue
        if str(item.get("rel", "")) in index and item.get("date"):
            return str(item.get("date"))
    return ""


def render_previews_page(query=None, message=""):
    query = query or {}
    message = message or query.get("msg", [""])[0]
    stats = preview_stats()
    videos = stats["files"]
    video_map = {str(item.get("rel", "")): item for item in videos if isinstance(item, dict)}
    ignored = sorted(stats["ignored"], key=lambda item: str(item.get("ignored_at") or item.get("last_failure_at") or ""), reverse=True)
    retry = sorted(stats["retry"], key=lambda item: str(item.get("last_failure_at") or ""), reverse=True)
    config = stats["config"]
    service_active = systemctl_active(PREVIEW_SERVICE_UNIT)
    timer_active = systemctl_active(PREVIEW_TIMER_UNIT)
    timer_enabled = systemctl_enabled(PREVIEW_TIMER_UNIT)
    timer_action = "/previews/disable" if timer_enabled == "enabled" else "/previews/enable"
    timer_label = "Disable" if timer_enabled == "enabled" else "Enable"
    show_config_form = query.get("edit", ["0"])[0] == "1"
    preview_day = query.get("preview_day", [""])[0].strip()
    if not preview_day:
        preview_day = default_preview_day(videos, stats["index"])

    config_fields = []
    for key, label, _default, min_value, max_value, help_text in PREVIEW_CONFIG_FIELDS:
        config_fields.append(
            form_field(
                label,
                '<input type="number" name="' + esc(key) + '" value="' + esc(config.get(key, "")) + '" min="' + str(min_value) + '" max="' + str(max_value) + '" required>',
                help_text + " (" + key + ")",
            )
        )

    body = (
        msg_html(message)
        + settings_tabs("previews")
        + '<section class="grid grid-3">'
        + '<div class="stat-card"><b>' + esc(stats["video_count"]) + '</b><span>Data in catalog</span></div>'
        + '<div class="stat-card"><b>' + esc(stats["indexed_count"]) + '</b><span>Index entries</span></div>'
        + '<div class="stat-card"><b>' + esc(stats["preview_file_count"]) + '</b><span>Preview files</span></div>'
        + '<div class="stat-card"><b>' + esc(len(retry)) + '</b><span>Failures in backlog</span></div>'
        + '<div class="stat-card"><b>' + esc(len(ignored)) + '</b><span>Dauerhaft ignoriert</span></div>'
        + '<div class="stat-card"><b>' + esc(stats["eta"]) + '</b><span>Prognose Restlaufzeit</span></div>'
        + '</section>'
        + '<section class="panel">'
        + '<h2>State</h2>'
        + render_kv_table([
            ("Latest catalog run", stats["generated_at"] or file_mtime_label(DATA_INDEX)),
            ("files.json", DATA_INDEX),
            ("index.json", PREVIEW_INDEX),
            ("backlog.json", PREVIEW_BACKLOG),
            ("Service", service_active),
            ("Timer", timer_active + " / " + timer_enabled),
            ("Remaining without ignored data", str(stats["remaining"])),
            ("Estimated runs", str(stats["runs_left"])),
        ])
        + '<div class="actions">'
        + '<form method="post" action="/previews/run" class="inline"><button type="submit">Start run</button></form>'
        + '<form method="post" action="' + timer_action + '" class="inline"><button type="submit" class="secondary">' + timer_label + '</button></form>'
        + '<a class="button secondary" href="/service-journal?u=' + quote(PREVIEW_SERVICE_UNIT) + '">Journal</a>'
        + '</div>'
        + '</section>'
        + '<section class="panel">'
        + '<h2>Options</h2>'
        + render_kv_table([(label, str(config.get(key, ""))) for key, label, _default, _min_value, _max_value, _help_text in PREVIEW_CONFIG_FIELDS])
        + '<div class="actions"><a class="button secondary" href="/previews?edit=1#preview-options">Edit</a></div>'
        + ('<div id="preview-options">' if show_config_form else '<div id="preview-options" style="display:none">')
        + '<form method="post" action="/previews/config" class="form-grid">'
        + ''.join(config_fields)
        + '<button type="submit">Save preview options</button>'
        + '</form>'
        + '</div>'
        + '</section>'
        + '<section class="panel">'
        + '<h2>Dauerhaft ignoriert</h2>'
        + '<table class="responsive-table"><thead><tr><th>File</th><th>Size</th><th>Error</th><th>Last attempt</th><th>stderr</th><th>Action</th></tr></thead><tbody>'
        + preview_entry_rows(ignored, video_map, "No permanently ignored data.")
        + '</tbody></table>'
        + '</section>'
        + '<section class="panel">'
        + '<h2>Failures</h2>'
        + '<table class="responsive-table"><thead><tr><th>File</th><th>Size</th><th>Error</th><th>Last attempt</th><th>stderr</th><th>Action</th></tr></thead><tbody>'
        + preview_entry_rows(retry, video_map, "No open preview failures.")
        + '</tbody></table>'
        + '</section>'
        + '<section class="panel">'
        + '<h2>Vorhandene Previews</h2>'
        + '<form method="get" action="/previews" class="filterbar">'
        + '<div class="form-field"><label>Date</label><input name="preview_day" value="' + esc(preview_day) + '" placeholder="DD.MM.YYYY"></div>'
        + '<button type="submit">Suchen</button>'
        + '</form>'
        + '<table class="responsive-table"><thead><tr><th>File</th><th>Date</th><th>Size</th><th>Action</th></tr></thead><tbody>'
        + preview_recent_rows(videos, stats["index"], preview_day)
        + '</tbody></table>'
        + '</section>'
    )
    return html_page("Previews", body, active="settings", subtitle="Preview cache, backlog and service options.")



def data_root():
    return parse_shell_var(read_file(CONFIG), "DATA_ROOT", "/files")


def human_bytes(num):
    try:
        num = float(num)
    except Exception:
        return ""
    units = ["B", "KiB", "MiB", "GiB", "TiB"]
    idx = 0
    while num >= 1024 and idx < len(units) - 1:
        num /= 1024
        idx += 1
    if idx == 0:
        return str(int(num)) + " " + units[idx]
    return "{:.1f} {}".format(num, units[idx])


def load_preview_index():
    try:
        with open(PREVIEW_INDEX, "r", encoding="utf-8") as f:
            return json.load(f)
    except Exception:
        return {}


def preview_url_for_rel(rel):
    key = hashlib.sha1(rel.encode("utf-8")).hexdigest()
    path = os.path.join(PREVIEW_DIR, key + ".jpg")
    if os.path.exists(path) and os.path.getsize(path) > 0:
        return "/preview/" + key + ".jpg"
    return ""


def preview_key_for_rel(rel):
    return hashlib.sha1(rel.encode("utf-8")).hexdigest()


def preview_path_for_rel(rel):
    return os.path.join(PREVIEW_DIR, preview_key_for_rel(rel) + ".jpg")


def screensaver_idle_minutes():
    value = parse_int_config_value(read_file(CONFIG), "WEB_SCREENSAVER_IDLE_MINUTES", 0)
    return max(0, min(value, 1440))


def screensaver_mode():
    mode = config_value("WEB_SCREENSAVER_MODE", "floating").strip().lower()
    if mode in ("legacy", "floating"):
        return mode
    return "floating"


def screensaver_preview_payload(limit=36):
    catalog = load_video_catalog()
    videos = catalog.get("files", []) if isinstance(catalog, dict) else []
    index = load_preview_index()
    if not isinstance(index, dict):
        index = {}

    rows = []
    seen = set()

    def add_item(rel, meta=None):
        rel = str(rel or "").lstrip("/")
        if not rel or rel in seen or rel.startswith("../") or rel == ".." or os.path.isabs(rel):
            return
        url = preview_url_for_rel(rel)
        if not url:
            return
        meta = meta if isinstance(meta, dict) else {}
        seen.add(rel)
        rows.append(
            {
                "url": url,
                "title": source_label_from_name(os.path.basename(rel)),
                "label": str(meta.get("display") or meta.get("date") or os.path.basename(rel)),
            }
        )

    for item in videos:
        if len(rows) >= limit:
            break
        if isinstance(item, dict):
            add_item(item.get("rel", ""), item)

    if len(rows) < limit:
        for rel in index:
            if len(rows) >= limit:
                break
            add_item(rel)

    return {
        "ok": True,
        "generated_at": catalog.get("generated_at", "") if isinstance(catalog, dict) else "",
        "items": rows,
    }


def normalize_file_rel(rel):
    rel = unquote(rel or "").lstrip("/")
    rel = os.path.normpath(rel)
    if rel in ("", ".") or rel.startswith("../") or rel == ".." or os.path.isabs(rel):
        raise ValueError("Invalid file path")
    return rel


def write_json_file_atomic(path, data):
    os.makedirs(os.path.dirname(path), mode=0o755, exist_ok=True)
    content = json.dumps(data, ensure_ascii=False, indent=2, sort_keys=True) + "\n"
    write_atomic(path, content, 0o644)


def load_preview_backlog():
    data = load_json_file(PREVIEW_BACKLOG, {})
    if not isinstance(data, dict):
        return {}
    backlog = {}
    for rel, entry in data.items():
        if not isinstance(rel, str) or not isinstance(entry, dict):
            continue
        item = dict(entry)
        item["rel"] = item.get("rel") or rel
        backlog[rel] = item
    return backlog


def load_video_catalog():
    data = load_json_file(DATA_INDEX, {})
    if not isinstance(data, dict):
        return {}
    videos = data.get("files")
    if not isinstance(videos, list):
        data["files"] = []
    return data


def count_preview_files():
    try:
        return len([name for name in os.listdir(PREVIEW_DIR) if name.endswith(".jpg")])
    except Exception:
        return 0


def file_mtime_label(path):
    try:
        return time.strftime("%Y-%m-%d %H:%M:%S", time.localtime(os.path.getmtime(path)))
    except Exception:
        return "-"


def format_duration(seconds):
    try:
        seconds = int(seconds)
    except Exception:
        return "-"
    if seconds <= 0:
        return "0 min"
    minutes = max(1, (seconds + 59) // 60)
    if minutes < 60:
        return str(minutes) + " min"
    hours = minutes // 60
    rest = minutes % 60
    if hours < 48:
        return str(hours) + (" h" if rest == 0 else " h " + str(rest) + " min")
    days = hours // 24
    return str(days) + " d"


def preview_timer_interval_seconds():
    text = read_file("/etc/systemd/system/vdisk-relay-preview-cache.timer")
    match = re.search(r"^OnUnitInactiveSec=(\d+)(min|m|s|h)?$", text, re.M)
    if not match:
        return 600
    value = int(match.group(1))
    unit = match.group(2) or "s"
    if unit in ("min", "m"):
        return value * 60
    if unit == "h":
        return value * 3600
    return value


def preview_stats():
    catalog = load_video_catalog()
    videos = catalog.get("files", [])
    index = load_preview_index()
    if not isinstance(index, dict):
        index = {}
    backlog = load_preview_backlog()
    file_rels = {str(item.get("rel", "")) for item in videos if isinstance(item, dict) and item.get("rel")}
    indexed_rels = {rel for rel in index if rel in file_rels}
    ignored = [entry for rel, entry in backlog.items() if isinstance(entry, dict) and entry.get("ignored") and (not file_rels or rel in file_rels)]
    retry = [entry for rel, entry in backlog.items() if isinstance(entry, dict) and not entry.get("ignored") and (not file_rels or rel in file_rels)]
    remaining = max(0, len(file_rels) - len(indexed_rels) - len(ignored))
    config = preview_config_values()
    per_run = config.get("PREVIEW_NEW_PER_RUN", 0)
    attempts_per_run = config.get("PREVIEW_ATTEMPTS_PER_RUN", 0)
    if attempts_per_run > 0:
        per_run = min(per_run, attempts_per_run) if per_run > 0 else attempts_per_run
    runs_left = (remaining + per_run - 1) // per_run if per_run > 0 else 0
    eta_seconds = runs_left * preview_timer_interval_seconds() if runs_left else 0
    return {
        "catalog": catalog,
        "files": videos,
        "index": index,
        "backlog": backlog,
        "ignored": ignored,
        "retry": retry,
        "video_count": len(file_rels),
        "indexed_count": len(indexed_rels),
        "preview_file_count": count_preview_files(),
        "remaining": remaining,
        "runs_left": runs_left,
        "eta": format_duration(eta_seconds),
        "generated_at": catalog.get("generated_at", ""),
        "config": config,
    }


def safe_video_path(rel):
    root = os.path.realpath(data_root())
    rel = unquote(rel or "").lstrip("/")
    rel = os.path.normpath(rel)
    if rel in ("", ".") or rel.startswith("../") or rel == ".." or os.path.isabs(rel):
        raise ValueError("Invalid file path")
    full = os.path.realpath(os.path.join(root, rel))
    if not full.startswith(root + os.sep):
        raise ValueError("File path outside DATA_ROOT")
    if not os.path.isfile(full):
        raise FileNotFoundError("File not found")
    return full, rel


def _source_label_rules():
    try:
        config_mtime = os.path.getmtime(CONFIG)
    except Exception:
        config_mtime = None
    if SOURCE_LABEL_RULE_CACHE["version"] == config_mtime:
        return SOURCE_LABEL_RULE_CACHE["rules"]

    rules = []
    try:
        sources = parse_sources()
    except Exception:
        sources = []

    for source in sources:
        source_id = source.get("id", "").strip()
        pattern = source.get("pattern", "").strip()
        if not source_id:
            continue
        label = source_id.replace("_", " ").replace("-", " ").strip().title() or "Data"
        seen = set()
        needles = [source_id.lower()]
        cleaned_pattern = re.sub(r"[*?\[\]{}()]", " ", pattern.lower())
        cleaned_pattern = re.sub(r"\s+", " ", cleaned_pattern).strip()
        if cleaned_pattern:
            needles.extend(part for part in cleaned_pattern.split(" ") if len(part) >= 3)
        for needle in needles:
            needle = needle.strip().lower()
            if not needle or needle in seen:
                continue
            seen.add(needle)
            rules.append((needle, label))

    SOURCE_LABEL_RULE_CACHE["version"] = config_mtime
    SOURCE_LABEL_RULE_CACHE["rules"] = rules
    return rules


def source_label_from_name(name):
    lower = name.lower()
    for needle, label in _source_label_rules():
        if needle in lower:
            return label
    return "Data"


VIDEO_TIME_PATTERNS = [
    re.compile(
        r"(?P<y>20\d{2})[-_](?P<m>\d{2})[-_](?P<d>\d{2})"
        r"[ T_-]+(?P<h>\d{2})[-_:](?P<mi>\d{2})(?:[-_:](?P<s>\d{2}))?"
    ),
    re.compile(
        r"(?P<y>20\d{2})(?P<m>\d{2})(?P<d>\d{2})"
        r"[ T_-]?(?P<h>\d{2})(?P<mi>\d{2})(?P<s>\d{2})"
    ),
]


def video_display_tz_for_name(tz_name):
    tz_name = str(tz_name or DEFAULT_WEB_DISPLAY_TIMEZONE).strip() or DEFAULT_WEB_DISPLAY_TIMEZONE
    if VIDEO_DISPLAY_TZ_CACHE.get("name") == tz_name:
        return VIDEO_DISPLAY_TZ_CACHE["tz"]

    tz = None
    if tz_name.upper() == "UTC":
        tz = timezone.utc
    elif ZoneInfo is not None:
        try:
            tz = ZoneInfo(tz_name)
        except Exception:
            pass
    VIDEO_DISPLAY_TZ_CACHE.update({"name": tz_name, "tz": tz})
    return tz


def parse_video_utc_datetime(name):
    for pattern in VIDEO_TIME_PATTERNS:
        match = pattern.search(name)
        if not match:
            continue
        try:
            second = int(match.groupdict().get("s") or "0")
            return datetime(
                int(match.group("y")),
                int(match.group("m")),
                int(match.group("d")),
                int(match.group("h")),
                int(match.group("mi")),
                second,
                tzinfo=timezone.utc,
            )
        except ValueError:
            continue
    return None


def timezone_offset_label(dt, tz_name=None):
    offset = dt.utcoffset()
    if offset is None:
        return tz_name or web_display_timezone_name()
    minutes = int(offset.total_seconds() // 60)
    sign = "+" if minutes >= 0 else "-"
    minutes = abs(minutes)
    return "UTC" + sign + "{:02d}:{:02d}".format(minutes // 60, minutes % 60)


def last_sunday_utc(year, month):
    day = 31
    dt = datetime(year, month, day, 1, 0, 0, tzinfo=timezone.utc)
    while dt.weekday() != 6:
        dt -= timedelta(days=1)
    return dt


def berlin_fallback_local_time(utc_dt):
    start = last_sunday_utc(utc_dt.year, 3)
    end = last_sunday_utc(utc_dt.year, 10)
    offset_hours = 2 if start <= utc_dt < end else 1
    return utc_dt + timedelta(hours=offset_hours), "UTC+{:02d}:00".format(offset_hours)


def video_time_info(path, mtime):
    display_tz_name = web_display_timezone_name()
    return video_time_info_for_display(path, mtime, display_tz_name, video_display_tz_for_name(display_tz_name))


def video_time_info_for_display(path, mtime, display_tz_name, tz):
    name = os.path.basename(path)
    utc_dt = parse_video_utc_datetime(name)
    if utc_dt is not None:
        if tz:
            local_dt = utc_dt.astimezone(tz)
            offset_label = timezone_offset_label(local_dt, display_tz_name)
        elif display_tz_name == DEFAULT_WEB_DISPLAY_TIMEZONE:
            local_dt, offset_label = berlin_fallback_local_time(utc_dt)
        else:
            local_dt = utc_dt
            offset_label = "UTC+00:00"
        tz_label = display_tz_name + " " + offset_label
        return {
            "sort_ts": int(utc_dt.timestamp()),
            "display": local_dt.strftime("%H:%M %d.%m.%y"),
            "date": local_dt.strftime("%d.%m.%Y"),
            "source": "Filename UTC -> " + tz_label,
        }

    if tz:
        local_dt = datetime.fromtimestamp(mtime, timezone.utc).astimezone(tz)
        offset_label = timezone_offset_label(local_dt, display_tz_name)
    elif display_tz_name == DEFAULT_WEB_DISPLAY_TIMEZONE:
        local_dt, offset_label = berlin_fallback_local_time(datetime.fromtimestamp(mtime, timezone.utc))
    else:
        local_dt = datetime.fromtimestamp(mtime, timezone.utc)
        offset_label = "UTC+00:00"
    return {
        "sort_ts": int(mtime),
        "display": local_dt.strftime("%H:%M %d.%m.%y"),
        "date": local_dt.strftime("%d.%m.%Y"),
        "source": "File-mtime -> " + display_tz_name + " " + offset_label,
    }


def video_delete_queue_status_text(status):
    status = str(status or "").strip()
    key = VIDEO_DELETE_QUEUE_STATUS_TEXT_KEYS.get(status, VIDEO_DELETE_QUEUE_STATUS_UNKNOWN_KEY)
    return t(key)


def video_delete_queue_status_class(status):
    status = str(status or "").strip()
    if status in {"queued_for_delete", "pending", "deleting"}:
        return "warn"
    if status == "failed_delete":
        return "bad"
    if status == "deleted":
        return "ok"
    if status == "ignored":
        return "muted"
    return "muted"


def video_delete_is_eligible_by_age(full, status_entry=None):
    try:
        mtime = os.path.getmtime(full)
    except Exception:
        return False
    if VIDEO_DELETE_QUEUE_MIN_FILE_AGE_SECONDS <= 0:
        return True
    entry_mtime = 0
    if isinstance(status_entry, dict):
        entry_mtime = int(status_entry.get("file_mtime", 0) or 0)
    if entry_mtime and int(mtime) != entry_mtime:
        return True
    return (time.time() - mtime) >= VIDEO_DELETE_QUEUE_MIN_FILE_AGE_SECONDS


def queue_videos_for_delete(video_rels):
    now_iso = local_iso_now()
    queued = []
    skipped = []
    if not isinstance(video_rels, (list, tuple, set)):
        return queued, skipped

    rels = []
    for rel in video_rels:
        if not isinstance(rel, str):
            continue
        rel = rel.strip().lstrip("/")
        if not rel:
            continue
        if rel not in rels:
            rels.append(rel)

    if not rels:
        return queued, skipped

    def mutator(data):
        changed = False
        items = data.setdefault("items", {})
        for rel in rels:
            try:
                full, normalized = safe_video_path(rel)
            except Exception as exc:
                skipped.append({"rel": rel, "reason": str(exc)})
                continue
            if not _is_file_deletable(normalized):
                skipped.append({"rel": rel, "reason": "temp-file"})
                continue
            try:
                mtime = os.path.getmtime(full)
                if not video_delete_is_eligible_by_age(full, items.get(rel)):
                    skipped.append({"rel": rel, "reason": "too-new"})
                    continue
            except Exception as exc:
                skipped.append({"rel": rel, "reason": str(exc)})
                continue

            existing = items.get(rel)
            if not isinstance(existing, dict):
                items[rel] = _new_delete_queue_entry(normalized, full, now_iso)
                queued.append(normalized)
                changed = True
                continue

            status = existing.get("status")
            if status == "queued_for_delete":
                continue
            if status == "deleting":
                continue
            if status == "deleted":
                continue
            if status == "failed_delete" and int(existing.get("attempts", 0)) < VIDEO_DELETE_QUEUE_MAX_RETRIES:
                existing["status"] = "queued_for_delete"
                existing["attempts"] = max(0, int(existing.get("attempts", 0)))
                existing["last_error"] = ""
                existing["next_attempt_at"] = now_iso
                existing["updated_at"] = now_iso
                existing["file_mtime"] = int(mtime)
                queued.append(normalized)
                changed = True
            elif status == "ignored":
                continue
            else:
                continue
        return changed

    data = update_video_delete_queue(mutator)
    return queued, skipped


def pop_next_video_delete_job():
    now = time.time()
    queue = read_video_delete_queue()
    items = queue.get("items", {})
    ready_rel = ""
    for rel, item in items.items():
        if not isinstance(item, dict):
            continue
        status = item.get("status")
        if status != "queued_for_delete":
            continue
        attempts = int(item.get("attempts", 0))
        if attempts >= VIDEO_DELETE_QUEUE_MAX_RETRIES:
            continue
        next_ts = _parse_queue_retry_timestamp(item.get("next_attempt_at"))
        if next_ts is not None and next_ts > now:
            continue
        ready_rel = rel
        break
    return ready_rel, dict(items.get(ready_rel, {})) if isinstance(items.get(ready_rel), dict) else {}


def _set_video_delete_status(rel, status, updates):
    rel = str(rel or "").strip()
    now_iso = local_iso_now()
    def mutator(data):
        items = data.setdefault("items", {})
        entry = items.get(rel)
        if not isinstance(entry, dict):
            return False
        entry["status"] = status
        if status == "queued_for_delete":
            entry["attempts"] = int(entry.get("attempts", 0))
        entry["updated_at"] = now_iso
        entry["last_error"] = str(updates.get("last_error", "")) if isinstance(updates, dict) else ""
        if isinstance(updates, dict):
            for key, value in updates.items():
                if key in ("status", "next_attempt_at", "attempts", "last_error", "updated_at"):
                    entry[key] = value
        return True
    return update_video_delete_queue(mutator)


def _delete_video_file(rel, entry, delete_preview):
    try:
        full, normalized = safe_video_path(rel)
    except Exception as exc:
        _set_video_delete_status(rel, "failed_delete", {"last_error": str(exc)})
        return {
            "ok": False,
            "last_error": str(exc),
        }
    if os.path.isdir(full):
        _set_video_delete_status(rel, "failed_delete", {"last_error": "not a file"})
        return {"ok": False, "last_error": "not a file"}
    if not _is_file_deletable(normalized):
        _set_video_delete_status(rel, "ignored", {"last_error": "temporary file"})
        return {"ok": False, "last_error": "temporary file"}
    if not video_delete_is_eligible_by_age(full, entry):
        now_iso = local_iso_now()
        _set_video_delete_status(
            rel,
            "queued_for_delete",
            {
                "last_error": "file too new for deletion",
                "next_attempt_at": (datetime.fromtimestamp(time.time() + VIDEO_DELETE_QUEUE_MIN_FILE_AGE_SECONDS, timezone.utc)).astimezone().isoformat(timespec="seconds"),
            },
        )
        return {"ok": False, "last_error": "file too new for deletion"}
    try:
        os.unlink(full)
    except Exception as exc:
        return {
            "ok": False,
            "last_error": str(exc),
            "attempts": int(entry.get("attempts", 0)) + 1 if isinstance(entry, dict) else 1,
        }

    preview_error = ""
    if delete_preview:
        try:
            _, removed = delete_preview_for_rel(rel)
            if removed:
                preview_error = ""
        except Exception as exc:
            preview_error = "preview delete failed: " + str(exc)

    return {
        "ok": True,
        "last_error": preview_error,
    }


def video_delete_worker_once():
    rel, entry = pop_next_video_delete_job()
    if not rel:
        return False
    now_iso = local_iso_now()
    delete_preview = int(parse_int_config_value(read_file(CONFIG), "DELETE_PREVIEW_WITH_VIDEO", 0) or 0) == 1
    _set_video_delete_status(
        rel,
        "deleting",
        {"last_error": "", "updated_at": now_iso, "next_attempt_at": now_iso},
    )
    result = _delete_video_file(rel, entry if isinstance(entry, dict) else {}, delete_preview)
    if result.get("ok"):
        _set_video_delete_status(
            rel,
            "deleted",
            {
                "last_error": str(result.get("last_error", "") or ""),
                "updated_at": local_iso_now(),
            },
        )
        return True

    current = read_video_delete_queue().get("items", {}).get(rel, {})
    attempts = int(result.get("attempts", 0) or int(current.get("attempts", 0) if isinstance(current, dict) else 0))
    if attempts >= VIDEO_DELETE_QUEUE_MAX_RETRIES:
        _set_video_delete_status(
            rel,
            "failed_delete",
            {
                "attempts": attempts,
                "updated_at": local_iso_now(),
                "next_attempt_at": "",
            },
        )
        return True

    delay = _next_delete_retry_delay_seconds(attempts)
    next_iso = datetime.fromtimestamp(time.time() + delay, timezone.utc).astimezone().isoformat(timespec="seconds")
    _set_video_delete_status(
        rel,
        "queued_for_delete",
        {
            "attempts": attempts,
            "updated_at": local_iso_now(),
            "next_attempt_at": next_iso,
            "last_error": str(current.get("last_error", "")) if isinstance(current, dict) else "",
        },
    )
    return True


def start_video_delete_worker():
    started = False
    thread_name = "video-delete-worker"
    for t in threading.enumerate():
        if t.name == thread_name and t.is_alive():
            started = True
            break
    if started:
        return

    def run():
        while True:
            did_work = False
            try:
                did_work = video_delete_worker_once()
            except Exception:
                did_work = False
            time.sleep(VIDEO_DELETE_QUEUE_DEQUEUE_SLEEP_SECONDS if did_work else 0.8)

    thread = threading.Thread(target=run, name=thread_name, daemon=True)
    thread.start()


def parse_video_page_params(query):
    def parse_int(name, default, allowed=None, minimum=1, maximum=500):
        raw = query.get(name, [str(default)])[0]
        try:
            value = int(raw)
        except Exception:
            value = default
        if allowed and value not in allowed:
            value = default
        return max(minimum, min(maximum, value))

    raw_day = query.get("day", [""])[0].strip()
    day = raw_day if re.fullmatch(r"\d{2}\.\d{2}\.\d{4}", raw_day) else ""

    return {
        "page": parse_int("page", 1, minimum=1, maximum=9999),
        "per": parse_int("per", 24, allowed=[12, 24, 48], minimum=12, maximum=48),
        "q": query.get("q", [""])[0].strip()[:120],
        "source": query.get("source", ["all"])[0].strip().lower()[:80] or "all",
        "f": query.get("f", [""])[0],
        "day": day,
    }


def videos_page_url(page=1, per=24, q="", source="all", day="", selected=""):
    params = {}
    if page > 1:
        params["page"] = str(page)
    if per != 24:
        params["per"] = str(per)
    if q:
        params["q"] = q
    if source and source != "all":
        params["source"] = source
    if day:
        params["day"] = day
    if selected:
        params["f"] = selected
    return "/data" + ("?" + urlencode(params) if params else "")


def cached_video_entries(max_files=5000):
    global VIDEO_CATALOG_META
    max_files = max(1, int(max_files))
    root = os.path.realpath(data_root())
    display_timezone = web_display_timezone_name()

    rules = _source_label_rules()
    rules_version = SOURCE_LABEL_RULE_CACHE["version"]
    cache = VIDEO_LIST_CACHE

    try:
        st = os.stat(DATA_INDEX)
        file_mtime = st.st_mtime_ns
        file_size = st.st_size
    except FileNotFoundError:
        with VIDEO_LIST_CACHE_LOCK:
            cache.update({
                "file_mtime": None,
                "file_size": None,
                "max_files": 0,
                "rules_version": None,
                "display_timezone": "",
                "items": [],
                "meta": {},
            })
        return None

    with VIDEO_LIST_CACHE_LOCK:
        if (
            cache.get("file_mtime") == file_mtime
            and cache.get("file_size") == file_size
            and cache.get("max_files") >= max_files
            and cache.get("rules_version") == rules_version
            and cache.get("display_timezone") == display_timezone
        ):
            meta = cache.get("meta", {})
            if meta.get("root") == root and cache.get("items"):
                VIDEO_CATALOG_META = dict(meta)
                return cache["items"][:max_files]

        data = load_json_file(DATA_INDEX, {})
        if not isinstance(data, dict):
            return None
        if os.path.realpath(data.get("root", "")) != root:
            return None

        raw_items = data.get("files")
        if not isinstance(raw_items, list):
            return None

        display_tz = video_display_tz_for_name(display_timezone)
        items = []
        for item in raw_items:
            if not isinstance(item, dict):
                continue

            rel = str(item.get("rel", "")).lstrip("/")
            if not rel or rel.startswith("../") or rel == ".." or os.path.isabs(rel):
                continue

            try:
                mtime = int(item.get("mtime", 0))
            except Exception:
                mtime = 0

            try:
                size = int(item.get("size", 0))
            except Exception:
                size = 0

            try:
                sort_ts = int(item.get("sort_ts", mtime))
            except Exception:
                sort_ts = mtime

            info = video_time_info_for_display(os.path.join(root, rel), mtime, display_timezone, display_tz)
            display = info["display"]
            date_label = info["date"]
            sort_ts = info.get("sort_ts", sort_ts)

            name = os.path.basename(rel)
            name_lower = name.lower()
            extension = str(item.get("extension") or os.path.splitext(name)[1].lstrip(".")).lower()
            media_type = str(item.get("media_type") or mimetypes.guess_type(name)[0] or "other")
            if "/" in media_type:
                media_type = media_type.split("/", 1)[0]
            source_id = str(item.get("source_id") or "").strip()
            profile = str(item.get("profile") or "").strip()
            telegram_mode = str(item.get("telegram_mode") or "auto").strip() or "auto"
            label = "Data"
            for needle, candidate in rules:
                if needle in name_lower:
                    label = candidate
                    break
            label_key = label.lower()
            search_blob = f"{name} {rel} {label} {display} {date_label}".lower()

            items.append({
                "rel": rel,
                "name": name,
                "label": label,
                "label_key": label_key,
                "extension": extension,
                "media_type": media_type,
                "source_id": source_id,
                "profile": profile,
                "telegram_mode": telegram_mode,
                "mtime": display,
                "date": date_label,
                "sort_ts": int(sort_ts),
                "size": human_bytes(size),
                "size_raw": size,
                "search_blob": search_blob,
                "url": "/file?f=" + quote(rel),
                "download_url": "/file?f=" + quote(rel) + "&download=1",
                "page_base": "/data?f=" + quote(rel),
            })

        items.sort(key=lambda item: item["sort_ts"], reverse=True)

        cache.update({
            "file_mtime": file_mtime,
            "file_size": file_size,
            "max_files": max(len(items), max_files),
            "rules_version": rules_version,
            "display_timezone": display_timezone,
            "items": items,
            "meta": {
                "source": "Cache",
                "generated_at": data.get("generated_at", ""),
                "count": data.get("count", len(items)),
                "root": root,
                "display_timezone": display_timezone,
            },
        })

        VIDEO_CATALOG_META = dict(cache["meta"])
        return items[:max_files]


def list_recent_videos(max_files=5000):
    entries = cached_video_entries(max_files)
    if entries is None:
        global VIDEO_CATALOG_META
        VIDEO_CATALOG_META = {
            "source": "Cache missing",
            "generated_at": "",
            "count": 0,
            "missing": True,
            "refresh_rc": 0,
            "refresh_message": "Catalog is not ready yet or invalid.",
        }
        return []

    return [
        {
            "rel": item["rel"],
            "name": item["name"],
            "mtime": item["mtime"],
            "date": item["date"],
            "sort_ts": item["sort_ts"],
            "size": item["size"],
            "extension": item.get("extension", ""),
            "media_type": item.get("media_type", "video"),
            "url": item["url"],
            "download_url": item["download_url"],
            "page_base": item["page_base"],
            "label": item["label"],
            "label_key": item["label_key"],
            "search_blob": item.get("search_blob", ""),
        }
        for item in entries[:max_files]
    ]


def media_player_html(rel, item=None, defer_src=False):
    item = item if isinstance(item, dict) else {}
    media_type = item.get("media_type") or "other"
    url = "/file?f=" + quote(rel)
    if media_type == "video":
        poster_url = preview_url_for_rel(rel)
        poster_attr = ' poster="' + esc(poster_url) + '"' if poster_url else ""
        src_attr = ' data-video-src="' + esc(url) + '"' if defer_src else ' src="' + esc(url) + '"'
        return '<video controls preload="none"' + poster_attr + src_attr + "></video>"
    if media_type == "image":
        return '<img class="data-media-image" src="' + url + '" alt="">'
    if media_type == "audio":
        return '<audio controls preload="metadata" src="' + url + '"></audio>'
    return '<div class="data-media-fallback"><span>' + esc(item.get("extension") or media_type or "file") + '</span><a class="button" href="' + url + '">Open file</a></div>'



        '<div class="modal-body">'
        + content
        + '</div></dialog>'
    )


def performance_debug_config_values():
    text = read_file(CONFIG)
    values = {}
    for key, _label, default in PERFORMANCE_DEBUG_CONFIG_FIELDS:
        if isinstance(default, int):
            values[key] = parse_int_config_value(text, key, default)
        else:
            values[key] = parse_shell_var(text, key, default)
    return values



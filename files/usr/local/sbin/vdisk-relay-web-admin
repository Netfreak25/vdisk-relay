        + render_kv_table([
            ("Bot-Variable", notify["bot_var"] or "-"),
            ("Chat-Variable", notify["chat_var"] or "-"),
            ("Chat type", notify["chat_type"] or "-"),
            ("Latest notify run", state.get("generated_at", "-")),
            ("Check interval", interval_label),
            ("Latest Telegram message", last_send),
            ("Last error", last_error or "-"),
        ])
        + '<p class="muted">The state cache keeps writing the dashboard state lightweight, but checks Telegram status changes only at the configured interval. A clear message is sent only when a failure notification was previously active for the same factor.</p>'
        + render_maintenance_notify_dialog(notify, bot_vars, chat_vars)
        + '</section>'
    )


def render_image_watchdog_status():
    def quick(cmd, timeout=4):
        try:
            r = subprocess.run(
                ["/usr/bin/timeout", str(timeout) + "s", "/bin/bash", "-lc", cmd],
                stdout=subprocess.PIPE,
                stderr=subprocess.STDOUT,
                text=True,
                timeout=timeout + 2,
                check=False,
            )
            return r.returncode, r.stdout.strip()
        except Exception as exc:
            return 1, "ERROR: " + str(exc)

    def module_loaded(name):
        try:
            with open("/proc/modules", "r", encoding="utf-8", errors="replace") as f:
                for line in f:
                    if line.split()[0] == name:
                        return True
        except Exception:
            pass
        return False

    def badge_status(status):
        if status == "OK":
            return '<span class="badge ok">OK</span>'
        if status == "CRITICAL":
            return '<span class="badge bad">CRITICAL</span>'
        return '<span class="badge" style="background:#78350f;color:#fde68a">WATCH</span>'

    notify = maintenance_notify_info()

    def add_factor(rows, factor_id, name, status, meaning, detail):
        rows.append(
            "<tr>"
            '<th data-label="Factor">' + esc(name) + "</th>"
            '<td data-label="State">' + badge_status(status) + "</td>"
            '<td data-label="Meaning">' + esc(meaning) + "</td>"
            '<td data-label="Detail">' + esc(detail) + "</td>"
            '<td class="actions" data-label="Telegram">' + render_maintenance_notify_factor_actions(factor_id, notify) + "</td>"
            "</tr>"
        )

    def last_log(pattern):
        rc, out = quick("tail -n 500 /var/log/vdisk-relay.log 2>/dev/null | grep -E '" + pattern + "' | tail -n 1 || true", 4)
        return out

    rows = []
    problems = []
    notes = []

    image = "/usbdisk.img"
    state_file = "/var/lib/vdisk-relay/image-mtime.state"
    pending_file = "/run/vdisk-relay/pending"
    mountpoint = "/run/vdisk-relay/mnt"

    gadget_loaded = module_loaded("g_mass_storage")
    dwc2_loaded = module_loaded("dwc2")
    libcomposite_loaded = module_loaded("libcomposite")

    bound_file = read_file("/sys/module/g_mass_storage/parameters/file", "").strip()

    try:
        current_mtime = str(int(os.stat(image).st_mtime))
        image_exists = True
    except Exception:
        current_mtime = ""
        image_exists = False

    stored_mtime = read_file(state_file, "").strip()
    pending = os.path.exists(pending_file)
    pending_text = read_file(pending_file, "").strip() if pending else ""
    config_text = read_file(CONFIG)
    live_fast_enabled = parse_int_config_value(config_text, "LIVE_FAST_LANE_ENABLED", 1) == 1
    live_fast_delay = parse_shell_var(config_text, "LIVE_FAST_LANE_DELAY_SECONDS", "3")
    live_fast_quiet = parse_shell_var(config_text, "LIVE_FAST_QUIET_SECONDS", "3")
    ultra_enabled = parse_int_config_value(config_text, "ULTRA_FAST_LANE_ENABLED", 0) == 1
    ultra_delay = parse_shell_var(config_text, "ULTRA_FAST_LANE_DELAY_SECONDS", "0")
    ultra_quiet = parse_shell_var(config_text, "ULTRA_FAST_LANE_QUIET_SECONDS", "0")
    ultra_sync_after = parse_shell_var(config_text, "ULTRA_FAST_LANE_SYNC_AFTER_SEND", "1")
    ultra_duplicate_mode = parse_shell_var(config_text, "ULTRA_FAST_DUPLICATE_MODE", "filename")
    ultra_queue_enabled = parse_shell_var(config_text, "ULTRA_FAST_REMAINDER_QUEUE_ENABLED", "1")
    ultra_queue_delay = parse_shell_var(config_text, "ULTRA_FAST_REMAINDER_QUEUE_DELAY_SECONDS", "2")

    retry_rc, retry_state = quick("systemctl is-active vdisk-relay-retry-live.timer 2>/dev/null || true", 3)
    fast_unit_rc, fast_unit_state = quick("systemctl is-failed vdisk-relay-fast-sync.service 2>/dev/null || true", 3)
    ultra_unit_rc, ultra_unit_state = quick("systemctl is-failed vdisk-relay-ultra-fast-sync.service 2>/dev/null || true", 3)
    queue_timer_rc, queue_timer_state = quick("systemctl is-active vdisk-relay-telegram-queue.timer 2>/dev/null || true", 3)
    queue_service_rc, queue_service_state = quick("systemctl is-failed vdisk-relay-telegram-queue.service 2>/dev/null || true", 3)
    watchdog_rc, watchdog_state = quick("systemctl is-active vdisk-relay-watchdog-live.timer 2>/dev/null || true", 3)
    path_rc, path_state = quick("systemctl is-active vdisk-relay-watch-live.path 2>/dev/null || true", 3)
    health_rc, health_out = quick("/usr/local/sbin/vdisk-relay health || true", 6)

    loop_rc, loop_out = quick("losetup -j /usbdisk.img 2>/dev/null || true", 3)
    local_mount = os.path.ismount(mountpoint)

    if gadget_loaded:
        add_factor(rows, "usb_gadget_module", "USB-Gadget Module", "OK", "g_mass_storage is loaded", "Host should still see a USB mass storage device.")
    else:
        add_factor(rows, "usb_gadget_module", "USB-Gadget Module", "CRITICAL", "g_mass_storage missing", "watchdog-live attempts to restore the gadget outside the delivery path.")
        problems.append("g_mass_storage is not loaded.")

    if dwc2_loaded and libcomposite_loaded:
        add_factor(rows, "usb_gadget_basis", "USB-Gadget Base", "OK", "dwc2 and libcomposite are loaded", "Kernel base for the gadget is available.")
    else:
        add_factor(rows, "usb_gadget_basis", "USB-Gadget Base", "WATCH", "dwc2/libcomposite not fully loaded", "Watchdog attempts to load missing modules.")
        notes.append("Check dwc2/libcomposite.")

    if bound_file == image:
        add_factor(rows, "backing_image", "Backing-Image", "OK", "Gadget uses /usbdisk.img", "Bound image matches.")
    elif bound_file:
        add_factor(rows, "backing_image", "Backing-Image", "CRITICAL", "Gadget uses a different image", bound_file)
        problems.append("Backing image does not match /usbdisk.img.")
    else:
        add_factor(rows, "backing_image", "Backing-Image", "WATCH", "Backing file not readable", "Parameter /sys/module/g_mass_storage/parameters/file is not available.")
        notes.append("Backing parameter could not be read.")

    if not image_exists:
        add_factor(rows, "image_file", "Image File", "CRITICAL", "/usbdisk.img missing or not readable", "No functional gadget without image.")
        problems.append("/usbdisk.img missing.")
    else:
        add_factor(rows, "image_file", "Image File", "OK", "/usbdisk.img exists", "mtime can be checked.")

    if not stored_mtime:
        add_factor(rows, "mtime_fallback", "mtime-Fallback", "WATCH", "Watchdog state not initialized yet", "This item should turn green after the next image-watchdog run.")
        notes.append("image-watchdog state is still missing.")
    elif current_mtime and stored_mtime == current_mtime:
        add_factor(rows, "mtime_fallback", "mtime-Fallback", "OK", "Image mtime is synchronized with watchdog state", "No unnoticed image change is pending.")
    elif current_mtime:
        add_factor(rows, "mtime_fallback", "mtime-Fallback", "WATCH", "Image was changed; watchdog state is not synchronized yet", "The next watchdog-live run will set or process pending state.")
        notes.append("Image-mtime unterscheidet sich vom Watchdog-State.")
    else:
        add_factor(rows, "mtime_fallback", "mtime-Fallback", "CRITICAL", "Image mtime not readable", "mtime fallback cannot work.")
        problems.append("Image mtime not readable.")

    if pending:
        add_factor(rows, "pending_state", "Pending-State", "WATCH", "Sync pending", pending_text or "Pending file present.")
        notes.append("Pending-State ist available.")
    else:
        add_factor(rows, "pending_state", "Pending-State", "OK", "No open sync", "No unprocessed pending state present.")

    if retry_state == "active":
        add_factor(rows, "retry_timer", "Retry-Timer", "OK", "retry-live.timer is active", "Fast retry runs only live sync.")
    else:
        add_factor(rows, "retry_timer", "Retry-Timer", "CRITICAL", "retry-live.timer is inactive", retry_state)
        problems.append("retry-live.timer is inactive.")

    if ultra_enabled:
        detail = "lane=ultra delay=" + ultra_delay + "s quiet=" + ultra_quiet + "s sync_after=" + ultra_sync_after + " duplicate=" + ultra_duplicate_mode + " fifo_queue=" + ultra_queue_enabled + " fifo_delay=" + ultra_queue_delay + "s"
        if ultra_unit_state == "failed":
            add_factor(rows, "fast_path", "Fast Path", "CRITICAL", "Ultra Fast Lane is active, but the ultra service failed", detail)
            problems.append("vdisk-relay-ultra-fast-sync.service ist failed.")
        else:
            add_factor(rows, "fast_path", "Fast Path", "OK", "Ultra Fast Lane is active", detail)
    elif live_fast_enabled:
        detail = "lane=fast delay=" + live_fast_delay + "s quiet=" + live_fast_quiet + "s"
        if fast_unit_state == "failed":
            add_factor(rows, "fast_path", "Fast Path", "CRITICAL", "Fast Lane is active, but the fast service failed", detail)
            problems.append("vdisk-relay-fast-sync.service ist failed.")
        else:
            add_factor(rows, "fast_path", "Fast Path", "OK", "Fast Lane is active", detail)
    else:
        add_factor(rows, "fast_path", "Fast Path", "WATCH", "Fast Lane is disabled", "Retry timer remains fallback.")
        notes.append("Fast Lane is disabled.")

    if queue_timer_state == "active" and queue_service_state != "failed":
        add_factor(rows, "telegram_queue", "Telegram-Queue", "OK", "telegram-queue.timer is active", "Telegram uploads run decoupled from the fast sync path.")
    else:
        detail = "timer=" + (queue_timer_state or "-") + " service_failed=" + (queue_service_state or "-")
        add_factor(rows, "telegram_queue", "Telegram-Queue", "CRITICAL", "Telegram queue is not ready", detail)
        problems.append("telegram-queue.timer is not active or the worker has failed.")

    if watchdog_state == "active":
        add_factor(rows, "watchdog_timer", "Watchdog-Timer", "OK", "watchdog-live.timer is active", "Gadget and image watchdog run periodically outside the dispatch path.")
    else:
        add_factor(rows, "watchdog_timer", "Watchdog-Timer", "CRITICAL", "watchdog-live.timer is inactive", watchdog_state)
        problems.append("watchdog-live.timer is inactive.")

    if path_state == "active":
        add_factor(rows, "inotify_path", "inotify-Path", "OK", "watch-live.path is active", "Normal changes are detected through inotify.")
    else:
        add_factor(rows, "inotify_path", "inotify-Path", "WATCH", "inotify path is inactive", "mtime fallback remains active as safeguard.")
        notes.append("watch-live.path is not active.")

    if health_out.startswith("OK "):
        add_factor(rows, "video_freshness", "Data-Freshness", "OK", "Newest active file is inside the time window", health_out)
    elif "STALE" in health_out or "CRITICAL" in health_out:
        add_factor(rows, "video_freshness", "Data-Freshness", "CRITICAL", "Newest active file is too old or missing", health_out)
        problems.append("Data freshness is critical.")
    else:
        add_factor(rows, "video_freshness", "Data-Freshness", "WATCH", "Health output is ambiguous", health_out)

    if local_mount:
        add_factor(rows, "local_mount", "Local Mount", "WATCH", "Image is locally mounted", mountpoint)
        notes.append("Local mount is active.")
    else:
        add_factor(rows, "local_mount", "Local Mount", "OK", "Image is not locally mounted", "Normal idle state.")

    if loop_out:
        add_factor(rows, "loopdevice", "Loopdevice", "WATCH", "Loop device active on /usbdisk.img", loop_out)
        notes.append("Loop device is active.")
    else:
        add_factor(rows, "loopdevice", "Loopdevice", "OK", "No local loop active", "Normal idle state.")

    if problems:
        overall = "CRITICAL"
        summary = "At least one factor prevents or endangers detection/processing."
    elif notes:
        overall = "WATCH"
        summary = "Base function is available, but at least one factor is suspicious or waiting for processing."
    else:
        overall = "OK"
        summary = "Gadget, inotify, mtime fallback and sync path look consistent."

    last_image = last_log("image-watchdog:")
    last_gadget = last_log("gadget-watchdog:")
    last_sync = last_log("live-sync:|sync done|sync start")

    event_rows = [
        ("Latest gadget watchdog", last_gadget),
        ("Latest image watchdog", last_image),
        ("Latest sync", last_sync),
    ]

    event_html = []
    for key, value in event_rows:
        event_html.append('<tr><th data-label="Event">' + esc(key) + '</th><td data-label="Log">' + esc(value or "no value") + "</td></tr>")

    notify_hint = "Maintenance Telegram active" if notify["enabled"] else "Maintenance Telegram inactive"
    return (
        '<section class="panel">'
        '<h2>Stale/USB path detection</h2>'
        '<p>' + badge_status(overall) + ' ' + esc(summary) + '</p>'
        '<p class="muted">'
        'This assessment combines gadget state, bound image, inotify, mtime fallback, pending state, retry timer, watchdog timer and data freshness. '
        'Nothing is unloaded or reloaded while g_mass_storage is loaded. '
        '<a href="/telegram/maintenance">' + esc(notify_hint) + '</a>.'
        '</p>'
        '<table class="responsive-table">'
        '<thead><tr><th>Factor</th><th>State</th><th>Meaning</th><th>Detail</th><th>Telegram</th></tr></thead>'
        '<tbody>' + ''.join(rows) + '</tbody>'
        '</table>'
        '<h3>Latest events</h3>'
        '<table class="responsive-table">' + ''.join(event_html) + '</table>'
        '</section>'
    )


def render_maintenance_page(message=""):
    last = read_file(MAINT_RESULT, "No maintenance action has been executed yet.")

    body = (
        settings_context("System")
        + settings_tabs("system")
        + maintenance_tabs("maintenance")
        + msg_html(message)
        + render_image_watchdog_status()
        + '<section class="panel">'
        + '<h2>Latest maintenance action</h2>'
        + '<pre>' + esc(last) + '</pre>'
        + '</section>'
    )

    return html_page("Stale Detection", body, active="settings", subtitle="Stale/USB path detection and last maintenance action.")


def render_maintenance_actions_page(message=""):
    format_marker = os.path.exists("/etc/vdisk-relay.format-on-boot")
    backups = list_config_backups()
    image_check = maintenance_result_info(
        MAINT_IMAGE_CHECK_RESULT,
        "No image check has been run through the WebUI yet.",
    )
    image_sync = maintenance_result_info(
        MAINT_IMAGE_SYNC_RESULT,
        "No manual image import has been run through the WebUI yet.",
    )

    backup_rows = []
    restore_options = []

    for mtime, name, size in backups:
        size_h = human_bytes(size) if "human_bytes" in globals() else str(size)
        backup_rows.append(
            "<tr>"
            '<td data-label="File">' + esc(name) + "</td>"
            '<td data-label="Time">' + esc(time.strftime("%Y-%m-%d %H:%M:%S", time.localtime(mtime))) + "</td>"
            '<td data-label="Size">' + esc(size_h) + "</td>"
            '<td class="actions" data-label="Action"><a class="button" href="/config-backup-download?f=' + esc(name) + '">Download</a></td>'
            "</tr>"
        )
        restore_options.append('<option value="' + esc(name) + '">' + esc(name) + "</option>")

    if not backup_rows:
        backup_rows.append('<tr><td colspan="4">No backups.</td></tr>')

    restore_select = "".join(restore_options) or '<option value="">No backups available</option>'
    restore_disabled = "" if restore_options else " disabled"
    archive_result = maintenance_result_info(
        MAINT_ARCHIVE_RESULT,
        "No manual archive run has been executed via the WebUI yet.",
    )

    body = (
        settings_context(t("settings.tab_actions"))
        + settings_tabs("actions")
        + msg_html(message)
        + '<section class="panel action-group">'
        + '<div class="panel-head-inline"><h2>' + esc(t("phrase.manual_actions")) + '</h2><span class="badge ok">' + esc(t("phrase.no_destructive_image_change")) + '</span></div>'
        + '<div class="action-group-grid">'
        + '<div class="action-card"><h3>' + esc(t("phrase.check_usb_image")) + '</h3>'
        + '<p class="muted">Stops g_mass_storage briefly, checks the partition table and filesystem, and starts the gadget again if it was active before.</p>'
        + '<form method="post" action="/maintenance/image-check" class="form-grid" data-confirm-message="Check image exclusively? The USB gadget is briefly unavailable to the host during this.">'
        + '<div class="form-field field-inline"><label><input type="checkbox" name="fix" value="1"> Repair errors automatically</label><div class="field-help">Without the checkbox, fsck runs read-only. With the checkbox, fsck may correct automatically.</div></div>'
        + '<button type="submit" data-icon="search">' + esc(t("phrase.start_check_usb_image")) + '</button></form></div>'
        + '<div class="action-card"><h3>' + esc(t("phrase.import_image_files")) + '</h3>'
        + '<p class="muted">Mounts the USB image read-only and writes new files to /files by rsync. No archive rsync and no Telegram dispatch.</p>'
        + '<form method="post" action="/maintenance/image-sync" data-confirm-message="Synchronize new files from the image to /files?"><button type="submit" data-icon="refresh">' + esc(t("phrase.start_import_image_files")) + '</button></form></div>'
        + '<div class="action-card"><h3>' + esc(t("phrase.run_archive_job")) + '</h3>'
        + '<p class="muted">Starts the rsync-daemon archive run from DATA_ROOT to the configured archive destination. The local image is not used for this.</p>'
        + '<form method="post" action="/maintenance/archive-run" data-confirm-message="Start archive job now?"><button type="submit" data-icon="refresh">' + esc(t("phrase.start_archive_job")) + '</button></form></div>'
        + '</div>'
        + '<div class="action-result-grid">'
        + '<section class="subpanel">' + render_maintenance_result_panel("Check status and log", image_check) + '</section>'
        + '<section class="subpanel">' + render_maintenance_result_panel("Image sync status and log", image_sync) + '</section>'
        + '<section class="subpanel">' + render_maintenance_result_panel("Archive status and log", archive_result) + '</section>'
        + '</div></section>'
        + '<section class="panel action-group">'
        + '<h2>Backup / Restore</h2>'
        + '<div class="action-group-grid">'
        + '<div class="action-card"><h3>Create backup</h3><p class="muted">Stores the WebUI and system configuration in a local tar.gz archive.</p>'
        + '<form method="post" action="/maintenance/config-backup"><button type="submit" data-icon="backup">Create config backup</button></form></div>'
        + '<div class="action-card action-card-danger"><h3>Restore</h3><p class="muted">Restores the configuration from a backup. A pre-restore backup is created automatically first.</p>'
        + '<form method="post" action="/maintenance/config-restore" class="form-grid" data-danger-action="1" data-confirm-message="Really restore config from backup?">'
        + '<div class="form-field"><label>Select backup</label><select name="backup"' + restore_disabled + '>' + restore_select + '</select><div class="field-help">Selection from an existing configuration backup.</div></div>'
        + '<div class="form-field field-inline"><label><input type="checkbox" name="confirm" value="RESTORE" required' + restore_disabled + '> I want to restore this configuration.</label><div class="field-help">Restore only with confirmation checkbox.</div></div>'
        + '<button class="danger" type="submit" data-icon="restore"' + restore_disabled + '>Restore backup</button></form></div>'
        + '</div>'
        + '<table class="responsive-table"><thead><tr><th>File</th><th>Time</th><th>Size</th><th>Action</th></tr></thead><tbody>'
        + ''.join(backup_rows)
        + '</tbody></table>'
        + '</section>'
        + '<section class="panel action-group action-group-danger">'
        + '<div class="panel-head-inline"><h2>Dangerous actions</h2><span class="badge bad">Confirmation required</span></div>'
        + '<div class="action-group-grid">'
        + '<div class="action-card action-card-danger"><h3>Format USB image</h3>'
        + '<p class="muted">Does not format immediately. It only marks formatting for the next boot. The gadget is not unloaded here.</p>'
        + '<p>State: ' + ('<span class="badge bad">FORMAT SCHEDULED</span>' if format_marker else '<span class="badge ok">not scheduled</span>') + '</p>'
        + '<form method="post" action="/maintenance/format-on-boot" class="form-grid" data-danger-action="1" data-confirm-message="Mark /usbdisk.img for formatting on the next boot?">'
        + '<div class="form-field field-inline"><label><input type="checkbox" name="confirm" value="FORMAT" required> I understand that the image will be reformatted on the next boot.</label><div class="field-help">The marker takes effect only after saving.</div></div>'
        + '<button class="danger" type="submit" data-icon="format">Mark format for next boot</button></form>'
        + '<form method="post" action="/maintenance/format-cancel"><button type="submit" data-icon="close">Remove format marker</button></form></div>'
        + '<div class="action-card action-card-danger"><h3>Reboot</h3><p class="muted">Restarts the Raspberry Pi through systemctl reboot. The reboot reason is set for boot notify.</p>'
        + '<form method="post" action="/maintenance/reboot" class="form-grid" data-danger-action="1" data-confirm-message="Really restart the Raspberry Pi now?">'
        + '<div class="form-field field-inline"><label><input type="checkbox" name="confirm" value="REBOOT" required> I want to restart the device now.</label><div class="field-help">Restart only with confirmation checkbox.</div></div>'
        + '<button class="danger" type="submit" data-icon="restart">Trigger reboot</button></form></div>'
        + '<div class="action-card action-card-danger"><h3>Shutdown</h3><p class="muted">Shuts down the Raspberry Pi. On the next start, the reason is reported by boot notify.</p>'
        + '<form method="post" action="/maintenance/shutdown" class="form-grid" data-danger-action="1" data-confirm-message="Really shut down the Raspberry Pi now?">'
        + '<div class="form-field field-inline"><label><input type="checkbox" name="confirm" value="SHUTDOWN" required> I want to shut down the device now.</label><div class="field-help">Shutdown only with confirmation checkbox.</div></div>'
        + '<button class="danger" type="submit" data-icon="power">Trigger shutdown</button></form></div>'
        + '</div></section>'
    )

    return html_page("Actions", body, active="settings", subtitle="Image check, format marker, config backup / restore, reboot and shutdown.")


def handle_maintenance_post(handler, path, form):
    if path == "/maintenance/format-on-boot":
        if form.get("confirm", [""])[0] != "FORMAT":
            raise ValueError("Confirmation missing")
        write_atomic("/etc/vdisk-relay.format-on-boot", "requested=" + time.strftime("%Y-%m-%dT%H:%M:%S%z") + "\n", 0o644)
        handler.redirect("/maintenance/actions")
        return True

    if path == "/maintenance/format-cancel":
        try:
            os.unlink("/etc/vdisk-relay.format-on-boot")
        except FileNotFoundError:
            pass
        handler.redirect("/maintenance/actions")
        return True

    if path == "/maintenance/image-check":
        fix = form.get("fix", ["0"])[0] == "1"
        cmd = "/usr/local/sbin/vdisk-relay image-check" + (" --fix" if fix else "")
        title = "Image Check" + (" mit Auto-Fix" if fix else " read-only")
        rc, out = run_maint_cmd(cmd, 1800)
        write_maintenance_result(title, rc, out)
        write_maintenance_result(title, rc, out, MAINT_IMAGE_CHECK_RESULT)
        handler.redirect("/maintenance/actions")
        return True

    if path == "/maintenance/image-sync":
        rc, out = run_maint_cmd("/usr/local/sbin/vdisk-relay sync --mount --apply-rsync", 1200)
        write_maintenance_result("Image to local sync", rc, out)
        write_maintenance_result("Image to local sync", rc, out, MAINT_IMAGE_SYNC_RESULT)
        handler.redirect("/maintenance/actions")
        return True

    if path == "/maintenance/archive-run":
        archive_seconds = parse_int_config_value(read_file(CONFIG), "ARCHIVE_RSYNC_MAX_SECONDS", 900)
        rc, out = run_maint_cmd(
            "/usr/local/sbin/vdisk-relay archive --apply",
            max(60, min(archive_seconds + 60, 86520)),
        )
        write_maintenance_result("Archive run", rc, out)
        write_maintenance_result("Archive run", rc, out, MAINT_ARCHIVE_RESULT)
        handler.redirect("/maintenance/actions")
        return True

    if path == "/maintenance/config-backup":
        rc, out = run_maint_cmd("/usr/local/sbin/vdisk-relay config-backup", 120)
        write_maintenance_result("Config Backup", rc, out)
        handler.redirect("/maintenance/actions")
        return True

    if path == "/maintenance/config-restore":
        if form.get("confirm", [""])[0] != "RESTORE":
            raise ValueError("Confirmation missing")
        name = form.get("backup", [""])[0]
        backup = safe_config_backup_path(name)
        rc, out = run_maint_cmd("/usr/local/sbin/vdisk-relay config-restore " + shell_quote(backup) + " --apply", 180)
        write_maintenance_result("Config Restore", rc, out)
        handler.redirect("/maintenance/actions")
        return True

    if path == "/maintenance/reboot":
        if form.get("confirm", [""])[0] != "REBOOT":
            raise ValueError("Confirmation missing")
        reason = "WebUI maintenance: manual reboot at " + time.strftime("%Y-%m-%d %H:%M:%S %z")
        write_reboot_reason(reason)
        rc, out = run_system_reboot()
        write_maintenance_result("System Reboot", rc, (out or "systemctl reboot was called.") + "\nreason=" + reason)
        handler.redirect("/maintenance/actions?msg=" + quote("Reboot was triggered."))
        return True

    if path == "/maintenance/shutdown":
        if form.get("confirm", [""])[0] != "SHUTDOWN":
            raise ValueError("Confirmation missing")
        reason = "WebUI maintenance: manual shutdown at " + time.strftime("%Y-%m-%d %H:%M:%S %z")
        write_reboot_reason(reason)
        rc, out = run_system_shutdown()
        write_maintenance_result("System Shutdown", rc, (out or "systemctl poweroff was called.") + "\nreason=" + reason)
        handler.redirect("/maintenance/actions?msg=" + quote("Shutdown was triggered."))
        return True

    return False


def safe_return_to(value):
    value = (value or "/").strip()
    if not value.startswith("/") or value.startswith("//"):
        return "/"
    if "\r" in value or "\n" in value:
        return "/"
    return value


def handle_language_post(handler, path, form):
    if path != "/language":
        return False
    lang = normalize_language(form.get("lang", [DEFAULT_LANGUAGE])[0])
    set_request_context(lang, current_request_path())
    prepare_language_runtime(lang)
    target = safe_return_to(form.get("return_to", ["/"])[0])
    handler.redirect(target, headers=[("Set-Cookie", language_cookie_header(lang))])
    return True


class Handler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        return

    def prepare_request_context(self, path=None):
        set_request_context(language_from_cookie(self.headers.get("Cookie", "")), path or self.path or "/")

    def _write_response_body(self, body):
        try:
            self.wfile.write(body)
            return True
        except (BrokenPipeError, ConnectionResetError):
            return False

    def send_html(self, body, code=200):
        body = localize_html_document(body)
        data = body.encode("utf-8")

        self.send_response(code)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Language", current_language())
        self.send_header("Cache-Control", "no-store")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self._write_response_body(data)

    def send_bytes(self, data, content_type, code=200, cache_control="no-store"):
        self.send_response(code)
        self.send_header("Content-Type", content_type)
        if content_type.startswith("text/") or "json" in content_type or "manifest" in content_type or "yesvascript" in content_type:
            self.send_header("Content-Language", current_language())
        if cache_control:
            self.send_header("Cache-Control", cache_control)
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self._write_response_body(data)

    def send_no_content(self, cache_control="no-store"):
        self.send_response(204)
        self.send_header("Content-Language", current_language())
        if cache_control:
            self.send_header("Cache-Control", cache_control)
        self.send_header("Content-Length", "0")
        self.end_headers()

    def wants_json(self):
        return (
            self.headers.get("X-Requested-With", "").lower() == "fetch"
            or "application/json" in self.headers.get("Accept", "").lower()
        )

    def send_json(self, payload, code=200):
        data = json.dumps(payload, ensure_ascii=False, separators=(",", ":")).encode("utf-8")
        self.send_response(code)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Language", current_language())
        self.send_header("Cache-Control", "no-store")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self._write_response_body(data)

    def redirect(self, target="/", code=303, headers=None):
        if self.wants_json():
            parsed = urlparse(target)
            query = parse_qs(parsed.query)
            message = localize_plain_text(query.get("msg", [t("js.action_done")])[0])
            self.send_json(
                {
                    "ok": True,
                    "message": message,
                    "redirect": target,
                }
            )
            return
        self.send_response(code)
        self.send_header("Location", target)
        self.send_header("Content-Language", current_language())
        for name, value in headers or []:
            self.send_header(name, value)
        self.end_headers()

    def send_captive_portal_response(self, path):
        emergency_info = network_emergency_info()
        if emergency_info.get("active"):
            if path == "/hotspot-detect.html":
                self.send_html(captive_portal_html(emergency_info), code=200)
                return
            self.redirect(captive_portal_target(), code=302)
            return

        response = captive_normal_response(path)
        if response["code"] == 204:
            self.send_no_content()
            return
        self.send_bytes(
            response["body"].encode("utf-8"),
            response["content_type"],
            code=response["code"],
            cache_control="no-store",
        )

    def read_post(self):
        length = int(self.headers.get("Content-Length", "0"))
        raw = self.rfile.read(length).decode("utf-8", errors="replace")
        return parse_qs(raw)

    def do_GET(self):
        parsed = urlparse(self.path)
        query = parse_qs(parsed.query)
        self.prepare_request_context(self.path)

        if parsed.path == "/manifest.webmanifest":
            self.send_bytes(app_manifest_json().encode("utf-8"), "application/manifest+json; charset=utf-8", cache_control="no-cache")
            return

        if parsed.path == "/sw.js":
            self.send_bytes(service_worker_js().encode("utf-8"), "application/yesvascript; charset=utf-8", cache_control="no-cache")
            return

        if parsed.path == "/favicon.svg":
            self.send_bytes(favicon_svg().encode("utf-8"), "image/svg+xml; charset=utf-8", cache_control="public, max-age=86400")
            return

        if parsed.path == "/app-icon-192.png":
            self.send_bytes(app_icon_png(192), "image/png", cache_control="public, max-age=86400")
            return

        if parsed.path == "/app-icon-512.png":
            self.send_bytes(app_icon_png(512), "image/png", cache_control="public, max-age=86400")
            return

        if parsed.path == "/app-version.json":
            self.send_json(app_version_info())
            return

        if captive_portal_path(parsed.path):
            self.send_captive_portal_response(parsed.path)
            return

        if parsed.path == "/setup":
            self.send_html(render_setup_page(query=query))
            return

        setup = pause_runtime_for_setup()
        if not setup["ready"]:
            self.redirect("/setup")
            return

        emergency_info = network_emergency_info()
        if emergency_info.get("active") and not emergency_get_allowed(parsed.path):
            self.redirect(emergency_redirect_target())
            return

        if parsed.path == "/emergency/status.json":
            self.send_json(emergency_info)
            return

        if parsed.path == "/screensaver-previews.json":
            self.send_json(screensaver_preview_payload())
            return

        if parsed.path == "/services":
            self.send_html(render_services_page(query=query))
            return

        if parsed.path == "/services-status.json":
            data = load_status_json()
            pending = service_action_pending(data)
            generated, sections_html = render_services_sections(data)
            self.send_bytes(
                json.dumps(
                    {
                        "generated_at": generated or "",
                        "pending": bool(pending),
                        "pending_unit": pending.get("unit", "") if pending else "",
                        "pending_action": pending.get("action", "") if pending else "",
                        "sections_html": sections_html,
                    },
                    ensure_ascii=False,
                ).encode("utf-8"),
                "application/json; charset=utf-8",
            )
            return

        if parsed.path == "/update":
            self.send_html(render_update_page(query=query))
            return

        if parsed.path == "/update-log":
            section = query.get("section", [""])[0]
            try:
                content = read_log_section(section)
            except ValueError:
                self.send_bytes(
                    json.dumps({"error": "invalid section", "section": section}, ensure_ascii=False).encode("utf-8"),
                    "application/json; charset=utf-8",
                    code=400,
                )
                return

            data = {
                "section": section,
                "content": content,
            }
            self.send_bytes(json.dumps(data, ensure_ascii=False).encode("utf-8"), "application/json; charset=utf-8")
            return

        if parsed.path == "/update-status.json":
            data = {
                "check": load_json_file(UPDATE_CHECK_STATUS, {}),
                "job": load_json_file(UPDATE_STATUS, {}),
                "update_service": systemctl_active("vdisk-relay-update.service"),
                "check_service": systemctl_active("vdisk-relay-update-check.service"),
            }
            self.send_bytes(json.dumps(data, ensure_ascii=False, separators=(",", ":")).encode("utf-8"), "application/json; charset=utf-8")
            return

        if parsed.path == "/service-journal":
            try:
                self.send_html(render_service_journal_page(query=query))
            except Exception as exc:
                self.send_html(html_page("Journal error", "<section class=\"panel\"><h2>ERROR</h2><pre>" + esc(exc) + "</pre></section>", active="settings"), code=400)
            return

        if parsed.path == "/maintenance":
            self.send_html(render_maintenance_page(message=query.get("msg", [""])[0]))
            return

        if parsed.path == "/maintenance/actions":
            self.send_html(render_maintenance_actions_page(message=query.get("msg", [""])[0]))
            return

        if parsed.path == "/config-backup-download":
            try:
                name = query.get("f", [""])[0]
                send_config_backup(self, name)
            except Exception as exc:
                self.send_html(html_page("Backup error", "<section class=\"panel\"><h2>Backup error</h2><pre>" + esc(exc) + "</pre></section>", active="settings"), code=404)
            return

        if parsed.path.startswith("/preview/"):
            name = os.path.basename(parsed.path[len("/preview/"):])
            path = os.path.join(PREVIEW_DIR, name)
            if os.path.isfile(path) and name.endswith(".jpg"):
                stat = os.stat(path)
                etag = 'W/"{}-{}-jpg"'.format(int(stat.st_mtime), stat.st_size)
                last_modified = formatdate(stat.st_mtime, usegmt=True)
                ims_header = self.headers.get("If-Modified-Since")
                inm_header = self.headers.get("If-None-Match")
                if inm_header and inm_header == etag:
                    self.send_response(304)
                    self.send_header("ETag", etag)
                    self.send_header("Last-Modified", last_modified)
                    self.send_header("Cache-Control", "public, max-age=" + str(PREVIEW_CACHE_MAX_AGE_SECONDS))
                    self.end_headers()
                    return
                if ims_header:
                    try:
                        since = parsedate_to_datetime(ims_header)
                        since_ts = int(since.timestamp()) if since.tzinfo is not None else int(time.mktime(since.timetuple()))
                        if int(stat.st_mtime) <= int(since_ts):
                            self.send_response(304)
                            self.send_header("ETag", etag)
                            self.send_header("Last-Modified", last_modified)
                            self.send_header("Cache-Control", "public, max-age=" + str(PREVIEW_CACHE_MAX_AGE_SECONDS))
                            self.end_headers()
                            return
                    except Exception:
                        pass

                data = open(path, "rb").read()
                self.send_response(200)
                self.send_header("Content-Type", "image/jpeg")
                self.send_header("Content-Length", str(len(data)))
                self.send_header("Cache-Control", "public, max-age=" + str(PREVIEW_CACHE_MAX_AGE_SECONDS))
                self.send_header("ETag", etag)
                self.send_header("Last-Modified", last_modified)
                self.end_headers()
                self._write_response_body(data)
            else:
                self.send_error(404)
            return

        if parsed.path == "/diagnostics":
            self.send_html(render_diagnostics_page())
            return

        if parsed.path == "/details":
            self.send_html(render_details_page())
            return

        if parsed.path == "/debug":
            self.send_html(render_diagnostics_page(open_debug=True))
            return

        if parsed.path == "/status.json":
            data = read_file(STATUS_JSON, "{}").encode("utf-8")

            self.send_response(200)
            self.send_header("Content-Type", "application/json; charset=utf-8")
            self.send_header("Content-Length", str(len(data)))
            self.end_headers()
            self._write_response_body(data)
            return

        if parsed.path.startswith("/status/"):
            tile_id = unquote(parsed.path[len("/status/"):]).strip("/")
            payload = render_status_detail_page(tile_id)
            if payload is None:
                self.send_error(404)
                return
            self.send_html(payload)
            return

        if parsed.path == "/data":
            payload = render_videos_page_workstation(
                query=query,
                as_json=self.wants_json(),
            )
            if isinstance(payload, dict):
                self.send_json(payload)
                return
            self.send_html(payload)
            return

        if parsed.path == "/file":
            try:
                rel = query.get("f", [""])[0]
                download = query.get("download", ["0"])[0] == "1"
                send_file(self, rel, download=download)
            except Exception as exc:
                self.send_html(html_page("File error", "<section class=\"panel\"><h2>File error</h2><pre>" + esc(exc) + "</pre></section>", active="data"), code=404)
            return

        if parsed.path == "/settings":
            self.redirect("/settings/general")
            return

        if parsed.path == "/general" or parsed.path == "/settings/general":
            self.send_html(render_general_settings_page(query=query, section="general"))
            return

        if parsed.path == "/settings/display":
            self.send_html(render_general_settings_page(query=query, section="display"))
            return

        if parsed.path == "/settings/timeline":
            self.send_html(render_general_settings_page(query=query, section="timeline"))
            return

        if parsed.path == "/settings/performance":
            self.send_html(render_general_settings_page(query=query, section="performance"))
            return

        if parsed.path == "/settings/previews":
            self.send_html(render_general_settings_page(query=query, section="previews"))
            return

        if parsed.path == "/settings/telegram":
            self.send_html(render_general_settings_page(query=query, section="telegram"))
            return

        if parsed.path == "/settings/system":
            self.send_html(render_settings_system_page(query=query))
            return

        if parsed.path == "/settings/actions":
            self.send_html(render_maintenance_actions_page(message=query.get("msg", [""])[0]))
            return

        if parsed.path == "/timeline-log":
            self.send_html(render_timeline_log_page())
            return

        if parsed.path == "/wifi":
            self.send_html(render_wifi_settings_page(query=query))
            return

        if parsed.path == "/sources":
            self.send_html(render_sources_page(query=query))
            return

        if parsed.path == "/bots":
            self.redirect("/telegram/bots" + (("?" + parsed.query) if parsed.query else ""))
            return

        if parsed.path == "/chats":
            self.redirect("/telegram/chats" + (("?" + parsed.query) if parsed.query else ""))
            return

        if parsed.path == "/telegram":
            self.send_html(render_telegram_home_page(query=query))
            return

        if parsed.path == "/telegram/bots":
            self.send_html(render_bots_page(query=query))
            return

        if parsed.path == "/telegram/chats":
            self.send_html(render_chats_page(query=query))
            return

        if parsed.path == "/telegram/queue":
            self.send_html(render_telegram_queue_page(query=query))
            return

        if parsed.path == "/telegram/maintenance":
            self.send_html(render_telegram_maintenance_page(query=query))
            return

        if parsed.path == "/telegram/debug":
            self.send_html(render_telegram_debug_page())
            return

        if parsed.path == "/archive":
            self.send_html(render_archive_settings_page(query=query))
            return

        if parsed.path == "/boot-notify":
            self.send_html(render_boot_notify_settings_page(query=query))
            return

        if parsed.path == "/previews":
            self.send_html(render_previews_page(query=query))
            return

        if parsed.path == "/telegram-debug":
            self.redirect("/telegram/debug")
            return

        if parsed.path != "/":
            self.send_error(404)
            return

        self.send_html(render_main_page())

    def do_POST(self):
        path = urlparse(self.path).path
        self.prepare_request_context(self.path)

        try:
            form = self.read_post()

            if handle_language_post(self, path, form):
                return

            if path == "/setup/save":
                write_initial_setup(form)
                self.redirect("/sources?msg=" + quote("Setup saved"))
                return

            setup = pause_runtime_for_setup()
            if not setup["ready"]:
                self.redirect("/setup?msg=" + quote("Setup must be fully saved first"))
                return

            if handle_emergency_post(self, path, form):
                return

            emergency_info = network_emergency_info()
            if emergency_info.get("active") and not emergency_post_allowed(path):
                self.redirect(emergency_redirect_target())
                return

            if handle_log_clear_post(self, path, form):
                return

            if handle_general_post(self, path, form):
                return

            if handle_wifi_post(self, path, form):
                return

            if handle_archive_post(self, path, form):
                return

            if handle_boot_notify_post(self, path, form):
                return

            if handle_maintenance_notify_post(self, path, form):
                return

            if handle_update_post(self, path, form):
                return

            if handle_preview_post(self, path, form):
                return

            if handle_service_post(self, path, form):
                return

            if handle_video_delete_post(self, path, form):
                return

            if handle_maintenance_post(self, path, form):
                return

            sources = parse_sources()
            source_id = form.get("id", [""])[0].strip()

            if path == "/sources/test":
                source = None
                for c in sources:
                    if c["id"] == source_id:
                        source = c
                        break
                if not source:
                    raise ValueError("Source not found")
                if not source["bot_var"] or not source["chat_var"]:
                    raise ValueError("Source Telegram assignment missing")

                rc, out = run_maint_cmd(
                    "/usr/local/sbin/vdisk-relay test-text-send --source "
                    + shlex.quote(source["id"])
                    + " --send",
                    80,
                )
                if rc == 0:
                    self.redirect("/sources?msg=" + quote(f"Test text for {source_id} sent"))
                    return
                raise ValueError("Test failed: " + (out[:200] if out else "unknown"))

            if path in ("/sources/enable", "/sources/disable", "/sources/delete", "/sources/test"):
                if not ID_RE.match(source_id):
                    raise ValueError("Invalid source ID")

            if path == "/sources/enable":
                found = False
                for c in sources:
                    if c["id"] == source_id:
                        c["enabled"] = "1"
                        found = True
                if not found:
                    raise ValueError("Source not found")
                write_sources(sources)
                self.redirect("/sources")
                return

            if path == "/sources/disable":
                found = False
                for c in sources:
                    if c["id"] == source_id:
                        c["enabled"] = "0"
                        found = True
                if not found:
                    raise ValueError("Source not found")
                write_sources(sources)
                self.redirect("/sources")
                return

            if path == "/sources/delete":
                new_sources = [c for c in sources if c["id"] != source_id]
                if len(new_sources) == len(sources):
                    raise ValueError("Source not found")
                write_sources(new_sources)
                self.redirect("/sources")
                return

            if False and path == "/sources/test":
                source = None
                for c in sources:
                    if c["id"] == source_id:
                        source = c
                        break
                if not source:
                    raise ValueError("Source not found")
                if not source["bot_var"] or not source["chat_var"]:
                    raise ValueError("Source Telegram assignment missing")

                test_file = source.get("last_file", "").strip()
                if not test_file or not os.path.isfile(test_file):
                    raise ValueError("No valid latest file found for test")

                rc, out = run_maint_cmd(
                    "/usr/local/sbin/vdisk-relay test-file-send --source "
                    + shlex.quote(source["id"])
                    + " --file "
                    + shlex.quote(test_file)
                    + " --send",
                    80,
                )
                if rc == 0:
                    self.redirect("/sources?msg=" + quote(f"Test message for {source_id} sent"))
                    return
                raise ValueError("Test failed: " + (out[:200] if out else "unknown"))

            if path == "/sources/save":
                original_id = form.get("original_id", [""])[0].strip()
                new_source = make_source(form)
                ids = [c["id"] for c in sources]

                if original_id:
                    updated = False

                    for i, c in enumerate(sources):
                        if c["id"] == original_id:
                            if new_source["id"] != original_id and new_source["id"] in ids:
                                raise ValueError("New source ID already exists")
                            sources[i] = new_source
                            updated = True

                    if not updated:
                        raise ValueError("Source to edit not found")
                else:
                    if new_source["id"] in ids:
                        raise ValueError("Source ID already exists")
                    sources.append(new_source)

                write_sources(sources)
                self.redirect("/sources")
                return

            if path == "/bot/save":
                env = parse_env()
                original_var = form.get("original_var", [""])[0].strip()
                base = form.get("id", [""])[0].strip()
                token = form.get("token", [""])[0].strip()
                var = env_var_from_base(base, "_BOT_TOKEN")

                if original_var:
                    old_token = env.get(original_var, "")

                    if not token:
                        token = old_token

                    if not token:
                        raise ValueError("Token missing")

                    if var != original_var and var in env:
                        raise ValueError("Bot name already exists")

                    if original_var in env and var != original_var:
                        del env[original_var]

                    if var != original_var:
                        for c in sources:
                            if c["bot_var"] == original_var:
                                c["bot_var"] = var
                        write_sources(sources)
                else:
                    if var in env:
                        raise ValueError("Bot name already exists")
                    if not token:
                        raise ValueError("Token missing")

                env[var] = token
                write_env(env)
                self.redirect("/telegram/bots")
                return

            if path == "/bot/delete":
                env = parse_env()
                var = form.get("var", [""])[0].strip()

                if var in used_bot_vars():
                    raise ValueError("Bot is still used by at least one source")

                if var not in env:
                    raise ValueError("Bot not found")

                del env[var]
                write_env(env)
                self.redirect("/telegram/bots")
                return

            if path == "/chat/save":
                env = parse_env()
                original_var = form.get("original_var", [""])[0].strip()
                base = form.get("id", [""])[0].strip()
                chat_id = form.get("chat_id", [""])[0].strip()

                if not chat_id:
                    raise ValueError("Chat ID missing")

                validate_plain(chat_id, "chat_id")
                var = env_var_from_base(base, "_CHAT_ID")

                if original_var:
                    if var != original_var and var in env:
                        raise ValueError("Chat name already exists")

                    if original_var in env and var != original_var:
                        del env[original_var]
                    old_chat_type_var = chat_type_var_from_chat_var(original_var)
                    if old_chat_type_var in env:
                        del env[old_chat_type_var]

                    if var != original_var:
                        for c in sources:
                            if c["chat_var"] == original_var:
                                c["chat_var"] = var
                        write_sources(sources)
                else:
                    if var in env:
                        raise ValueError("Chat name already exists")

                env[var] = chat_id
                env[chat_type_var_from_chat_var(var)] = chat_type_from_id(chat_id)
                write_env(env)
                self.redirect("/telegram/chats")
                return

            if path == "/chat/delete":
                env = parse_env()
                var = form.get("var", [""])[0].strip()

                if var in used_chat_vars():
                    raise ValueError("Chat is still used by at least one source")

                if var not in env:
                    raise ValueError("Chat not found")

                chat_type_var = chat_type_var_from_chat_var(var)
                if chat_type_var in env:
                    del env[chat_type_var]

                del env[var]
                write_env(env)
                self.redirect("/telegram/chats")
                return

            self.send_error(404)

        except Exception as e:
            if path.startswith("/sources/"):
                target = "/sources"
            elif path.startswith("/bot/"):
                target = "/telegram/bots"
            elif path.startswith("/chat/"):
                target = "/telegram/chats"
            elif path.startswith("/general/") or path == "/general/save":
                if path == "/general/save":
                    saved_section = str(form.get("settings_section", ["general"])[0]).strip().lower()
                    if saved_section == "display":
                        target = "/settings/display"
                    elif saved_section == "timeline":
                        target = "/settings/timeline"
                    elif saved_section == "performance":
                        target = "/settings/performance"
                    elif saved_section == "previews":
                        target = "/settings/previews"
                    elif saved_section == "telegram":
                        target = "/settings/telegram"
                    else:
                        target = "/general"
                else:
                    target = "/general"
            elif path.startswith("/wifi/"):
                target = "/wifi"
            elif path.startswith("/archive/"):
                target = "/archive"
            elif path.startswith("/boot-notify/"):
                target = "/boot-notify"
            elif path.startswith("/maintenance-notify/"):
                target = "/telegram/maintenance"
            elif path.startswith("/previews/"):
                target = "/previews"
            elif path.startswith("/setup/"):
                target = "/setup"
            elif path.startswith("/service/"):
                target = "/services"
            elif path == "/data/delete":
                target = "/data"
            elif path.startswith("/update/"):
                target = "/update"
            elif path.startswith("/maintenance/"):
                target = "/maintenance/actions"
            else:
                target = "/"

            if self.wants_json():
                self.send_json(
                    {
                        "ok": False,
                        "message": localize_plain_text(str(e)),
                        "redirect": target,
                    },
                    code=400,
                )
                return

            body = f'''
<p><a href="{target}">back</a></p>
<section class="panel">
  <h2>ERROR</h2>
  <pre>{esc(e)}</pre>
</section>
'''
            active = {
                "/sources": "settings",
                "/telegram": "settings",
                "/telegram/bots": "settings",
                "/telegram/chats": "settings",
                "/telegram/queue": "settings",
                "/telegram/maintenance": "settings",
                "/telegram/debug": "settings",
                "/general": "settings",
                "/settings/display": "settings",
                "/settings/general": "settings",
                "/settings/timeline": "settings",
                "/settings/performance": "settings",
                "/settings/previews": "settings",
                "/settings/telegram": "settings",
                "/settings/system": "settings",
                "/settings/actions": "settings",
                "/timeline-log": "settings",
                "/wifi": "settings",
                "/archive": "settings",
                "/boot-notify": "settings",
                "/update": "settings",
                "/previews": "settings",
                "/setup": "settings",
                "/services": "settings",
                "/maintenance": "settings",
                "/maintenance/actions": "settings",
                "/diagnostics": "settings",
                "/details": "settings",
                "/debug": "settings",
                "/telegram-debug": "settings",
            }.get(target, "overview")
            self.send_html(html_page("Error", body, active=active), code=400)


class ThreadingHTTPServer(ThreadingMixIn, HTTPServer):
    allow_reuse_address = True
    daemon_threads = True


def main():
    start_video_delete_worker()
    server = ThreadingHTTPServer(("0.0.0.0", 80), Handler)
    server.serve_forever()


if __name__ == "__main__":
    main()

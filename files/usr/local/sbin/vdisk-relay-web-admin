def render_diagnostics_page(open_debug=False, message=""):
    txt, status_meta = status_text_with_meta()
    data = load_status_json()
    data = data if isinstance(data, dict) else {}
    cached_at = data.get("generated_at", "")
    cached_class = "ok" if cached_at else "warn"
    cached_label = cached_at or t("phrase.unknown")
    overall, cls = status_badge(txt, stale=status_meta.get("stale", False))
    debug_doc = read_file(DEBUG_HTML, "")
    debug_class = "ok" if debug_doc else "warn"
    debug_label = t("phrase.available") if debug_doc else t("phrase.missing")
    debug_open = " open" if open_debug else ""

    components = status_components(txt)
    status_rows = []
    for name in sorted(components):
        item = components.get(name, {})
        state = item.get("state", "-")
        badge_cls = "ok" if state == "OK" else "bad" if state == "FAIL" else "warn"
        status_rows.append(
            "<tr>"
            '<th data-label="Component">' + esc(name) + "</th>"
            '<td data-label="State"><span class="badge ' + badge_cls + '">' + esc(state) + "</span></td>"
            '<td data-label="Detail">' + esc(item.get("message", "-")) + "</td>"
            "</tr>"
        )
    if not status_rows:
        status_rows.append('<tr><td colspan="3">' + esc(t("phrase.no_status_components")) + '</td></tr>')

    if debug_doc:
        debug_block = (
            '<div class="debug-cache-frame legacy-debug">'
            + html_body_fragment(debug_doc)
            + "</div>"
        )
    else:
        debug_block = '<p>' + esc(DEBUG_HTML) + " " + esc(t("phrase.not_available_yet")) + ".</p>"

    body = f"""
{settings_context("System")}
{settings_tabs("system")}
{maintenance_tabs("diagnostics")}
{msg_html(message)}

<section class="hero-status">
  <div>
    <div class="status-title">{esc(t("phrase.overall_status"))}</div>
    <div class="status-value">{overall}</div>
  </div>
  <div class="badge {cls}">{esc(t("phrase.overall_status"))} {overall}</div>
</section>

<section class="panel">
  <h2>{esc(t("phrase.status_source"))}</h2>
  {render_kv_table([
      ("State JSON", STATUS_JSON),
      ("State cache", cached_label),
      ("Debug HTML", DEBUG_HTML),
      ("Debug Cache", debug_label),
  ])}
  <p>
    <span class="badge {cached_class}">State {esc(cached_label)}</span>
    <span class="badge {debug_class}">Debug {esc(debug_label)}</span>
  </p>
</section>

<section class="panel">
  <h2>{esc(t("phrase.status_components"))}</h2>
  <table class="responsive-table"><thead><tr><th>{esc(t("phrase.component"))}</th><th>{esc(t("phrase.state"))}</th><th>{esc(t("phrase.detail"))}</th></tr></thead><tbody>{''.join(status_rows)}</tbody></table>
</section>

<section class="panel">
  <h2>{esc(t("phrase.diagnostics"))}</h2>
  <details class="diagnostic-disclosure"{debug_open}>
    <summary>Debugcache</summary>
    <div class="diagnostic-body">{debug_block}</div>
  </details>
</section>
"""
    return html_page(t("phrase.diagnostics"), body, active="settings", subtitle=t("phrase.diagnostics_subtitle"))

def render_details_page():
    return render_diagnostics_page(open_debug=False)


def run_maint_cmd(cmd, timeout=180):
    try:
        p = subprocess.run(
            ["/usr/bin/timeout", str(timeout) + "s", "/bin/bash", "-lc", cmd],
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=timeout + 5,
            check=False,
        )
        return p.returncode, p.stdout.strip()
    except Exception as exc:
        return 1, "ERROR: " + str(exc)


def trim_maintenance_log(text):
    text = (text or "").strip()
    if len(text) <= MAINT_LOG_MAX_CHARS:
        return text
    return (
        "... Log truncated, last "
        + str(MAINT_LOG_MAX_CHARS)
        + " Zeichen ...\n"
        + text[-MAINT_LOG_MAX_CHARS:]
    )


def write_maintenance_result(title, rc, text, path=MAINT_RESULT):
    os.makedirs("/run/vdisk-relay", mode=0o755, exist_ok=True)
    content = (
        "=== " + title + " ===\n"
        + "status=" + ("OK" if rc == 0 else "ERROR") + "\n"
        + "rc=" + str(rc) + "\n"
        + "updated=" + time.strftime("%Y-%m-%d %H:%M:%S %z") + "\n"
        + trim_maintenance_log(text) + "\n"
    )
    write_atomic(path, content, 0o644)


def maintenance_result_info(path, empty_log):
    text = read_file(path, "").strip()
    if not text:
        return {
            "status": "unknown",
            "badge": '<span class="badge off">unknown</span>',
            "rc": "-",
            "updated": "-",
            "log": empty_log,
        }

    rc_match = re.search(r"^rc=(-?\d+)", text, re.M)
    status_match = re.search(r"^status=(.+)$", text, re.M)
    updated_match = re.search(r"^updated=(.+)$", text, re.M)
    rc = rc_match.group(1) if rc_match else "-"
    status = status_match.group(1).strip() if status_match else ("OK" if rc == "0" else "ERROR")
    cls = "ok" if status == "OK" else "bad"
    updated = updated_match.group(1).strip() if updated_match else file_mtime_label(path)
    return {
        "status": status,
        "badge": '<span class="badge ' + cls + '">' + esc(status) + '</span>',
        "rc": rc,
        "updated": updated,
        "log": text,
    }


def render_maintenance_result_panel(title, info, extra_rows=None):
    rows = [
        ("State", info["badge"]),
        ("Latest run", info["updated"]),
        ("Exit-Code", info["rc"]),
    ]
    if extra_rows:
        rows.extend(extra_rows)
    table_rows = []
    for key, value in rows:
        table_rows.append(
            "<tr>"
            '<th data-label="Value">' + esc(key) + "</th>"
            '<td data-label="State">' + (value if str(value).startswith("<span") else esc(value)) + "</td>"
            "</tr>"
        )
    return (
        '<h3>' + esc(title) + '</h3>'
        + '<table class="responsive-table kv-table"><tbody>'
        + ''.join(table_rows)
        + '</tbody></table>'
        + '<pre>' + esc(info["log"]) + '</pre>'
    )


def list_config_backups():
    try:
        items = []
        for name in os.listdir(CONFIG_BACKUP_DIR):
            if not name.endswith(".tar.gz"):
                continue
            path = os.path.join(CONFIG_BACKUP_DIR, name)
            st = os.stat(path)
            items.append((st.st_mtime, name, st.st_size))
        items.sort(reverse=True)
        return items[:30]
    except Exception:
        return []


def safe_config_backup_path(name):
    name = os.path.basename(name)
    if not name.endswith(".tar.gz"):
        raise ValueError("ungueltiges Backup")
    path = os.path.realpath(os.path.join(CONFIG_BACKUP_DIR, name))
    root = os.path.realpath(CONFIG_BACKUP_DIR)
    if not path.startswith(root + os.sep):
        raise ValueError("Invalid backup path")
    if not os.path.isfile(path):
        raise FileNotFoundError("Backup not found")
    return path


def send_config_backup(handler, name):
    path = safe_config_backup_path(name)
    size = os.path.getsize(path)

    handler.send_response(200)
    handler.send_header("Content-Type", "application/gzip")
    handler.send_header("Content-Length", str(size))
    handler.send_header("Content-Disposition", 'attachment; filename="' + os.path.basename(path).replace('"', '') + '"')
    handler.end_headers()

    with open(path, "rb") as f:
        while True:
            chunk = f.read(256 * 1024)
            if not chunk:
                break
            try:
                handler.wfile.write(chunk)
            except BrokenPipeError:
                break



def load_status_json():
    try:
        return json.loads(read_file(STATUS_JSON, "{}"))
    except Exception:
        return {}


def iso_to_epoch(value):
    text = str(value or "").strip()
    if not text:
        return None
    try:
        if text.endswith("Z"):
            text = text[:-1] + "+00:00"
        dt = datetime.fromisoformat(text)
        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=timezone.utc)
        return dt.timestamp()
    except Exception:
        return None


def status_generated_epoch(status_data=None):
    if not isinstance(status_data, dict):
        return None
    return iso_to_epoch(status_data.get("generated_at", ""))


def service_action_pending(status_data=None):
    data = load_json_file(SERVICE_ACTION_PENDING, {})
    if not isinstance(data, dict):
        return {}
    unit = str(data.get("unit") or "").strip()
    if unit not in ALLOWED_SERVICE_UNITS:
        clear_service_action_pending()
        return {}
    try:
        created_epoch = float(data.get("created_epoch") or 0)
    except Exception:
        created_epoch = 0
    max_age = int(data.get("max_age_seconds") or STATUS_CACHE_MAX_AGE_SECONDS)
    now = time.time()
    if created_epoch <= 0 or now - created_epoch > max(30, max_age):
        clear_service_action_pending()
        return {}
    generated_epoch = status_generated_epoch(status_data)
    if generated_epoch is not None and generated_epoch >= created_epoch:
        clear_service_action_pending()
        return {}
    data["age_seconds"] = int(max(0, now - created_epoch))
    return data


def clear_service_action_pending():
    try:
        os.unlink(SERVICE_ACTION_PENDING)
    except FileNotFoundError:
        pass
    except Exception:
        pass


def write_service_action_pending(unit, action, message=""):
    os.makedirs(os.path.dirname(SERVICE_ACTION_PENDING), mode=0o755, exist_ok=True)
    now = time.time()
    write_json_file_atomic(
        SERVICE_ACTION_PENDING,
        {
            "unit": unit,
            "action": action,
            "created_at": datetime.fromtimestamp(now, timezone.utc).astimezone().isoformat(),
            "created_epoch": now,
            "max_age_seconds": STATUS_CACHE_MAX_AGE_SECONDS,
            "message": message,
        },
    )


def trigger_status_cache_rebuild():
    return systemctl_quick(["start", "--no-block", STATUS_CACHE_SERVICE_UNIT], 8)


def service_badge(value):
    value = "" if value is None else str(value)
    if value in ("OK", "active", "enabled", "success", "timer enabled", "call enabled", "0", "inactive(success)"):
        cls = "ok"
    elif value in ("failed", "CRIT", "error"):
        cls = "bad"
    elif value in ("pending", "PENDING"):
        cls = "pending"
    elif value in ("inactive", "disabled", "unknown", "", "off"):
        cls = "off"
    else:
        cls = "warn"
    return '<span class="badge ' + cls + '">' + esc(value or "unknown") + '</span>'


def _as_text(value):
    return str(value) if value is not None else ""


def _unit_exec_status_is_timeout(exec_status):
    text = _as_text(exec_status).strip().lower()
    if not text:
        return False
    return text == "124" or "timeout" in text


def _unit_result_is_success(result, exec_status):
    result_text = _as_text(result).strip().lower()
    exec_text = _as_text(exec_status).strip().lower()
    if not result_text:
        return False
    if result_text in ("success", "0"):
        return True
    if result_text in ("exit-code",):
        try:
            return int(exec_text or 0) == 0
        except Exception:
            return exec_text == "success"
    if "timeout" in result_text:
        return True
    return False


def _unit_result_is_failed(result, exec_status):
    if _unit_exec_status_is_timeout(exec_status):
        return False

    result_text = _as_text(result).strip().lower()
    exec_text = _as_text(exec_status).strip().lower()
    if not result_text:
        return False
    if result_text in ("success", "ok", "0"):
        return False
    if "timeout" in result_text:
        return False
    if result_text == "exit-code":
        try:
            code = int(exec_text)
            return code != 0
        except Exception:
            return False
    return result_text in ("failed", "failure", "fail", "error", "abort", "aborted", "start-limit", "core-dump")


def service_state_badge(active, result="", exec_status=""):
    active_state = _as_text(active).strip().lower() or "unknown"
    if _unit_result_is_failed(result, exec_status):
        return service_badge("failed")

    if _unit_result_is_success(result, exec_status):
        return service_badge("success")

    if active_state in ("failed", "failed-condition", "failed-etc", "dependency"):
        return service_badge("failed")

    if active_state in ("inactive", "inactive (dead)", "dead", "deactivated", "deactivating", "active, but not running?"):
        return service_badge("inactive")

    return service_badge(active_state)


def service_pair_label(unit, units):
    unit_set = set(units)
    if unit.endswith(".service") and (unit[:-8] + ".timer") in unit_set:
        return "pair-parent"
    if unit.endswith(".timer") and (unit[:-6] + ".service") in unit_set:
        return "pair-child"
    if unit.endswith(".service") and (unit[:-6] + ".path") in unit_set:
        return "pair-parent"
    if unit.endswith(".path") and (unit[:-5] + ".service") in unit_set:
        return "pair-child"
    return ""


def service_enabled_display(unit, unit_set, enabled):
    if enabled != "static":
        return enabled
    return "call enabled"


def service_action_controls(active, enabled, unit):
    active_norm = (active or "").strip()
    run_action = "/service/restart" if active_norm == "active" else "/service/start"
    run_label = "Restart" if active_norm == "active" else "Start"
    run_confirm = "Restart unit" if active_norm == "active" else "Start unit"
    run_button = (
        '<form method="post" action="'
        + run_action
        + '" class="inline" onsubmit="return confirm(\''
        + run_confirm
        + ": "
        + esc(unit)
        + "?\');\">"
        '<input type="hidden" name="unit" value="'
        + esc(unit)
        + '">'
        '<button type="submit">'
        + run_label
        + "</button>"
        "</form>"
    )
    enabled_norm = (enabled or "").strip()
    if enabled_norm in ("enabled", "timer enabled", "call enabled"):
        return run_button + (
            '<form method="post" action="/service/disable" class="inline" onsubmit="return confirm(\'Disable and stop unit: '
            + esc(unit)
            + "?\');\">"
            '<input type="hidden" name="unit" value="'
            + esc(unit)
            + '">'
            '<button class="secondary" type="submit">Disable</button>'
            "</form>"
        )

    return run_button + (
            '<form method="post" action="/service/enable" class="inline" onsubmit="return confirm(\'Enable unit: '
        + esc(unit)
        + "?\');\">"
        '<input type="hidden" name="unit" value="'
        + esc(unit)
        + '">'
        '<button class="secondary" type="submit">Enable</button>'
        "</form>"
    )


def chain_unit_cell(unit, unit_set):
    role = service_pair_label(unit, unit_set)
    if role == "pair-child":
        return (
            '<span class="service-chain pair-child">'
            + '<span class="chain-icon">&#x1f517;</span><span class="service-chain-placeholder"></span>'
            + esc(unit)
            + "</span>"
        )
    if role == "pair-parent":
        return '<span class="service-chain pair-parent"><span class="service-chain-placeholder"></span>' + esc(unit) + "</span>"
    return esc(unit)


def render_services_sections(status_data=None, focus_unit=""):
    if not isinstance(status_data, dict):
        status_data = load_status_json()

    generated = status_data.get("generated_at", "") if isinstance(status_data, dict) else ""
    rows_by_group = []

    for group, units in SERVICE_GROUPS:
        unit_set = set(units)
        rows = []
        for unit in units:
            values = cached_unit_values(unit, status_data)
            active = values["active"]
            enabled = values["enabled"]
            paired_service = unit.endswith(".service") and (unit[:-8] + ".timer" in unit_set or unit[:-6] + ".path" in unit_set)
            paired_timer = (unit.endswith(".timer") and unit[:-6] + ".service" in unit_set) or (unit.endswith(".path") and unit[:-5] + ".service" in unit_set)
            pair_role = "pair-parent" if paired_service else ("pair-child" if paired_timer else "")
            if unit.endswith(".service") and paired_service and enabled == "static":
                enabled = service_enabled_display(unit, unit_set, enabled)
            enabled = service_enabled_display(unit, unit_set, enabled)
            result = values["result"]
            exec_status = values["exec_status"]
            row_class = "service-row"
            if pair_role:
                row_class += " service-pair " + pair_role
            if unit == focus_unit:
                row_class += " is-focused"
            unit_cell = chain_unit_cell(unit, unit_set)
            rows.append(
                '<tr class="' + row_class + '" id="' + esc(unit_row_id(unit)) + '">'
                + '<th data-label="Unit">' + unit_cell + "</th>"
                + '<td data-label="Active">' + service_state_badge(active, result, exec_status) + "</td>"
                + '<td data-label="Enabled">' + service_badge(enabled) + "</td>"
                + '<td data-label="Result">' + esc(result or "-") + "<br><small>ExecMainStatus: " + esc(exec_status or "-") + "</small></td>"
                + '<td class="actions service-actions" data-label="Actions">'
                + service_action_controls(active, enabled, unit)
                + '<a class="button secondary" href="/service-journal?u=' + quote(unit) + '">Journal</a>'
                + "</td>"
                + "</tr>"
            )
        rows_by_group.append(
            '<section class="panel">'
            '<h2>' + esc(group) + '</h2>'
            '<table class="responsive-table"><thead><tr><th>Unit</th><th>Active</th><th>Enabled</th><th>Result</th><th>Actions</th></tr></thead>'
            '<tbody>' + ''.join(rows) + '</tbody></table>'
            '</section>'
        )

    return generated, ''.join(rows_by_group)


def render_unit_control_rows(units, status_data=None, show_result=False):
    if not isinstance(units, (list, tuple)):
        raise ValueError("Units must be provided as a list")
    if status_data is None or not isinstance(status_data, dict):
        status_data = load_status_json()
    unit_set = set(units)
    rows = []

    for unit in units:
        values = cached_unit_values(unit, status_data)
        active = values["active"]
        enabled = values["enabled"]
        enabled = service_enabled_display(unit, unit_set, enabled)

        result = values["result"]
        exec_status = values["exec_status"]
        unit_cell = chain_unit_cell(unit, unit_set)
        result_cell = (
            '<td data-label="Result">' + esc(result or "-") + "<br><small>ExecMainStatus: " + esc(exec_status or "-") + "</small></td>"
            if show_result
            else ""
        )
        rows.append(
            '<tr class="service-row">'
            + '<th data-label="Unit">' + unit_cell + "</th>"
            + '<td data-label="Active">' + service_state_badge(active, result, exec_status) + "</td>"
            + '<td data-label="Enabled">' + service_badge(enabled) + "</td>"
            + result_cell
            + '<td class="actions service-actions" data-label="Actions">'
            + service_action_controls(active, enabled, unit)
            + '<a class="button secondary" href="/service-journal?u=' + quote(unit) + '">Journal</a>'
            + "</td>"
            + "</tr>"
        )

    if not rows:
        cols = 5 if show_result else 4
        rows.append('<tr><td colspan="' + str(cols) + '">No units available.</td></tr>')
    return ''.join(rows)


def validate_service_unit(unit):
    if unit not in ALLOWED_SERVICE_UNITS:
        raise ValueError("Invalid or disallowed unit")
    return unit


def run_systemctl_restart(unit):
    unit = validate_service_unit(unit)
    systemctl = shutil.which("systemctl") or "/bin/systemctl"
    timeout_bin = shutil.which("timeout") or "/usr/bin/timeout"
    try:
        proc = subprocess.run(
            [timeout_bin, "12s", systemctl, "--no-block", "restart", unit],
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=15,
            check=False,
        )
        return proc.returncode, proc.stdout.strip()
    except Exception as exc:
        return 1, "ERROR: " + str(exc)


def run_systemctl_start(unit):
    unit = validate_service_unit(unit)
    systemctl = shutil.which("systemctl") or "/bin/systemctl"
    timeout_bin = shutil.which("timeout") or "/usr/bin/timeout"
    try:
        proc = subprocess.run(
            [timeout_bin, "12s", systemctl, "--no-block", "start", unit],
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=15,
            check=False,
        )
        return proc.returncode, proc.stdout.strip()
    except Exception as exc:
        return 1, "ERROR: " + str(exc)


def run_systemctl_enable(unit):
    unit = validate_service_unit(unit)
    return systemctl_quick(["enable", "--now", unit], 20)


def run_systemctl_disable(unit):
    unit = validate_service_unit(unit)
    rc1, out1 = systemctl_quick(["disable", "--now", unit], 20)
    rc2, out2 = systemctl_quick(["stop", unit], 8)
    out = "\n".join(part for part in [out1, out2] if part)
    return (0 if rc1 == 0 or rc2 == 0 else rc1), out


def run_system_reboot():
    return run_system_power_action("reboot")


def run_system_shutdown():
    return run_system_power_action("poweroff")


def run_system_power_action(action):
    if action not in ("reboot", "poweroff"):
        return 1, "ERROR: ungueltige Systemaktion"
    systemctl = shutil.which("systemctl") or "/bin/systemctl"
    timeout_bin = shutil.which("timeout") or "/usr/bin/timeout"
    try:
        proc = subprocess.run(
            [timeout_bin, "8s", systemctl, action],
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=10,
            check=False,
        )
        return proc.returncode, proc.stdout.strip()
    except Exception as exc:
        return 1, "ERROR: " + str(exc)


def write_reboot_reason(reason):
    text = reason.strip() + "\n"
    write_atomic("/etc/restart.reason", text, 0o644)


def read_unit_journal(unit, lines=120):
    unit = validate_service_unit(unit)
    try:
        lines = int(lines)
    except Exception:
        lines = 120
    lines = max(40, min(400, lines))
    journalctl = shutil.which("journalctl") or "/bin/journalctl"
    timeout_bin = shutil.which("timeout") or "/usr/bin/timeout"
    try:
        proc = subprocess.run(
            [timeout_bin, "8s", journalctl, "-u", unit, "-n", str(lines), "--no-pager", "-o", "short-iso"],
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=10,
            check=False,
        )
        return proc.returncode, proc.stdout.strip()
    except Exception as exc:
        return 1, "ERROR: " + str(exc)


def systemctl_quick(args, timeout=8):
    systemctl = shutil.which("systemctl") or "/bin/systemctl"
    timeout_bin = shutil.which("timeout") or "/usr/bin/timeout"
    try:
        proc = subprocess.run(
            [timeout_bin, str(timeout) + "s", systemctl] + list(args),
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            timeout=timeout + 2,
            check=False,
        )
        return proc.returncode, proc.stdout.strip()
    except Exception as exc:
        return 1, "ERROR: " + str(exc)


def systemctl_active(unit):
    rc, out = systemctl_quick(["is-active", unit], 4)
    return out.strip() if out.strip() else ("active" if rc == 0 else "unknown")


def systemctl_enabled(unit):
    rc, out = systemctl_quick(["is-enabled", unit], 4)
    return out.strip() if out.strip() else ("enabled" if rc == 0 else "unknown")


def start_fixed_unit(unit):
    if unit not in ("vdisk-relay-update-check.service", "vdisk-relay-update.service"):
        raise ValueError("Invalid update unit")
    return systemctl_quick(["start", "--no-block", unit], 8)


def validate_update_branch(branch):
    branch = str(branch or "").strip()
    if branch not in UPDATE_BRANCH_CHOICES:
        raise ValueError("Unsupported update branch: " + (branch or "-"))
    return branch


def write_update_branch_switch_request(branch):
    branch = validate_update_branch(branch)
    json_write_atomic(
        UPDATE_BRANCH_SWITCH_REQUEST,
        {
            "branch": branch,
            "requested_at": datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds"),
            "source": "webui",
        },
        0o644,
    )
    return branch


def clear_update_branch_switch_request():
    try:
        os.unlink(UPDATE_BRANCH_SWITCH_REQUEST)
    except FileNotFoundError:
        pass


def update_badge(status, running=False):
    if running:
        return '<span class="badge warn">RUNNING</span>'
    if status in ("ok", "success"):
        return '<span class="badge ok">' + esc(status.upper()) + '</span>'
    if status in ("failed", "error"):
        return '<span class="badge bad">' + esc(status.upper()) + '</span>'
    return '<span class="badge warn">' + esc((status or "unknown").upper()) + '</span>'


def update_capability():
    repo_root = read_file(UPDATE_REPO_ROOT, "").strip()
    git_creds = git_credentials_status()
    return {
        "repo_root": repo_root,
        "repo_known": bool(repo_root),
        "repo_exists": bool(repo_root and os.path.isdir(repo_root)),
        "runner_exists": os.path.isfile("/usr/local/sbin/vdisk-relay-update-run"),
        "check_exists": os.path.isfile("/usr/local/sbin/vdisk-relay-update-check"),
        "update_service": systemctl_active("vdisk-relay-update.service"),
        "check_service": systemctl_active("vdisk-relay-update-check.service"),
        "check_timer": systemctl_enabled("vdisk-relay-update-check.timer"),
        "git_credentials": git_creds,
    }


def read_log_tail(path, max_lines=120, max_chars=12000):
    text = read_file(path, "")
    if not text:
        return ""
    lines = text.splitlines()[-max_lines:]
    out = "\n".join(lines)
    if len(out) > max_chars:
        out = out[-max_chars:]
    return out


def read_update_log_tail(max_lines=120, max_chars=12000):
    return read_log_tail(UPDATE_LOG, max_lines, max_chars)


def timeline_trace_file():
    path = config_value("TIMELINE_TRACE_FILE", "/var/log/vdisk-relay-timeline.jsonl")
    return path if path.startswith("/") else "/var/log/vdisk-relay-timeline.jsonl"


def read_log_section(section):
    if section == "check-log":
        return read_log_tail(UPDATE_CHECK_LOG, 120, 20000)
    if section == "check-journal":
        rc, content = read_unit_journal("vdisk-relay-update-check.service", 80)
        return content or ("No journal output. rc=" + str(rc))
    if section in ("update-log", "run-log"):
        return read_update_log_tail(120, 20000)
    if section == "timeline-log":
        content = read_log_tail(timeline_trace_file(), 180, 40000)
        return content or "No timeline data available or timeline trace is disabled."
    if section == "telegram-log":
        content = matching_log_lines(APP_LOG, TELEGRAM_LOG_PATTERNS, TELEGRAM_DEBUG_LOG_LINES, TELEGRAM_DEBUG_LOG_BYTES)
        return content or "No Telegram log lines in the current excerpt."
    raise ValueError("Invalid log range")


def clearable_log_path(section):
    if section == "check-log":
        return UPDATE_CHECK_LOG
    if section in ("update-log", "run-log"):
        return UPDATE_LOG
    if section == "timeline-log":
        return timeline_trace_file()
    if section == "telegram-log":
        return APP_LOG
    raise ValueError("This log cannot be cleared")


def clear_log_file(path):
    if not path or not path.startswith("/") or "\x00" in path:
        raise ValueError("Invalid log path")
    parent = os.path.dirname(path)
    if parent:
        os.makedirs(parent, mode=0o750, exist_ok=True)
    fd = os.open(path, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
    os.close(fd)


def handle_log_clear_post(handler, path, form):
    if path != "/log/clear":
        return False
    section = form.get("section", [""])[0].strip()
    try:
        clear_log_file(clearable_log_path(section))
    except Exception as exc:
        handler.send_json({"ok": False, "section": section, "error": str(exc)}, code=400)
        return True
    handler.send_json({"ok": True, "section": section, "content": "", "message": "Log cleared"})
    return True


def render_timeline_log_page():
    path = timeline_trace_file()
    content = read_log_section("timeline-log")
    body = (
        settings_tabs("timeline")
        + '<section class="panel">'
        + '<div class="panel-head-inline"><h2>' + esc(t("phrase.timeline")) + '</h2><div class="log-actions">'
        + '<button class="button secondary icon-button" type="button" data-log-refresh="timeline-log" data-log-target="timeline-log" title="' + esc(t("phrase.reload_timeline")) + '" aria-label="' + esc(t("phrase.reload_timeline")) + '">&#8635;</button>'
        + '<button class="button secondary icon-button log-clear-button" type="button" data-log-clear="timeline-log" data-log-target="timeline-log" title="' + esc(t("phrase.clear_timeline")) + '" aria-label="' + esc(t("phrase.clear_timeline")) + '">&times;</button>'
        + '<a class="button secondary" href="/settings/timeline">' + esc(t("phrase.back")) + '</a></div></div>'
        + render_kv_table([
            (t("settings.timeline_file"), path),
            (t("settings.timeline_trace"), "active" if parse_int_config_value(read_file(CONFIG), "TIMELINE_TRACE_ENABLED", 0) == 1 else "off"),
            (t("settings.timeline_system_snapshot"), "active" if parse_int_config_value(read_file(CONFIG), "TIMELINE_TRACE_SYSTEM_SNAPSHOT", 0) == 1 else "off"),
        ])
        + '<pre class="log-output" id="timeline-log">' + esc(content) + '</pre>'
        + '</section>'
    )
    return html_page(t("phrase.timeline"), body, active="settings", subtitle=t("settings.subtitle_timeline_log"))


def render_kv_table(items):
    rows = []
    for key, value in items:
        rows.append("<tr><th>" + esc(key) + "</th><td>" + esc(value) + "</td></tr>")
    return '<table class="kv-table"><tbody>' + "".join(rows) + "</tbody></table>"


def render_update_page(query=None):
    query = query or {}
    msg = query.get("msg", [""])[0]
    check = load_json_file(UPDATE_CHECK_STATUS, {})
    job = load_json_file(UPDATE_STATUS, {})
    def _value_from(dict_like, key, default=""):
        return dict_like.get(key, default) if isinstance(dict_like, dict) else default

    def _is_status_running(value):
        status = str(value or "").strip().lower()
        return status in {"running", "starting", "fetching", "pulling", "installing", "verifying", "updating"}

    def _is_unit_running(state):
        normalized = str(state or "").strip().lower()
        return normalized in {"active", "activating", "reloading", "running"}

    check_status = check.get("status", "unknown") if isinstance(check, dict) else "unknown"
    job_status = job.get("status", "never run") if isinstance(job, dict) else "never run"
    job_phase = job.get("phase", "") if isinstance(job, dict) else ""
    job_message = job.get("message", "") if isinstance(job, dict) else ""

    check_service_state = systemctl_active("vdisk-relay-update-check.service")
    update_service_state = systemctl_active("vdisk-relay-update.service")
    check_active = _is_unit_running(check_service_state) or _is_status_running(check_status)
    update_active = (
        _is_unit_running(update_service_state)
        or bool(_value_from(job, "running", False))
        or _is_status_running(job_status)
    )
    capability = update_capability()
    status_data = load_status_json()
    check_journal_rc, check_journal = read_unit_journal("vdisk-relay-update-check.service", 80)
    updater_unit_rows = render_unit_control_rows(UPDATER_UNITS, status_data=status_data)
    actual_branch = current_git_branch()
    check_branch = str(check.get("branch", "") if isinstance(check, dict) else "").strip()
    job_branch = str(job.get("branch", "") if isinstance(job, dict) else "").strip()
    current_branch = actual_branch if actual_branch != "-" else job_branch or check_branch
    display_branch = current_branch or "-"
    can_start = (
        capability["repo_known"]
        and capability["repo_exists"]
        and capability["runner_exists"]
        and not update_active
    )
    can_switch_branch = (
        capability["repo_known"]
        and capability["repo_exists"]
        and capability["runner_exists"]
        and not update_active
        and not check_active
    )

    update_button = (
        '<button class="danger" type="submit">Start update</button>'
        if can_start
        else '<button class="danger" type="submit" disabled>Start update</button>'
    )
    check_button = '<button type="submit">Check update</button>'

    branch_buttons = []
    for branch_name in UPDATE_BRANCH_CHOICES:
        branch_label = "Active: " + branch_name if branch_name == current_branch else "Switch to " + branch_name
        disabled = " disabled" if branch_name == current_branch or not can_switch_branch else ""
        branch_buttons.append(
            '<form method="post" action="/update/branch" class="inline" data-ayesx-reload="0" onsubmit="return confirm(\'Switch update branch to '
            + esc(branch_name)
            + '? The updater will pull and install that branch.\');">'
            + '<input type="hidden" name="branch" value="' + esc(branch_name) + '">'
            + '<button type="submit" class="secondary"' + disabled + '>' + esc(branch_label) + '</button>'
            + '</form>'
        )

    monitor_active = "1" if update_active or check_active else "0"
    refresh_script = ""

    update_log_script = """
<script>
(function(){
  var pollTimer = null;
  var reloadAfterFinish = false;
  var lastDisconnected = false;
  var actionGraceUntil = 0;
  var autoLogRefreshAt = 0;
  var activePollMs = 5000;
  var idlePollMs = 15000;
  var runLogAutoRefreshEnabled = false;
  var runLogAutoRefreshTimer = null;
  var runLogAutoRefreshInFlight = false;
  var runLogAutoRefreshIntervalMs = 5000;

  function setLoading(btn, busy) {
    if (!btn) {
      return;
    }
    btn.disabled = busy;
  }

  function escapeHtml(value) {
    return String(value == null ? '' : value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  function setText(id, value) {
    var node = document.getElementById(id);
    if (node) {
      node.textContent = value == null || value === '' ? '-' : String(value);
    }
  }

  function setHtml(id, html) {
    var node = document.getElementById(id);
    if (node) {
      node.innerHTML = html || '';
    }
  }

  function badgeHtml(status, running) {
    var raw = String(status || 'unknown');
    var lower = raw.toLowerCase();
    var cls = 'warn';
    var label = raw.toUpperCase();
    if (running) {
      label = 'RUNNING';
    } else if (lower === 'ok' || lower === 'success' || lower === 'aktuell') {
      cls = 'ok';
    } else if (lower === 'error' || lower === 'failed' || lower === 'fehler') {
      cls = 'bad';
    }
    return '<span class="badge ' + cls + '">' + escapeHtml(label) + '</span>';
  }

  function serviceActive(value) {
    var valueLower = String(value || '').toLowerCase();
    return valueLower === 'active' || valueLower === 'activating' || valueLower === 'reloading' || valueLower === 'running';
  }

  function statusRunning(status) {
    var text = String(status || '').toLowerCase();
    return (
      text === 'running' ||
      text === 'starting' ||
      text === 'fetching' ||
      text === 'pulling' ||
      text === 'installing' ||
      text === 'verifying' ||
      text === 'checking'
    );
  }

  function liveRoot() {
    return document.getElementById('update-page-live');
  }

  function setLiveState(message, waiting) {
    var root = liveRoot();
    var state = document.getElementById('update-live-state');
    if (root) {
      root.classList.toggle('is-waiting', !!waiting);
    }
    if (state) {
      state.textContent = message || '';
    }
  }

  function refreshUpdateLog(btn, section, targetId, options) {
    var pre = document.getElementById(targetId);
    var quiet = options && options.quiet;
    if (!pre) {
      return Promise.resolve(false);
    }
    setLoading(btn, true);
    return fetch('/update-log?section=' + encodeURIComponent(section) + '&_=' + Date.now(), {
      cache: 'no-store',
      headers: {
        'Accept': 'application/json',
        'X-Requested-With': 'fetch'
      }
    })
      .then(function(response){
        return response.text().then(function(rawText){
          if (!response.ok) {
            throw new Error('HTTP ' + response.status);
          }
          return rawText;
        });
      })
      .then(function(rawText){
        var text = '';
        try {
          text = JSON.parse(rawText).content || '';
        } catch (err) {
          text = rawText;
        }
        pre.textContent = text || text('js.no_log_output', 'No log output.');
        pre.scrollTop = pre.scrollHeight;
        return true;
      })
      .catch(function(err){
        if (!quiet) {
          pre.textContent = text('js.log_unreachable_retry', 'Log is currently unreachable. The page keeps trying. ') + String(err.message || err);
        }
        return false;
      })
      .finally(function(){
        setLoading(btn, false);
        pre.scrollTop = pre.scrollHeight;
      });
  }

  function runLogAutoRefreshButton() {
    return document.getElementById('update-run-autorefresh');
  }

  function setRunLogAutoRefreshControlState(enabled) {
    var btn = runLogAutoRefreshButton();
    if (!btn) {
      return;
    }
    runLogAutoRefreshEnabled = !!enabled;
    btn.classList.toggle('is-busy', runLogAutoRefreshEnabled);
    btn.setAttribute('aria-pressed', runLogAutoRefreshEnabled ? 'true' : 'false');
    btn.title = runLogAutoRefreshEnabled ? 'Stop auto-refresh update log' : 'Start auto-refresh update log';
    btn.setAttribute('aria-label', btn.title);
    btn.textContent = runLogAutoRefreshEnabled ? 'Stop' : 'Auto';
  }

  function stopRunLogAutoRefresh() {
    runLogAutoRefreshEnabled = false;
    if (runLogAutoRefreshTimer) {
      window.clearTimeout(runLogAutoRefreshTimer);
      runLogAutoRefreshTimer = null;
    }
    runLogAutoRefreshInFlight = false;
    setRunLogAutoRefreshControlState(false);
  }

  function scheduleRunLogAutoRefresh(ms) {
    if (runLogAutoRefreshTimer) {
      window.clearTimeout(runLogAutoRefreshTimer);
      runLogAutoRefreshTimer = null;
    }
    if (!runLogAutoRefreshEnabled) {
      return;
    }
    var delay = Number(ms);
    if (!delay || delay < 200) {
      delay = runLogAutoRefreshIntervalMs;
    }
    runLogAutoRefreshTimer = window.setTimeout(refreshRunLogAuto, delay);
  }

  function refreshRunLogAuto() {
    if (!runLogAutoRefreshEnabled || !liveRoot()) {
      return;
    }
    if (runLogAutoRefreshInFlight) {
      scheduleRunLogAutoRefresh(runLogAutoRefreshIntervalMs);
      return;
    }
    runLogAutoRefreshInFlight = true;
    refreshUpdateLog(null, 'update-log', 'update-run-log', { quiet: true })
      .finally(function(){
        runLogAutoRefreshInFlight = false;
        if (runLogAutoRefreshEnabled) {
          scheduleRunLogAutoRefresh(runLogAutoRefreshIntervalMs);
        }
      });
  }

  function toggleRunLogAutoRefresh() {
    if (runLogAutoRefreshEnabled) {
      stopRunLogAutoRefresh();
      return;
    }
    runLogAutoRefreshEnabled = true;
    setRunLogAutoRefreshControlState(true);
    refreshRunLogAuto();
  }

  function schedulePoll(ms) {
    if (pollTimer) {
      window.clearTimeout(pollTimer);
    }
    pollTimer = window.setTimeout(pollUpdateStatus, ms);
  }

  function markDisconnected() {
    lastDisconnected = true;
    reloadAfterFinish = true;
    setLiveState(text('js.webserver_down_update', 'The web server is not responding. The update page keeps waiting.'), true);
    schedulePoll(activePollMs);
  }

  function maybeRefreshLogs(updateRunning, checkRunning) {
    var now = Date.now();
    if (now - autoLogRefreshAt < 9000) {
      return;
    }
    autoLogRefreshAt = now;
    if (updateRunning) {
      refreshUpdateLog(null, 'update-log', 'update-run-log', { quiet: true });
    }
    if (checkRunning) {
      refreshUpdateLog(null, 'check-log', 'update-check-log', { quiet: true });
    }
  }

  function renderStatus(payload) {
    var check = payload && payload.check && typeof payload.check === 'object' ? payload.check : {};
    var job = payload && payload.job && typeof payload.job === 'object' ? payload.job : {};
    var checkRunning = serviceActive(payload && payload.check_service) || statusRunning(check && check.status);
    var updateRunning = serviceActive(payload && payload.update_service) || statusRunning(job && job.status) || !!job.running;
    var running = checkRunning || updateRunning;
    var message = check.message || text('js.no_update_check', 'No update check available yet');
    var jobStatus = job.status || text('js.never_run', 'never run');
    var jobLine = badgeHtml(jobStatus, updateRunning) + ' ' + escapeHtml(job.phase || '') + ' ' + escapeHtml(job.message || '');

    setText('update-live-message', message);
    setHtml('update-check-badge', badgeHtml(check.status || 'unknown', checkRunning));
    setHtml('update-job-summary', jobLine);
    setText('update-branch', job.branch || check.branch || '-');
    setText('update-local', check.current_short || '-');
    setText('update-remote', check.remote_short || '-');
    setText('update-behind', check.behind == null ? '-' : check.behind);

    if (running) {
      reloadAfterFinish = true;
      lastDisconnected = false;
      maybeRefreshLogs(updateRunning, checkRunning);
      setLiveState(updateRunning ? text('js.update_running', 'Update running. This page stays open during web service restarts.') : text('js.update_check_running', 'Update check running.'), false);
      schedulePoll(activePollMs);
      return;
    }

    if (reloadAfterFinish && Date.now() < actionGraceUntil) {
      setLiveState(text('js.update_action_starting', 'Action is starting. Waiting for service status.'), false);
      schedulePoll(1200);
      return;
    }

    if (reloadAfterFinish) {
      setLiveState(lastDisconnected ? text('js.update_server_back', 'Web server is reachable again. Reloading page.') : text('js.update_finished_reload', 'Update finished. Reloading page.'), false);
      window.setTimeout(function(){
        window.location.replace('/update?msg=' + encodeURIComponent(text('js.update_finished', 'Update finished')));
      }, 900);
      return;
    }

    setLiveState(text('js.update_idle', 'State is current. Automatic checks continue in the background.'), false);
    schedulePoll(idlePollMs);
  }

  function pollUpdateStatus() {
    if (!liveRoot()) {
      return;
    }
    fetch('/update-status.json?_=' + Date.now(), {
      cache: 'no-store',
      headers: {
        'Accept': 'application/json',
        'X-Requested-With': 'fetch'
      }
    })
      .then(function(response){
        if (!response.ok) {
          throw new Error('HTTP ' + response.status);
        }
        return response.json();
      })
      .then(function(payload){
        renderStatus(payload || {});
      })
      .catch(function(){
        markDisconnected();
      });
  }

  document.addEventListener('videoVdisk:ayesxAction', function(event){
    var path = event.detail && event.detail.path;
    if (path !== '/update/check' && path !== '/update/start' && path !== '/update/branch') {
      return;
    }
    reloadAfterFinish = true;
    actionGraceUntil = Date.now() + 10000;
    setLiveState(
      path === '/update/start'
        ? text('js.update_started_waiting', 'Update was started. Waiting for status data.')
        : (path === '/update/branch' ? text('js.branch_switch_started', 'Branch switch was started. Waiting for status data.') : text('js.update_check_started', 'Update check was started.')),
      false
    );
    schedulePoll(800);
  });

  document.addEventListener('videoVdisk:updateConnectionLost', function(event){
    var path = event.detail && event.detail.path;
    if (path === '/update/check' || path === '/update/start' || path === '/update/branch') {
      markDisconnected();
    }
  });

  document.addEventListener('visibilitychange', function(){
    if (!document.hidden && liveRoot()) {
      schedulePoll(200);
    }
  });

  if (liveRoot()) {
    reloadAfterFinish = liveRoot().getAttribute('data-update-active') === '1';
    setRunLogAutoRefreshControlState(runLogAutoRefreshEnabled);
    document.addEventListener('click', function(event){
      var btn = event.target.closest('[data-log-autorefresh]');
      if (!btn) {
        return;
      }
      event.preventDefault();
      event.stopImmediatePropagation();
      toggleRunLogAutoRefresh();
    });
    stopRunLogAutoRefresh();
    schedulePoll(1200);
  }
})();
</script>
"""

    body = (
        settings_context("System")
        + settings_tabs("system")
        + maintenance_tabs("update")
        + msg_html(msg)
        + '<section class="hero-status update-live" id="update-page-live" data-update-active="' + monitor_active + '">'
        + '<div><div class="status-title">Update availability</div>'
        + '<div class="status-value" id="update-live-message">' + esc(check.get("message", "No update check available yet") if isinstance(check, dict) else "No update check available yet") + '</div>'
        + '<p class="muted" id="update-live-state">This page load does not run a Git fetch. The snapshot comes from ' + esc(UPDATE_CHECK_STATUS) + '.</p></div>'
        + '<div id="update-check-badge">' + update_badge(check_status, check_active) + '</div>'
        + '</section>'
        + '<div class="update-status-grid">'
        + '<div class="stat-card"><span>Branch</span><b id="update-branch">' + esc(display_branch) + '</b></div>'
        + '<div class="stat-card"><span>Local</span><b id="update-local">' + esc(check.get("current_short", "-") if isinstance(check, dict) else "-") + '</b></div>'
        + '<div class="stat-card"><span>Remote</span><b id="update-remote">' + esc(check.get("remote_short", "-") if isinstance(check, dict) else "-") + '</b></div>'
        + '<div class="stat-card"><span>Behind</span><b id="update-behind">' + esc(check.get("behind", "-") if isinstance(check, dict) else "-") + '</b></div>'
        + '</div>'
        + '<section class="panel">'
        + '<h2>Actions</h2>'
        + '<form method="post" action="/update/check" class="inline" data-ayesx-reload="0">'
        + check_button
        + '</form>'
        + '<form method="post" action="/update/start" class="inline" data-ayesx-reload="0" onsubmit="return confirm(\'Start update now? The web service may restart briefly during the update.\');">'
        + update_button
        + '</form>'
        + '<a class="button secondary" href="/update">Refresh</a>'
        + '<div class="actions">'
        + ''.join(branch_buttons)
        + '</div>'
        + '</section>'
        + '<section class="panel">'
        + '<h2>Latest update run</h2>'
        + '<p id="update-job-summary">' + update_badge(job_status, update_active) + ' ' + esc(job_phase) + ' ' + esc(job_message) + '</p>'
        + render_kv_table([
            ("Job", job.get("job_id", "-") if isinstance(job, dict) else "-"),
            ("Started", job.get("started_at", "-") if isinstance(job, dict) else "-"),
            ("Finished", job.get("finished_at", "-") if isinstance(job, dict) else "-"),
            ("Old commit", job.get("old_commit", "-")[:12] if isinstance(job, dict) and job.get("old_commit") else "-"),
            ("New commit", job.get("new_commit", "-")[:12] if isinstance(job, dict) and job.get("new_commit") else "-"),
            ("Exit-Code", job.get("exit_code", "-") if isinstance(job, dict) else "-"),
        ])
        + '<h3>Update-Log'
        + '<button class="button secondary icon-button" type="button" data-log-refresh="update-log" data-log-target="update-run-log" title="Reload update log" aria-label="Reload update log">&#8635;</button>'
        + '<button class="button secondary icon-button" id="update-run-autorefresh" type="button" data-log-autorefresh="1" data-log-target="update-run-log" title="Start auto-refresh update log" aria-label="Start auto-refresh update log" aria-pressed="false">Auto</button>'
        + '<button class="button secondary icon-button log-clear-button" type="button" data-log-clear="update-log" data-log-target="update-run-log" title="Clear update log" aria-label="Clear update log">&times;</button>'
        + '</h3>'
        + '<pre class="update-log" id="update-run-log">' + esc(read_update_log_tail() or "No update log available yet.") + '</pre>'
        + '</section>'
        + '<section class="panel">'
        + '<h2>Latest update check</h2>'
        + render_kv_table([
            ("State", check_status),
            ("Checked", check.get("checked_at", "-") if isinstance(check, dict) else "-"),
            ("Message", check.get("message", "-") if isinstance(check, dict) else "-"),
            ("Diagnostics", check.get("diagnostics", "-") if isinstance(check, dict) else "-"),
            ("Logdatei", UPDATE_CHECK_LOG),
        ])
        + '<h3>Check-Log'
        + '<button class="button secondary icon-button" type="button" data-log-refresh="check-log" data-log-target="update-check-log" title="Reload check log" aria-label="Reload check log">&#8635;</button>'
        + '<button class="button secondary icon-button log-clear-button" type="button" data-log-clear="check-log" data-log-target="update-check-log" title="Clear check log" aria-label="Clear check log">&times;</button>'
        + '</h3>'
        + '<pre class="update-log" id="update-check-log">' + esc(read_log_tail(UPDATE_CHECK_LOG) or "No update check log available yet.") + '</pre>'
        + '<h3>Check-Journal'
        + '<button class="button secondary icon-button" type="button" data-log-refresh="check-journal" data-log-target="update-check-journal" title="Reload check journal" aria-label="Reload check journal">&#8635;</button>'
        + '</h3>'
        + '<pre class="update-log" id="update-check-journal">' + esc(check_journal or ("No journal output. rc=" + str(check_journal_rc))) + '</pre>'
        + '</section>'
        + '<section class="panel">'
        + '<h2>Update-Capability</h2>'
        + render_kv_table([
            ("Repo path", capability["repo_root"] or "-"),
            ("Repo available", "yes" if capability["repo_exists"] else "no"),
            ("Update-Runner", "yes" if capability["runner_exists"] else "no"),
            ("Update-Check", "yes" if capability["check_exists"] else "no"),
            ("Update-Service", capability["update_service"]),
            ("Check-Service", capability["check_service"]),
            ("Check-Timer", capability["check_timer"]),
        ])
        + '</section>'
        + '<section class="panel">'
        + '<h2>Updater-Units</h2>'
        + '<table class="responsive-table"><thead><tr><th>Unit</th><th>Active</th><th>Enabled</th><th>Actions</th></tr></thead><tbody>'
        + updater_unit_rows
        + '</tbody></table>'
        + '</section>'
        + refresh_script
        + update_log_script
    )

    return html_page("Update", body, active="settings", subtitle="Check availability and start a controlled update.", show_update_banner=False)


def handle_update_post(handler, path, form):
    if path == "/update/check":
        rc, out = start_fixed_unit("vdisk-relay-update-check.service")
        msg = "Update check started" if rc == 0 else "Update check could not be started: " + out[:180]
        handler.redirect("/update?msg=" + quote(msg))
        return True

    if path == "/update/start":
        if systemctl_active("vdisk-relay-update.service") == "active":
            handler.redirect("/update?msg=" + quote("Update already running"))
            return True
        capability = update_capability()
        if not (capability["repo_known"] and capability["repo_exists"] and capability["runner_exists"]):
            handler.redirect("/update?msg=" + quote("Update capability missing"))
            return True
        rc, out = start_fixed_unit("vdisk-relay-update.service")
        msg = "Update started" if rc == 0 else "Update could not be started: " + out[:180]
        handler.redirect("/update?msg=" + quote(msg))
        return True

    if path == "/update/branch":
        if systemctl_active("vdisk-relay-update.service") == "active":
            handler.redirect("/update?msg=" + quote("Update already running"))
            return True
        if systemctl_active("vdisk-relay-update-check.service") == "active":
            handler.redirect("/update?msg=" + quote("Update check already running"))
            return True
        capability = update_capability()
        if not (capability["repo_known"] and capability["repo_exists"] and capability["runner_exists"]):
            handler.redirect("/update?msg=" + quote("Update capability missing"))
            return True
        try:
            branch = write_update_branch_switch_request(form.get("branch", [""])[0])
        except ValueError as exc:
            handler.redirect("/update?msg=" + quote(str(exc)))
            return True
        rc, out = start_fixed_unit("vdisk-relay-update.service")
        if rc != 0:
            clear_update_branch_switch_request()
        msg = "Branch switch to " + branch + " started" if rc == 0 else "Branch switch could not be started: " + out[:180]
        handler.redirect("/update?msg=" + quote(msg))
        return True

    return False


def handle_emergency_post(handler, path, form):
    if not path.startswith("/emergency/"):
        return False

    if path == "/emergency/heartbeat":
        payload = write_emergency_heartbeat(
            route=form.get("route", ["/wifi"])[0],
            session_id=form.get("session_id", [""])[0],
            source=form.get("source", ["heartbeat"])[0],
        )
        handler.send_json({"ok": True, "message": "Heartbeat saved", "heartbeat": payload})
        return True

    if path == "/emergency/hold":
        write_emergency_heartbeat(
            route=form.get("route", ["/wifi?emergency=1"])[0],
            session_id=form.get("session_id", ["manual"])[0],
            source="hold-button",
        )
        handler.redirect("/wifi?emergency=1&msg=" + quote("AP hold time updated"))
        return True

    if path == "/emergency/test-normal":
        clear_emergency_heartbeat()
        rc, out = systemctl_quick(["start", "--no-block", "vdisk-relay-network-guardian.service"], 8)
        if rc == 0:
            msg = "Normal mode check started"
        else:
            msg = "Normal mode check could not be started rc=" + str(rc) + ": " + out[:180]
        handler.redirect("/wifi?emergency=1&msg=" + quote(msg))
        return True

    return False


def handle_general_post(handler, path, form):
    if path != "/general/save":
        return False

    perf_current = performance_debug_config_values()
    display_timezone = validate_web_display_timezone(form.get("web_display_timezone", [web_display_timezone_name()])[0])

    def bounded_int(field, label, min_value, max_value, default_value=None):
        fallback = "" if default_value is None else str(default_value)
        raw_value = form.get(field, [fallback])[0].strip()
        try:
            value = int(raw_value)
        except Exception:
            raise ValueError(label + " is invalid")
        if value < min_value or value > max_value:
            raise ValueError(label + " must be between " + str(min_value) + " and " + str(max_value) + "")
        return value

    raw = form.get("max_video_age_hours", [""])[0].strip()
    try:
        hours = int(raw)
    except Exception:
        raise ValueError("Max-age hours is invalid")
    if hours < 1 or hours > 720:
        raise ValueError("Max-age hours must be between 1 and 720")
    raw_saver = form.get("screensaver_idle_minutes", ["0"])[0].strip()
    try:
        saver_minutes = int(raw_saver)
    except Exception:
        raise ValueError("Screen saver minutes is invalid")
    if saver_minutes < 0 or saver_minutes > 1440:
        raise ValueError("Screen saver minutes must be between 0 and 1440")
    raw_mode = form.get("screensaver_mode", ["floating"])[0].strip().lower()
    if raw_mode not in ("legacy", "floating"):
        raise ValueError("Unknown screensaver mode")
    timeline_file = form.get("timeline_trace_file", [str(perf_current["TIMELINE_TRACE_FILE"])])[0].strip()
    if not timeline_file.startswith("/"):
        raise ValueError("Timeline file must be an absolute path")
    if len(timeline_file) > 200:
        raise ValueError("Timeline file is too long")
    validate_config_literal(timeline_file, "timeline_trace_file")
    duplicate_mode = form.get("ultra_duplicate_mode", [str(perf_current["ULTRA_FAST_DUPLICATE_MODE"] or "filename")])[0].strip()
    if duplicate_mode not in ULTRA_FAST_DUPLICATE_MODES:
        raise ValueError("Unknown Ultra duplicate protection mode")

    seconds = hours * 3600
    updates = {
        "WEB_DISPLAY_TIMEZONE": display_timezone,
        "MAX_DATA_AGE_SECONDS": seconds,
        "WEB_SCREENSAVER_IDLE_MINUTES": saver_minutes,
        "WEB_SCREENSAVER_MODE": raw_mode,
        "TIMELINE_TRACE_ENABLED": bounded_int("timeline_trace_enabled", "Timeline-Trace", 0, 1, perf_current["TIMELINE_TRACE_ENABLED"]),
        "TIMELINE_TRACE_FILE": timeline_file,
        "TIMELINE_TRACE_SYSTEM_SNAPSHOT": bounded_int("timeline_trace_system_snapshot", "System-Snapshot", 0, 1, perf_current["TIMELINE_TRACE_SYSTEM_SNAPSHOT"]),
        "TELEGRAM_TRACE_REPLY_BODY": bounded_int("telegram_trace_reply_body", "Telegram Reply Body", 0, 1, perf_current["TELEGRAM_TRACE_REPLY_BODY"]),
        "TELEGRAM_TRACE_REPLY_MAX_BYTES": bounded_int("telegram_trace_reply_max_bytes", "Reply-Max-Bytes", 0, 200000, perf_current["TELEGRAM_TRACE_REPLY_MAX_BYTES"]),
        "DELETE_PREVIEW_WITH_VIDEO": bounded_int("delete_preview_with_video", "Delete preview with video", 0, 1, perf_current["DELETE_PREVIEW_WITH_VIDEO"]),
        "ULTRA_FAST_LANE_ENABLED": bounded_int("ultra_fast_lane_enabled", "Ultra Fast Lane", 0, 1, perf_current["ULTRA_FAST_LANE_ENABLED"]),
        "ULTRA_FAST_LANE_DELAY_SECONDS": bounded_int("ultra_fast_lane_delay_seconds", "Ultra Delay", 0, 3600, perf_current["ULTRA_FAST_LANE_DELAY_SECONDS"]),
        "ULTRA_FAST_LANE_QUIET_SECONDS": bounded_int("ultra_fast_lane_quiet_seconds", "Ultra Quiet", 0, 3600, perf_current["ULTRA_FAST_LANE_QUIET_SECONDS"]),
        "ULTRA_FAST_LANE_SYNC_AFTER_SEND": bounded_int("ultra_fast_lane_sync_after_send", "Sync after Ultra dispatch", 0, 1, perf_current["ULTRA_FAST_LANE_SYNC_AFTER_SEND"]),
        "ULTRA_FAST_DUPLICATE_MODE": duplicate_mode,
        "ULTRA_FAST_REMAINDER_QUEUE_ENABLED": bounded_int("ultra_fast_remainder_queue_enabled", "Ultra FIFO-Restqueue", 0, 1, perf_current["ULTRA_FAST_REMAINDER_QUEUE_ENABLED"]),
        "ULTRA_FAST_REMAINDER_QUEUE_DELAY_SECONDS": bounded_int("ultra_fast_remainder_queue_delay_seconds", "Ultra FIFO-Delay", 0, 3600, perf_current["ULTRA_FAST_REMAINDER_QUEUE_DELAY_SECONDS"]),
    }
    update_config_values(
        updates,
        section_label="General",
        ordered_keys=[
            "WEB_DISPLAY_TIMEZONE",
            "WEB_SCREENSAVER_IDLE_MINUTES",
            "WEB_SCREENSAVER_MODE",
            "MAX_DATA_AGE_SECONDS",
            "TIMELINE_TRACE_ENABLED",
            "TIMELINE_TRACE_FILE",
            "TIMELINE_TRACE_SYSTEM_SNAPSHOT",
            "TELEGRAM_TRACE_REPLY_BODY",
            "TELEGRAM_TRACE_REPLY_MAX_BYTES",
            "DELETE_PREVIEW_WITH_VIDEO",
            "ULTRA_FAST_LANE_ENABLED",
            "ULTRA_FAST_LANE_DELAY_SECONDS",
            "ULTRA_FAST_LANE_QUIET_SECONDS",
            "ULTRA_FAST_LANE_SYNC_AFTER_SEND",
            "ULTRA_FAST_DUPLICATE_MODE",
            "ULTRA_FAST_REMAINDER_QUEUE_ENABLED",
            "ULTRA_FAST_REMAINDER_QUEUE_DELAY_SECONDS",
        ],
    )
    saved_section = form.get("settings_section", ["general"])[0].strip().lower()
    section_redirects = {
        "general": "/general",
        "display": "/settings/display",
        "timeline": "/settings/timeline",
        "performance": "/settings/performance",
        "previews": "/settings/previews",
        "telegram": "/settings/telegram",
    }
    target = section_redirects.get(saved_section, "/general")
    handler.redirect(target + "?msg=" + quote("General settings saved"))
    return True


def validate_network_guardian_int(form, key):
    min_value, max_value = NETWORK_GUARDIAN_INTEGER_LIMITS[key]
    raw = form.get(key, [""])[0].strip()
    try:
        value = int(raw)
    except Exception:
        raise ValueError("Invalid value for " + key)
    if value < min_value or value > max_value:
        raise ValueError(key + " must be between " + str(min_value) + " and " + str(max_value) + "")
    return value


def validate_config_literal(value, name):
    validate_plain(value, name)
    if "$" in value or "`" in value or "\\" in value:
        raise ValueError("Invalid shell metacharacter in " + name)
    return value


def validate_network_guardian_text(form, key, required=True):
    value = form.get(key, [""])[0].strip()
    if required and not value:
        raise ValueError(key + " missing")
    if len(value) > NETWORK_GUARDIAN_TEXT_MAX_LENGTHS[key]:
        raise ValueError(key + " is too long")
    validate_config_literal(value, key)
    return value


def validate_network_guardian_config_form(form, current_config):
    updates = {}
    for key in NETWORK_GUARDIAN_INTEGER_LIMITS:
        updates[key] = validate_network_guardian_int(form, key)

    ssid_prefix = validate_network_guardian_text(form, "NETWORK_GUARDIAN_AP_SSID_PREFIX")
    ap_ipv4 = validate_ipv4_interface_value(form.get("NETWORK_GUARDIAN_AP_IPV4", [""])[0], "AP-IPv4", required=True)
    updates["NETWORK_GUARDIAN_AP_SSID_PREFIX"] = ssid_prefix
    updates["NETWORK_GUARDIAN_AP_IPV4"] = ap_ipv4

    clear_password = form.get("NETWORK_GUARDIAN_AP_PASSWORD_CLEAR", ["0"])[0] == "1"
    password = form.get("NETWORK_GUARDIAN_AP_PASSWORD", [""])[0].strip()
    if clear_password:
        updates["NETWORK_GUARDIAN_AP_PASSWORD"] = ""
    elif password:
        if len(password) < 8 or len(password) > NETWORK_GUARDIAN_TEXT_MAX_LENGTHS["NETWORK_GUARDIAN_AP_PASSWORD"]:
            raise ValueError("AP password must be 8 to 63 characters long")
        validate_config_literal(password, "NETWORK_GUARDIAN_AP_PASSWORD")
        updates["NETWORK_GUARDIAN_AP_PASSWORD"] = password
    elif not str(current_config.get("NETWORK_GUARDIAN_AP_PASSWORD", "")).strip():
        updates["NETWORK_GUARDIAN_AP_PASSWORD"] = ""

    return updates


def handle_wifi_post(handler, path, form):
    if not path.startswith("/wifi/"):
        return False

    if path == "/wifi/guardian-gate":
        enabled = bool_config_value(form.get("enabled", ["0"])[0])
        if enabled and int(network_guardian_config_values().get("NETWORK_GUARDIAN_ENABLED", 1) or 0) != 1:
            update_config_values(
                {"NETWORK_GUARDIAN_ENABLED": 1},
                section_label="Network Guardian",
                ordered_keys=[item[0] for item in NETWORK_GUARDIAN_CONFIG_FIELDS],
            )
        rc, out = set_network_guardian_gate(enabled)
        if rc == 0:
            msg = "Network Guardian armed" if enabled else "Network Guardian disarmed"
        else:
            action = "Arm" if enabled else "Disarm"
            msg = action + " failed rc=" + str(rc) + ": " + out[:180]
        handler.redirect("/wifi?refresh=1&msg=" + quote(msg))
        return True

    if path == "/wifi/guardian-save":
        updates = validate_network_guardian_config_form(form, network_guardian_config_values())
        update_config_values(
            updates,
            section_label="Network Guardian",
            ordered_keys=[item[0] for item in NETWORK_GUARDIAN_CONFIG_FIELDS],
        )
        handler.redirect("/wifi?msg=" + quote("Network Guardian saved; active on next run"))
        return True

    if path == "/wifi/connect":
        name = validate_wifi_text(form.get("name", [""])[0], "Wi-Fi profile", 120, allow_empty=True)
        if name:
            rc, out = run_nmcli(["connection", "up", name, "ifname", WIFI_DEFAULT_IFACE], 45)
            msg = "Wi-Fi profile connected" if rc == 0 else "Wi-Fi connection failed rc=" + str(rc) + ": " + out[:180]
        else:
            rc, out = run_nmcli(["device", "connect", WIFI_DEFAULT_IFACE], 45)
            msg = "Wi-Fi connection initiated" if rc == 0 else "Wi-Fi connection failed rc=" + str(rc) + ": " + out[:180]
        msg += clear_wifi_status_cache()
        handler.redirect("/wifi?refresh=1&msg=" + quote(msg))
        return True

    if path == "/wifi/powersave-off":
        name = validate_wifi_text(form.get("name", [""])[0], "Wi-Fi profile", 120)
        rc, out = run_nmcli(["connection", "modify", name, "802-11-wireless.powersave", "2"], 15)
        msg = "Powersave disabled for profile" if rc == 0 else "Powersave could not be changed rc=" + str(rc) + ": " + out[:180]
        msg += clear_wifi_status_cache()
        handler.redirect("/wifi?refresh=1&msg=" + quote(msg))
        return True

    if path == "/wifi/scan":
        scan = manual_wifi_scan()
        count = len(scan.get("items", []))
        if scan.get("rc") == 0:
            msg = "Wi-Fi scan completed: " + str(count) + " networks found"
        else:
            msg = "Wi-Fi scan failed rc=" + str(scan.get("rc")) + ": " + scan.get("error", "")[:180]
        handler.redirect("/wifi?scan=1&msg=" + quote(msg))
        return True

    if path == "/wifi/ip-save":
        name = validate_wifi_text(form.get("name", [""])[0], "Wi-Fi profile", 120)
        method = validate_wifi_ip_method(form.get("method", ["auto"])[0])
        if not wifi_connection_exists(name):
            raise ValueError("Wi-Fi profile not found")

        if method == "manual":
            address = validate_ipv4_interface_value(form.get("address", [""])[0], "IPv4-Adresse", required=True)
            gateway = validate_optional_ipv4_address(form.get("gateway", [""])[0], "Gateway")
            dns = normalize_ipv4_dns(form.get("dns", [""])[0])
        else:
            address = ""
            gateway = ""
            dns = ""

        rc, out = run_nmcli(
            [
                "connection",
                "modify",
                name,
                "ipv4.method",
                method,
                "ipv4.addresses",
                address,
                "ipv4.gateway",
                gateway,
                "ipv4.dns",
                dns,
                "ipv4.ignore-auto-dns",
                "no",
            ],
            20,
        )
        if rc != 0:
            raise ValueError("IP settings could not be saved: " + out[:240])

        msg = "IP settings saved; active on next connection" + clear_wifi_status_cache()
        handler.redirect("/wifi?refresh=1&msg=" + quote(msg))
        return True

    if path == "/wifi/save":
        name = validate_wifi_text(form.get("name", [""])[0], "Verbindungsname", 120)
        ssid = validate_wifi_text(form.get("ssid", [""])[0], "SSID", 64)
        psk = validate_wifi_text(form.get("psk", [""])[0], "Wi-Fi password", 128, allow_empty=True, strip_value=False)
        priority = validate_wifi_priority(form.get("priority", ["0"])[0])
        autoconnect = "yes" if form.get("autoconnect", ["0"])[0] == "1" else "no"

        exists = wifi_connection_exists(name)
        if not exists:
            if not psk:
                raise ValueError("Wi-Fi password missing for new profile")
            rc, out = run_nmcli(["connection", "add", "type", "wifi", "ifname", WIFI_DEFAULT_IFACE, "con-name", name, "ssid", ssid], 20)
            if rc != 0:
                raise ValueError("Wi-Fi profile could not be created: " + out[:240])

        rc, out = run_nmcli(
            [
                "connection",
                "modify",
                name,
                "802-11-wireless.ssid",
                ssid,
                "connection.autoconnect",
                autoconnect,
                "connection.autoconnect-priority",
                str(priority),
                "802-11-wireless.powersave",
                "2",
            ],
            20,
        )
        if rc != 0:
            raise ValueError("Wi-Fi profile could not be saved: " + out[:240])

        if psk:
            rc, out = run_nmcli(
                [
                    "connection",
                    "modify",
                    name,
                    "802-11-wireless-security.key-mgmt",
                    "wpa-psk",
                    "802-11-wireless-security.psk",
                    psk,
                ],
                20,
            )
            if rc != 0:
                raise ValueError("Wi-Fi password could not be saved: " + out[:240])

        msg = "Wi-Fi profile saved" + clear_wifi_status_cache()
        handler.redirect("/wifi?refresh=1&msg=" + quote(msg))
        return True

    return False


def validate_archive_number(form, name, min_value, max_value):
    raw = form.get(name, [""])[0].strip()
    try:
        value = int(raw)
    except Exception:
        raise ValueError("Invalid value for " + name)
    if value < min_value or value > max_value:
        raise ValueError(name + " must be between " + str(min_value) + " and " + str(max_value) + "")
    return value


def handle_archive_post(handler, path, form):
    if not path.startswith("/archive/"):
        return False

    if path == "/archive/save":
        existing = archive_config()
        target = form.get("target", [""])[0].strip()
        password_file = form.get("password_file", [""])[0].strip() or existing["password_file"]
        password = form.get("password", [""])[0]
        validate_plain(target, "archive_target")
        validate_plain(password_file, "archive_password_file")
        if not target:
            raise ValueError("Archive destination missing")
        if not password and not os.path.isfile(password_file):
            raise ValueError("Archive password missing")
        if password:
            write_archive_password(password_file, password)
        updates = {
            "ARCHIVE_RSYNC_TARGET": target,
            "ARCHIVE_RSYNC_PASSWORD_FILE": password_file,
            "ARCHIVE_RSYNC_MAX_SECONDS": validate_archive_number(form, "max_seconds", 30, 86400),
            "ARCHIVE_RSYNC_CONTIMEOUT": validate_archive_number(form, "contimeout", 1, 300),
            "ARCHIVE_RSYNC_TIMEOUT": validate_archive_number(form, "timeout", 1, 3600),
        }
        update_config_values(
            updates,
            section_label="Archive",
            ordered_keys=[item[0] for item in ARCHIVE_CONFIG_FIELDS],
        )
        handler.redirect("/archive?msg=" + quote("Archive settings saved"))
        return True

    if path == "/archive/enable":
        cfg = archive_config()
        pass_status = archive_password_status(cfg["password_file"])
        if not cfg["target"] or not pass_status["exists"] or not pass_status["readable"]:
            handler.redirect("/archive?msg=" + quote("Archive cannot be enabled: target or password missing"))
            return True
        set_archive_enabled(True)
        handler.redirect("/archive?msg=" + quote("Archive enabled"))
        return True

    if path == "/archive/disable":
        set_archive_enabled(False)
        handler.redirect("/archive?msg=" + quote("Archive disabled"))
        return True

    return False


def handle_boot_notify_post(handler, path, form):
    if path == "/boot-notify/save":
        env = parse_env()
        bot_var = form.get("bot_var", [""])[0].strip()
        chat_var = form.get("chat_var", [""])[0].strip()

        if not bot_var or not chat_var:
            raise ValueError("Please select bot variable and chat variable")
        if bot_var not in available_bot_vars():
            raise ValueError("Unbekannte Bot-Variable")
        if chat_var not in available_chat_vars():
            raise ValueError("Unbekannte Chat-Variable")

        env[BOOT_NOTIFY_BOT_VAR] = bot_var
        env[BOOT_NOTIFY_CHAT_VAR] = chat_var

        write_env(env)
        handler.redirect(
            "/boot-notify?msg=" + quote("Boot notify configuration saved")
            + "&bot_var=" + quote(bot_var)
            + "&chat_var=" + quote(chat_var)
        )
        return True

    if path == "/boot-notify/enable":
        if not boot_notify_info()["ready"]:
            handler.redirect("/boot-notify?msg=" + quote("Boot notify cannot be enabled yet: configuration incomplete"))
            return True
        boot_notify_set_enabled(True)
        handler.redirect("/boot-notify?msg=" + quote("Boot notify enabled"))
        return True

    if path == "/boot-notify/disable":
        boot_notify_set_enabled(False)
        handler.redirect("/boot-notify?msg=" + quote("Boot notify disabled"))
        return True

    if path == "/boot-notify/test":
        notify = boot_notify_info()
        if not notify["ready"]:
            handler.redirect("/boot-notify?msg=" + quote("Boot notify configuration missing"))
            return True
        if not notify["enabled"]:
            handler.redirect("/boot-notify?msg=" + quote("Boot notify is disabled"))
            return True

        rc, out = run_maint_cmd("/usr/local/sbin/vdisk-relay boot-notify --send", 40)
        if rc == 0:
            handler.redirect("/boot-notify?msg=" + quote("Boot notify Test sent"))
            return True

        handler.redirect("/boot-notify?msg=" + quote("Boot notify test failed: " + out[:180]))
        return True

    return False


def handle_maintenance_notify_post(handler, path, form):
    if not path.startswith("/maintenance-notify/"):
        return False

    if path == "/maintenance-notify/save":
        bot_var = form.get("bot_var", [""])[0].strip()
        chat_var = form.get("chat_var", [""])[0].strip()

        if not bot_var or not chat_var:
            raise ValueError("Please select bot variable and chat variable")
        if bot_var not in available_bot_vars():
            raise ValueError("Unbekannte Bot-Variable")
        if chat_var not in available_chat_vars():
            raise ValueError("Unbekannte Chat-Variable")

        config = maintenance_notify_config()
        config["bot_var"] = bot_var
        config["chat_var"] = chat_var
        write_maintenance_notify_config(config)
        maintenance_notify_reset_check_clock()
        handler.redirect("/telegram/maintenance?msg=" + quote("Maintenance Telegram target saved"))
        return True

    if path == "/maintenance-notify/enable":
        if not maintenance_notify_info()["ready"]:
            handler.redirect("/telegram/maintenance?msg=" + quote("Maintenance Telegram cannot be enabled yet: configuration incomplete"))
            return True
        maintenance_notify_set_enabled(True)
        maintenance_notify_reset_check_clock()
        handler.redirect("/telegram/maintenance?msg=" + quote("Maintenance Telegram enabled"))
        return True

    if path == "/maintenance-notify/disable":
        maintenance_notify_set_enabled(False)
        maintenance_notify_reset_check_clock()
        handler.redirect("/telegram/maintenance?msg=" + quote("Maintenance Telegram disabled"))
        return True

    if path == "/maintenance-notify/toggle-factor":
        factor = form.get("factor", [""])[0].strip()
        kind = form.get("kind", [""])[0].strip()
        enabled = form.get("enabled", ["0"])[0].strip() == "1"

        if factor not in MAINTENANCE_NOTIFY_FACTOR_IDS:
            raise ValueError("Unknown maintenance factor")
        if kind not in ("alert", "clear"):
            raise ValueError("Unknown Telegram switch")

        config = maintenance_notify_config()
        item = dict(config["factors"].get(factor, {"alert": False, "clear": False}))
        if kind == "alert":
            item["alert"] = enabled
            if not enabled:
                item["clear"] = False
        else:
            if enabled and not item.get("alert"):
                raise ValueError("All-clear message requires an active fault alert")
            item["clear"] = enabled and bool(item.get("alert"))

        config["factors"][factor] = item
        write_maintenance_notify_config(config)
        maintenance_notify_reset_check_clock()
        handler.redirect("/telegram/maintenance?msg=" + quote("Telegram switch saved"))
        return True

    return False


def validate_preview_config_form(form):
    updates = {}
    for key, _label, _default, min_value, max_value, _help_text in PREVIEW_CONFIG_FIELDS:
        raw = form.get(key, [""])[0].strip()
        try:
            value = int(raw)
        except Exception:
            raise ValueError("Invalid value for " + key)
        if value < min_value or value > max_value:
            raise ValueError(key + " must be between " + str(min_value) + " and " + str(max_value) + "")
        updates[key] = value
    if updates["PREVIEW_LONG_FFMPEG_TIMEOUT"] < updates["PREVIEW_FFMPEG_TIMEOUT"]:
        raise ValueError("Long timeout must not be smaller than normal timeout")
    return updates


def delete_preview_for_rel(rel):
    rel = normalize_file_rel(rel)
    path = preview_path_for_rel(rel)
    removed = False
    for candidate in (path, path[:-4] + ".tmp.jpg"):
        try:
            os.unlink(candidate)
            removed = True
        except FileNotFoundError:
            pass
    index = load_preview_index()
    if rel in index:
        del index[rel]
        write_json_file_atomic(PREVIEW_INDEX, index)
        removed = True
    return rel, removed


def release_preview_backlog(rel):
    rel = normalize_file_rel(rel)
    backlog = load_preview_backlog()
    if rel in backlog:
        del backlog[rel]
        write_json_file_atomic(PREVIEW_BACKLOG, backlog)
        return rel, True
    return rel, False


def handle_preview_post(handler, path, form):
    if not path.startswith("/previews/"):
        return False

    if path == "/previews/config":
        updates = validate_preview_config_form(form)
        update_config_values(
            updates,
            section_label="Preview cache",
            ordered_keys=[item[0] for item in PREVIEW_CONFIG_FIELDS],
        )
        handler.redirect("/previews?msg=" + quote(t("msg.preview_options_saved")))
        return True

    if path == "/previews/run":
        rc, out = systemctl_quick(["start", "--no-block", PREVIEW_SERVICE_UNIT], 8)
        msg = t("msg.preview_run_started") if rc == 0 else t("msg.preview_run_failed") + " rc=" + str(rc) + ": " + out[:160]
        handler.redirect("/previews?msg=" + quote(msg))
        return True

    if path == "/previews/enable":
        rc, out = systemctl_quick(["enable", "--now", PREVIEW_TIMER_UNIT], 20)
        msg = t("msg.preview_timer_enabled") if rc == 0 else t("msg.preview_timer_enable_failed") + " rc=" + str(rc) + ": " + out[:160]
        handler.redirect("/previews?msg=" + quote(msg))
        return True

    if path == "/previews/disable":
        rc, out = systemctl_quick(["disable", "--now", PREVIEW_TIMER_UNIT], 20)
        msg = t("msg.preview_timer_disabled") if rc == 0 else t("msg.preview_timer_disable_failed") + " rc=" + str(rc) + ": " + out[:160]
        handler.redirect("/previews?msg=" + quote(msg))
        return True

    if path == "/previews/delete-preview":
        rel, removed = delete_preview_for_rel(form.get("rel", [""])[0])
        msg = (t("msg.preview_deleted") + ": " if removed else t("msg.preview_not_found") + ": ") + rel
        handler.redirect("/previews?msg=" + quote(msg))
        return True

    if path == "/previews/release":
        rel, removed = release_preview_backlog(form.get("rel", [""])[0])
        msg = ("File released again: " if removed else "No backlog entry found: ") + rel
        handler.redirect("/previews?msg=" + quote(msg))
        return True

    return False


def render_services_page(query=None):
    query = query or {}
    focus_unit = query.get("focus", [""])[0].strip()
    if focus_unit and focus_unit not in ALLOWED_SERVICE_UNITS:
        focus_unit = ""
    status_data = load_status_json()
    pending = service_action_pending(status_data)
    generated, sections_html = render_services_sections(status_data, focus_unit=focus_unit)

    services_refresh_script = """
<script>
(function(){
  function setLoading(btn, busy) {
    if (!btn) {
      return;
    }
    btn.disabled = busy;
  }

  function refreshServices(btn) {
    var wrapper = document.getElementById('services-groups');
    var cacheBadge = document.getElementById('services-cache');
    if (!wrapper) {
      return;
    }
    setLoading(btn, true);
    fetch('/services-status.json?_=' + Date.now(), {
      cache: 'no-store'
    })
      .then(function(response){
        return response.text().then(function(rawText){
          if (!response.ok) {
            throw new Error(rawText || ('HTTP ' + response.status));
          }
          return rawText;
        });
      })
      .then(function(rawText){
        var payload = JSON.parse(rawText);
        if (!payload || payload.sections_html === undefined) {
          throw new Error(text('js.empty_service_type_response', 'Empty service-type response'));
        }
        wrapper.innerHTML = payload.sections_html;
        if (cacheBadge) {
          cacheBadge.textContent = payload.pending ? text('phrase.service_status_pending', 'Status refresh pending') : ('Cache ' + (payload.generated_at || 'unknown'));
          cacheBadge.className = 'badge ' + (payload.pending ? 'pending' : 'warn');
        }
      })
      .catch(function(err){
        wrapper.dataset.error = String(err.message || err);
      })
      .finally(function(){
        setLoading(btn, false);
      });
  }

  document.addEventListener('click', function(event){
    var btn = event.target.closest('#services-refresh');
    if (!btn) {
      return;
    }
    event.preventDefault();
    refreshServices(btn);
  });
})();
</script>
"""

    message = query.get("msg", [""])[0]
    pending_html = ""
    if pending:
        pending_html = (
            '<p class="msg">'
            + esc(t("phrase.service_action_pending", unit=str(pending.get("unit") or ""), action=str(pending.get("action") or "")))
            + '</p>'
        )
    cache_badge_cls = "pending" if pending else "warn"
    cache_badge_text = t("phrase.service_status_pending") if pending else (generated or "unknown")
    body = (
        settings_context("System")
        + settings_tabs("system")
        + maintenance_tabs("services")
        + msg_html(message)
        + pending_html
        + ('<p class="msg">' + esc(t("overview.focus_unit", unit=focus_unit)) + '</p>' if focus_unit else "")
        + '<section class="panel">'
        + '<h2>Status data</h2>'
        + '<p class="muted">Datenquelle: <code>' + esc(STATUS_JSON) + '</code></p>'
        + '<p>Service-Cache: <span class="badge ' + cache_badge_cls + '" id="services-cache">' + esc(cache_badge_text) + '</span></p>'
        + '<button class="button secondary" type="button" id="services-refresh" title="Reload services" aria-label="Reload services">'
        + 'Reload services</button>'
        + '</section>'
        + '<div id="services-groups">' + sections_html + '</div>'
        + services_refresh_script
    )
    return html_page("Services", body, active="settings", subtitle="State, enable state and journal for the vdisk-relay units.")



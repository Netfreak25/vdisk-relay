    cls, detail = overview_tile_status(tile, status_data, txt)
    items = overview_tile_items(tile, status_data, txt)
    generated = status_data.get("generated_at") or t("phrase.unknown")
    log_excerpt = status_detail_log_excerpt(tile, status_data)
    actions = []
    for label_key, href in tile.get("actions", ()):
        actions.append('<a class="button secondary" href="' + esc(href) + '">' + esc(t(label_key)) + '</a>')
    title = t(tile["title_key"])
    source_label = status_meta.get("source") or "cache"
    if status_meta.get("stale"):
        source_label += " / stale"
    body = (
        '<div class="section-context"><a href="/">' + esc(t("phrase.overview")) + '</a><span aria-hidden="true">/</span><span>' + esc(title) + '</span></div>'
        + '<section class="hero-status">'

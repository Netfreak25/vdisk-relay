def render_maintenance_notify_panel(notify):
    bot_vars = available_bot_vars()
    chat_vars = available_chat_vars()
    status_badge = (
        '<span class="badge ok">active</span>' if notify["enabled"] else '<span class="badge off">inactive</span>'
    )
    ready_badge = (
        '<span class="badge ok">ready</span>' if notify["ready"] else '<span class="badge warn">incomplete</span>'
    )
    state = notify.get("state", {})
    if not isinstance(state, dict):
        state = {}
    last_send = state.get("last_send", "-")
    last_error = state.get("last_error", "")
    interval_label = fmt_age(state.get("interval_seconds", 1800))

    return (
        '<section class="panel">'
        '<div class="panel-head-inline"><h2>Telegram-Messageen</h2><div class="status-pills">'
        + status_badge
        + ready_badge

ID_RE = re.compile(r"^[A-Za-z0-9_-]{1,40}$")
ENV_ID_RE = re.compile(r"^[A-Za-z0-9_]{1,40}$")


def esc(value):
    return html.escape("" if value is None else str(value), quote=True)


I18N_PHRASE_KEYS = ()


def normalize_language(lang):
    lang = (lang or "").strip().lower().split("-", 1)[0]
    return lang if lang in SUPPORTED_LANGUAGES else DEFAULT_LANGUAGE


def i18n_file_for(lang):
    filename = normalize_language(lang) + ".json"
    for directory in (I18N_DIR, I18N_REPO_DIR):
        path = os.path.join(directory, filename)
        if os.path.isfile(path):
            return path
    return ""


def load_i18n_file(lang):
    lang = normalize_language(lang)
    path = i18n_file_for(lang)
    if not path:
        return {}
    try:
        mtime = os.path.getmtime(path)
    except Exception:
        return {}
    cache = I18N_CACHE.get(lang)
    if cache and cache.get("path") == path and cache.get("mtime") == mtime:
        return dict(cache.get("data", {}))
    try:
        with open(path, "r", encoding="utf-8") as handle:
            data = json.load(handle)
    except Exception:
        data = {}
    if not isinstance(data, dict):
        data = {}
    I18N_CACHE[lang] = {"path": path, "mtime": mtime, "data": dict(data)}
    return dict(data)


def i18n_file_marker(lang):
    lang = normalize_language(lang)
    path = i18n_file_for(lang)
    if not path:
        return (lang, "", 0, 0)
    try:
        stat = os.stat(path)
        return (lang, path, stat.st_mtime, stat.st_size)
    except Exception:
        return (lang, path, 0, 0)


def language_catalog(lang=None):
    lang = normalize_language(lang or current_language())
    base = load_i18n_file(DEFAULT_LANGUAGE)
    if lang == DEFAULT_LANGUAGE:
        return base
    data = dict(base)
    data.update(load_i18n_file(lang))
    return data


def current_language():
    return normalize_language(getattr(REQUEST_CONTEXT, "language", DEFAULT_LANGUAGE))


def current_request_path():
    path = getattr(REQUEST_CONTEXT, "path", "/") or "/"
    if not path.startswith("/") or path.startswith("//"):
        return "/"
    return path


def set_request_context(language=None, path="/"):
    REQUEST_CONTEXT.language = normalize_language(language)
    REQUEST_CONTEXT.path = path if path and path.startswith("/") and not path.startswith("//") else "/"


def language_from_cookie(cookie_header):
    try:
        cookie = SimpleCookie()
        cookie.load(cookie_header or "")
        if LANGUAGE_COOKIE in cookie:
            return normalize_language(cookie[LANGUAGE_COOKIE].value)
    except Exception:
        pass
    return DEFAULT_LANGUAGE


def language_cookie_header(lang):
    lang = normalize_language(lang)
    return (
        LANGUAGE_COOKIE
        + "="
        + lang
        + "; Path=/; Max-Age="
        + str(LANGUAGE_COOKIE_MAX_AGE)
        + "; SameSite=Lax"
    )


def t(key, **params):
    value = language_catalog().get(key)
    if value is None:
        value = load_i18n_file(DEFAULT_LANGUAGE).get(key, key)
    if params:
        try:
            return str(value).format(**params)
        except Exception:
            return str(value)
    return str(value)


def localize_plain_text(value, lang=None):
    lang = normalize_language(lang or current_language())
    return replace_localized_phrases(str(value), lang=lang, html=False)


def i18n_phrase_replacements(lang=None):
    lang = normalize_language(lang or current_language())
    target = language_catalog(lang)
    default = load_i18n_file(DEFAULT_LANGUAGE)
    german = load_i18n_file("de")
    signature = (i18n_file_marker(lang), i18n_file_marker(DEFAULT_LANGUAGE), i18n_file_marker("de"))
    cached = I18N_REPLACEMENT_CACHE.get(lang)
    if cached and cached.get("signature") == signature:
        return list(cached.get("items", []))

    seen = set()
    items = []

    def add(source, translated):
        source = str(source or "")
        translated = str(translated or "")
        if not source or source == translated:
            return
        marker = (source, translated)
        if marker in seen:
            return
        seen.add(marker)
        items.append((source, translated))

    for key, source in default.items():
        if isinstance(source, str):
            add(source, target.get(key, source))

    if lang != "de":
        for key, source in german.items():
            if isinstance(source, str):
                add(source, target.get(key, source))

    for source, key in I18N_PHRASE_KEYS:
        add(source, target.get(key, source))

    items.sort(key=lambda item: len(item[0]), reverse=True)
    I18N_REPLACEMENT_CACHE[lang] = {"signature": signature, "items": list(items)}
    return items


def i18n_replacement_signature(lang, html=False):
    lang = normalize_language(lang)
    return (
        i18n_file_marker(lang),
        i18n_file_marker(DEFAULT_LANGUAGE),
        i18n_file_marker("de"),
        bool(html),
    )


def i18n_replacement_items(lang=None, html=False):
    lang = normalize_language(lang or current_language())
    signature = i18n_replacement_signature(lang, html=html)
    cache_key = (lang, bool(html))
    cached = I18N_REPLACEMENT_ITEM_CACHE.get(cache_key)
    if cached and cached.get("signature") == signature:
        return list(cached.get("items", []))

    mapping = {}

    def add(source, translated):
        source = str(source or "")
        translated = str(translated or "")
        if not source or source == translated or source in mapping:
            return
        mapping[source] = translated

    for source, translated in i18n_phrase_replacements(lang):
        add(source, translated)
        if html:
            escaped_source = esc(source)
            if escaped_source != source:
                add(escaped_source, esc(translated))

    items = []
    for source in sorted(mapping, key=len, reverse=True):
        compiled = None
        if source[0].isalnum() or source[-1].isalnum():
            compiled = re.compile(r"(?<!\w)" + re.escape(source) + r"(?!\w)")
        items.append((source, mapping[source], compiled))

    I18N_REPLACEMENT_ITEM_CACHE[cache_key] = {
        "signature": signature,
        "items": list(items),
    }
    return list(items)


def replace_localized_phrases(text, lang=None, html=False):
    items = i18n_replacement_items(lang=lang, html=html)
    if not items or not text:
        return text

    replacements = []

    def marker(translated):
        token_id = "".join(chr(0xE000 + int(char)) for char in str(len(replacements)))
        token = "\0" + token_id + "\0"
        replacements.append((token, translated))
        return token

    for source, translated, compiled in items:
        if source not in text:
            continue
        if compiled:
            text = compiled.sub(lambda _match, value=translated: marker(value), text)
        else:
            token = marker(translated)
            text = text.replace(source, token)

    for token, translated in replacements:
        text = text.replace(token, translated)

    return text


def localize_html_fragment(fragment, lang=None):
    lang = normalize_language(lang or current_language())
    return replace_localized_phrases(fragment, lang=lang, html=True)


def localize_html_document(document, lang=None):
    lang = normalize_language(lang or current_language())
    if lang == DEFAULT_LANGUAGE:
        return document
    parts = I18N_HTML_SKIP_RE.split(document)
    for idx in range(0, len(parts), 2):
        parts[idx] = localize_html_fragment(parts[idx], lang)
    return "".join(parts)



            "ok": True,
            "current_url": videos_page_url(page, per, search, source, day, selected_rel),
            "workspace_html": workspace,
        }

    body = video_page_css() + workspace

    return html_page("Data", body, active="data", subtitle="Media workspace with server-side pagination.")


def send_file(handler, rel, download=False):
    full, rel = safe_video_path(rel)
    size = os.path.getsize(full)
    mime = mimetypes.guess_type(full)[0] or "video/mp4"
    range_header = handler.headers.get("Range", "")

    start = 0
    end = size - 1
    status = 200

    if range_header.startswith("bytes="):
        spec = range_header.split("=", 1)[1].split(",", 1)[0].strip()
        if "-" in spec:
            a, b = spec.split("-", 1)
            if a:
                start = int(a)
            if b:
                end = int(b)
            status = 206

    if start < 0:
        start = 0
    if end >= size:
        end = size - 1

    if start > end:
        handler.send_response(416)
        handler.send_header("Content-Range", "bytes */{}".format(size))
        handler.end_headers()
        return

    length = end - start + 1
    disposition = "attachment" if download else "inline"
    filename = os.path.basename(full).replace('"', "")

    handler.send_response(status)
    handler.send_header("Content-Type", mime)
    handler.send_header("Accept-Ranges", "bytes")
    handler.send_header("Content-Length", str(length))
    handler.send_header("Content-Disposition", disposition + '; filename="' + filename + '"')

    if status == 206:
        handler.send_header("Content-Range", "bytes {}-{}/{}".format(start, end, size))

    handler.end_headers()

    with open(full, "rb") as f:
        f.seek(start)
        remaining = length
        while remaining > 0:
            chunk = f.read(min(256 * 1024, remaining))
            if not chunk:
                break
            try:
                handler.wfile.write(chunk)
            except BrokenPipeError:
                break
            remaining -= len(chunk)


def status_step_class(txt, component_names, keywords=()):
    components = status_components(txt)
    found = False
    for name in component_names:
        item = components.get(name)
        if not item:
            continue
        item_cls = status_class_from_state(item.get("state"))
        if item_cls == "bad":
            return "bad", "suspicious"
        if item_cls == "warn":
            return "warn", item.get("message") or "watch"
        if item_cls == "off":
            return "off", item.get("message") or "disabled"
        found = True
    if found:
        return "ok", "ok"

    lines = txt.splitlines()
    matched = []
    for line in lines:
        lower = line.lower()
        if any(k in lower for k in keywords):
            matched.append(lower)

    if not matched:
        return "warn", "no cache line"

    joined = "\n".join(matched)
    if any(word in joined for word in ["fail", "failed", "kritisch", "critical", "error", "stale"]):
        return "bad", "suspicious"
    if any(word in joined for word in ["ok", "active", "success", "enabled"]):
        return "ok", "ok"
    return "warn", "beobachten"


def render_system_flow(txt, status_data=None):
    html_steps = []
    for tile in OVERVIEW_TILES:
        cls, detail = overview_tile_status(tile, status_data, txt)
        title = t(tile["title_key"])
        label = t(tile["subtitle_key"])
        html_steps.append(
            '<a class="flow-step ' + cls + '" href="' + esc(tile["href"]) + '" aria-label="' + esc(t("overview.open_details", title=title)) + '">'
            '<b>' + esc(title) + '</b>'
            '<span>' + esc(label + " - " + detail) + '</span>'
            '<i aria-hidden="true">›</i>'
            '</a>'
        )
    return '<div class="flow">' + ''.join(html_steps) + '</div>'


def render_main_page(message=""):
    txt, status_meta = status_text_cache_only()
    status_data = load_status_json()
    overall, cls = status_badge(txt, stale=status_meta.get("stale", False))

    if status_meta.get("source") == "live":
        overview_hint = "Live status read (cache stale or missing)."
    elif status_meta.get("source") == "missing":
        overview_hint = "Status cache missing; using fallback text."
    elif status_meta.get("stale"):
        age_seconds = status_meta.get("age_seconds")
        if age_seconds is None:
            overview_hint = "Status cache is stale and cannot be refreshed right now."
        else:
            overview_hint = "Status cache is stale (" + str(int(age_seconds)) + "s)."
    else:
        overview_hint = t("phrase.cached_overview_hint")

    body = f"""
{msg_html(message)}

<section class="hero-status has-signal">
  <div>
    <div class="status-title">{esc(t("phrase.overall_status"))}</div>
    <div class="status-value">{overall}</div>
    <p class="muted">{esc(overview_hint)}</p>
  </div>
  <div class="sync-signal" aria-hidden="true">
    <span class="sync-track"></span>
    <span class="sync-track"></span>
    <span class="sync-track"></span>
  </div>
  <div class="badge {cls}">{esc(t("phrase.overall_status"))} {overall}</div>
</section>

<div class="overview-flow">
{render_system_flow(txt, status_data)}
</div>
"""
    return html_page(t("phrase.overview"), body, active="overview", subtitle=t("phrase.overview_subtitle"))


def unit_row_id(unit):
    return "unit-" + re.sub(r"[^A-Za-z0-9_-]+", "-", unit).strip("-")


def cached_unit_values(unit, status_data=None):
    if not isinstance(status_data, dict):
        status_data = {}
    units = status_data.get("units", {})
    values = units.get(unit, {}) if isinstance(units, dict) else {}
    if not isinstance(values, dict):
        values = {}
    out = {
        "active": values.get("ActiveState") or values.get("active") or "unknown",
        "enabled": values.get("UnitFileState") or values.get("enabled_display") or values.get("enabled") or "unknown",
        "result": values.get("Result") or values.get("result") or "",
        "exec_status": values.get("ExecMainStatus") or values.get("exec_status") or "",
        "available": values.get("available", bool(values)),
    }
    pending = service_action_pending(status_data)
    if pending.get("unit") == unit:
        action = str(pending.get("action") or "action")
        age = pending.get("age_seconds", 0)
        out["active"] = "pending"
        out["result"] = "pending " + action
        out["exec_status"] = str(age) + "s"
        out["pending"] = True
    return out


def render_cached_unit_table(units, status_data=None):
    rows = []
    for unit in units:
        values = cached_unit_values(unit, status_data)
        active = values["active"]
        enabled = values["enabled"]
        result = values["result"]
        exec_status = values["exec_status"]
        rows.append(
            '<tr class="service-row" id="' + esc(unit_row_id(unit)) + '">'
            + '<th data-label="' + esc(t("phrase.unit")) + '">' + esc(unit) + '</th>'
            + '<td data-label="' + esc(t("phrase.active")) + '">' + service_state_badge(active, result, exec_status) + '</td>'
            + '<td data-label="' + esc(t("phrase.enabled")) + '">' + service_badge(enabled) + '</td>'
            + '<td data-label="' + esc(t("phrase.result")) + '">' + esc(result or "-") + '<br><small>ExecMainStatus: ' + esc(exec_status or "-") + '</small></td>'
            + '<td class="actions" data-label="' + esc(t("phrase.actions")) + '">'
            + '<a class="button secondary" href="/service-journal?u=' + quote(unit) + '">' + esc(t("phrase.journal")) + '</a>'
            + '<a class="button secondary" href="/services?focus=' + quote(unit) + '#' + esc(unit_row_id(unit)) + '">' + esc(t("overview.action.services")) + '</a>'
            + '</td>'
            + '</tr>'
        )
    if not rows:
        rows.append('<tr><td colspan="5">' + esc(t("overview.no_units")) + '</td></tr>')
    return (
        '<table class="responsive-table"><thead><tr>'
        '<th>' + esc(t("phrase.unit")) + '</th>'
        '<th>' + esc(t("phrase.active")) + '</th>'
        '<th>' + esc(t("phrase.enabled")) + '</th>'
        '<th>' + esc(t("phrase.result")) + '</th>'
        '<th>' + esc(t("phrase.actions")) + '</th>'
        '</tr></thead><tbody>' + ''.join(rows) + '</tbody></table>'
    )


def render_status_item_table(items):
    rows = []
    for item in items:
        state = str(item.get("state") or "-")
        cls = status_class_from_state(state)
        rows.append(
            '<tr>'
            '<th data-label="' + esc(t("phrase.component")) + '">' + esc(item.get("name") or item.get("id") or "-") + '</th>'
            '<td data-label="' + esc(t("phrase.state")) + '"><span class="badge ' + cls + '">' + esc(state) + '</span></td>'
            '<td data-label="' + esc(t("phrase.detail")) + '">' + esc(item.get("message") or "-") + '</td>'
            '<td data-label="' + esc(t("overview.kind")) + '">' + esc(t("overview.kind_" + str(item.get("kind") or "component"))) + '</td>'
            '</tr>'
        )
    if not rows:
        rows.append('<tr><td colspan="4">' + esc(t("overview.no_matching_components")) + '</td></tr>')
    return (
        '<table class="responsive-table"><thead><tr>'
        '<th>' + esc(t("phrase.component")) + '</th>'
        '<th>' + esc(t("phrase.state")) + '</th>'
        '<th>' + esc(t("phrase.detail")) + '</th>'
        '<th>' + esc(t("overview.kind")) + '</th>'
        '</tr></thead><tbody>' + ''.join(rows) + '</tbody></table>'
    )


def status_detail_log_excerpt(tile, status_data=None, limit=28):
    if not isinstance(status_data, dict):
        return ""
    text = str(status_data.get("log_tail") or "")
    if not text:
        logs = status_data.get("logs", {})
        if isinstance(logs, dict):
            text = str(logs.get("vdisk-relay.log") or "")
    terms = [str(term).lower() for term in tile.get("log_terms", ()) if str(term).strip()]
    if not text or not terms:
        return ""
    matched = []
    for line in text.splitlines():
        lower = line.lower()
        if any(term in lower for term in terms):
            matched.append(line)
    return "\n".join(matched[-limit:])



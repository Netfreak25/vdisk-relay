def handle_service_post(handler, path, form):
    if path not in ("/service/start", "/service/restart", "/service/enable", "/service/disable"):
        return False
    unit = validate_service_unit(form.get("unit", [""])[0].strip())
    if path == "/service/start":
        rc, out = run_systemctl_start(unit)
        action = "Start"
    elif path == "/service/restart":
        rc, out = run_systemctl_restart(unit)
        action = "Restart"
    elif path == "/service/enable":
        rc, out = run_systemctl_enable(unit)
        action = "Enable"
    else:
        rc, out = run_systemctl_disable(unit)
        action = "Disable"

    if rc == 0:
        write_service_action_pending(unit, action, out[:240])
        cache_rc, cache_out = trigger_status_cache_rebuild()
        msg = action + " executed: " + unit
        if cache_rc != 0:
            msg += "; status cache refresh could not be started: " + cache_out[:120]
    else:
        msg = action + " failed rc=" + str(rc) + ": " + unit + " " + out[:160]
    handler.redirect("/services?msg=" + quote(msg))
    return True


def handle_video_delete_post(handler, path, form):
    if path != "/data/delete":
        return False

    payload = queue_videos_delete_api(form)
    queued_count = payload.get("queued_count", 0)
    skipped = payload.get("skipped", [])
    skipped_count = len(skipped) if isinstance(skipped, (list, tuple)) else 0
    skipped_text = ""
    if skipped_count:
        skipped_text = " " + t("bulkActions.skipped_count", count=skipped_count)

    if queued_count:
        message = (
            t("bulkActions.queued_for_deletion")
            + " ("
            + str(queued_count)
            + ")"
        )
        if skipped_count:
            message += skipped_text
        payload["message"] = message
    else:
        if skipped_count:
            message = t("bulkActions.no_videos_queued") + skipped_text
        else:
            message = t("bulkActions.no_videos_queued")
        payload["message"] = message

    if handler.wants_json():
        payload["ok"] = bool(payload.get("ok") or payload.get("queued", []))
        handler.send_json(payload)
        return True

    redirect_message = t("bulkActions.no_videos_selected")
    if payload.get("queued_count", 0):
        redirect_message = (
            t("bulkActions.queued_for_deletion")
            + " ("
            + str(payload.get("queued_count", 0))
            + ")"
        )
    handler.redirect("/data?msg=" + quote(redirect_message))
    return True


def tail_file_text(path, max_bytes=131072):
    try:
        with open(path, "rb") as handle:
            handle.seek(0, os.SEEK_END)
            size = handle.tell()
            handle.seek(max(0, size - max_bytes))
            data = handle.read()
        return data.decode("utf-8", errors="replace")
    except Exception:
        return ""


def matching_log_lines(path, patterns, max_lines=80, max_bytes=131072):
    text = tail_file_text(path, max_bytes)
    if not text:
        return ""
    lowered = [p.lower() for p in patterns]
    lines = []
    for line in text.splitlines():
        lower = line.lower()
        if any(pattern in lower for pattern in lowered):
            lines.append(line)
    return "\n".join(lines[-max_lines:])



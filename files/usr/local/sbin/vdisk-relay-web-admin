def telegram_queue_time_label(value):
    if value in (None, "", "-"):
        return "-"
    if isinstance(value, (int, float)):
        return fmt_epoch_local(value) or str(value)
    text = str(value).strip()
    if re.match(r"^[0-9]+$", text):
        return fmt_epoch_local(text) or text
    return text


def telegram_queue_job_sort_value(job):
    for key in ("created_epoch", "created_at", "updated_at", "mtime"):
        value = job.get(key)
        if isinstance(value, (int, float)):
            return float(value)
        text = str(value or "").strip()
        if re.match(r"^[0-9]+$", text):
            return float(text)
    return float(job.get("_file_mtime", 0) or 0)


def telegram_queue_job_error(job):
    for key in ("last_error", "error", "message"):
        value = str(job.get(key, "") or "").strip()
        if value:
            return value
    return ""


def telegram_queue_info(limit=40):
    states = ("pending", "processing", "done", "failed")
    info = {
        "exists": os.path.isdir(TELEGRAM_QUEUE_DIR),
        "dir": TELEGRAM_QUEUE_DIR,
        "counts": {state: 0 for state in states},
        "corrupt": 0,
        "jobs": [],
        "oldest_pending": "-",
        "newest_pending": "-",
        "next_retry": "-",
        "last_error": "-",
    }
    if not info["exists"]:
        return info

    all_jobs = []
    pending_jobs = []
    error_jobs = []
    for state in states:
        state_dir = os.path.join(TELEGRAM_QUEUE_DIR, state)
        if not os.path.isdir(state_dir):
            continue
        try:
            entries = [entry for entry in os.scandir(state_dir) if entry.is_file()]
        except Exception:
            continue
        info["counts"][state] = len(entries)
        for entry in entries:
            payload = load_json_file(entry.path, {})
            if not isinstance(payload, dict) or not payload:
                payload = {"_corrupt": True}
                info["corrupt"] += 1
            payload["_state"] = state
            payload["_file"] = entry.path
            try:
                payload["_file_mtime"] = entry.stat().st_mtime
            except Exception:
                payload["_file_mtime"] = 0
            all_jobs.append(payload)
            if state == "pending":
                pending_jobs.append(payload)
            if telegram_queue_job_error(payload):
                error_jobs.append(payload)

    pending_jobs.sort(key=telegram_queue_job_sort_value)
    if pending_jobs:
        info["oldest_pending"] = telegram_queue_time_label(
            pending_jobs[0].get("created_at") or pending_jobs[0].get("created_epoch") or pending_jobs[0].get("_file_mtime")
        )
        info["newest_pending"] = telegram_queue_time_label(
            pending_jobs[-1].get("created_at") or pending_jobs[-1].get("created_epoch") or pending_jobs[-1].get("_file_mtime")
        )
        retry_values = []
        for job in pending_jobs:
            text = str(job.get("next_attempt_at") or job.get("next_attempt_epoch") or "").strip()
            if re.match(r"^[0-9]+$", text):
                retry_values.append(int(text))
        if retry_values:
            info["next_retry"] = telegram_queue_time_label(min(retry_values))

    error_jobs.sort(key=telegram_queue_job_sort_value, reverse=True)
    if error_jobs:
        info["last_error"] = telegram_queue_job_error(error_jobs[0]) or "-"

    all_jobs.sort(key=telegram_queue_job_sort_value, reverse=True)
    info["jobs"] = all_jobs[:limit]
    return info


def render_telegram_queue_summary(info=None):
    info = info or telegram_queue_info(limit=12)
    counts = info["counts"]
    state = "active" if info["exists"] else "not active yet"
    return (
        '<div class="grid-3">'
        '<div class="stat-card"><span>State</span><b>' + esc(state) + '</b></div>'
        '<div class="stat-card"><span>Pending</span><b>' + esc(counts.get("pending", 0)) + '</b></div>'
        '<div class="stat-card"><span>Processing</span><b>' + esc(counts.get("processing", 0)) + '</b></div>'
        '<div class="stat-card"><span>Done</span><b>' + esc(counts.get("done", 0)) + '</b></div>'
        '<div class="stat-card"><span>Failed</span><b>' + esc(counts.get("failed", 0)) + '</b></div>'
        '<div class="stat-card"><span>Defekt</span><b>' + esc(info.get("corrupt", 0)) + '</b></div>'
        '</div>'
    )


def render_telegram_queue_panel(info=None):
    info = info or telegram_queue_info()
    rows = []
    for job in info["jobs"]:
        source = job.get("source_id") or "-"
        path = job.get("path") or job.get("file") or job.get("basename") or os.path.basename(job.get("_file", ""))
        attempts = job.get("attempts", job.get("try_count", "-"))
        created = telegram_queue_time_label(job.get("created_at") or job.get("created_epoch") or job.get("_file_mtime"))
        next_try = telegram_queue_time_label(job.get("next_attempt_at") or job.get("next_attempt_epoch"))
        error = telegram_queue_job_error(job) or ("corrupt job file" if job.get("_corrupt") else "-")
        trace_id = str(job.get("trace_id") or "")
        trace_label = trace_id[-12:] if trace_id else "-"
        rows.append(
            "<tr>"
            '<th data-label="Source">' + esc(source) + "</th>"
            '<td data-label="File">' + esc(path) + "</td>"
            '<td data-label="State">' + esc(job.get("_state", "-")) + "</td>"
            '<td data-label="Attempts">' + esc(attempts) + "</td>"
            '<td data-label="Trace">' + esc(trace_label) + "</td>"
            '<td data-label="Created">' + esc(created) + "</td>"
            '<td data-label="Next attempt">' + esc(next_try) + "</td>"
            '<td data-label="Error">' + esc(error) + "</td>"
            "</tr>"
        )
    if not rows:
        rows.append('<tr><td colspan="8">No queue jobs available.</td></tr>')

    return (
        '<section class="panel">'
        '<div class="panel-head-inline"><h2>Telegram queue</h2><span class="badge ' + ("ok" if info["exists"] else "warn") + '">' + esc("active" if info["exists"] else "not active yet") + '</span></div>'
        + render_telegram_queue_summary(info)
        + render_kv_table([
            ("Queue directory", info["dir"]),
            ("Oldest pending job", info["oldest_pending"]),
            ("Newest pending job", info["newest_pending"]),
            ("Next retry", info["next_retry"]),
            ("Last error", info["last_error"]),
        ])
        + '<table class="responsive-table"><thead><tr><th>Source</th><th>File</th><th>State</th><th>Attempts</th><th>Trace</th><th>Created</th><th>Next attempt</th><th>Error</th></tr></thead><tbody>'
        + ''.join(rows)
        + '</tbody></table>'
        + '</section>'
    )


def telegram_readiness():
    env = parse_env()
    sources = parse_sources()
    active = [source for source in sources if source.get("enabled") == "1"]
    ready = 0
    for source in active:
        if env.get(source.get("bot_var", "")) and env.get(source.get("chat_var", "")):
            ready += 1
    return ready, len(active)



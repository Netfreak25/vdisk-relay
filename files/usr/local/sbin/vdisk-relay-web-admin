"""
    backup_file(CONFIG, "vdisk-relay.conf")
    write_atomic(CONFIG, config, 0o644)

    env = parse_env()
    env[bot_var] = bot_token
    env[chat_var] = chat_id
    env[chat_type_var_from_chat_var(chat_var)] = chat_type_from_id(chat_id)
    write_env(env)

    os.makedirs(os.path.dirname(rsync_pass_file), mode=0o700, exist_ok=True)
    write_atomic(rsync_pass_file, rsync_pass + "\n", 0o600)

    try:
        os.unlink(SETUP_PAUSE_MARKER)
    except FileNotFoundError:
        pass


def env_base_from_var(var, suffix):
    if var.endswith(suffix):
        return var[:-len(suffix)]
    return var


def env_var_from_base(base, suffix):
    base = base.strip().upper().replace("-", "_")

    if base.endswith(suffix):
        return base

    if not ENV_ID_RE.match(base):
        raise ValueError("Invalid ID for environment variable")

    return base + suffix


def mask_token(value):
    if not value:
        return "empty"

    if len(value) <= 12:
        return "set"

    return value[:6] + "..." + value[-4:] + f" ({len(value)} Zeichen)"


def validate_plain(value, name):
    if "|" in value or "\n" in value or "\r" in value or '"' in value:
        raise ValueError(f"Invalid character in {name}")
    return value


def source_send_state_file(source_id):
    safe_id = re.sub(r"[^A-Za-z0-9_-]", "_", str(source_id or "unknown"))
    if not safe_id:
        safe_id = "unknown"
    return os.path.join(SEND_STATE_DIR, safe_id + ".send-state")


def available_bot_vars():
    env = parse_env()
    sources = parse_sources()

    vals = set(DEFAULT_BOT_VARS)
    vals.update(k for k in env if k.endswith("_BOT_TOKEN"))
    vals.update(c["bot_var"] for c in sources if c.get("bot_var"))

    return sorted(vals)


def available_chat_vars():
    env = parse_env()
    sources = parse_sources()

    vals = set(DEFAULT_CHAT_VARS)
    vals.update(k for k in env if k.endswith("_CHAT_ID"))
    vals.update(c["chat_var"] for c in sources if c.get("chat_var"))

    return sorted(vals)


def used_bot_vars():
    return set(c["bot_var"] for c in parse_sources() if c.get("bot_var"))


def used_chat_vars():
    return set(c["chat_var"] for c in parse_sources() if c.get("chat_var"))


def make_source(form):
    defaults = get_defaults()

    source_id = form.get("id", [""])[0].strip()
    enabled = form.get("enabled", ["0"])[0].strip()
    profile = form.get("profile", ["generic-media-drop"])[0].strip() or "generic-media-drop"
    label = form.get("label", [source_id])[0].strip() or source_id
    pattern = form.get("pattern", [""])[0].strip()
    extensions = form.get("extensions", ["*"])[0].strip() or "*"
    telegram_mode = form.get("telegram_mode", ["auto"])[0].strip() or "auto"
    time_mode = form.get("time_mode", ["mtime"])[0].strip() or "mtime"
    source_timezone = form.get("source_timezone", ["UTC"])[0].strip() or "UTC"
    display_timezone = form.get("display_timezone", ["Europe/Berlin"])[0].strip() or "Europe/Berlin"
    last_file = form.get("last_file", [""])[0].strip()
    bot_var = form.get("bot_var", [""])[0].strip()
    chat_var = form.get("chat_var", [""])[0].strip()
    retries = form.get("retries", [defaults["retries"]])[0].strip() or defaults["retries"]
    wait = form.get("wait", [defaults["wait"]])[0].strip() or defaults["wait"]
    tmp_log = form.get("tmp_log", [""])[0].strip()

    if not ID_RE.match(source_id):
        raise ValueError("Invalid source ID")

    if enabled not in ("0", "1"):
        raise ValueError("enabled must be 0 or 1")

    if not pattern:
        raise ValueError("Pattern missing")

    if telegram_mode not in ("auto", "video", "photo", "audio", "document"):
        raise ValueError("Ungueltiger Telegram-Modus")

    validate_plain(pattern, "pattern")
    validate_plain(profile, "profile")
    validate_plain(label, "label")
    validate_plain(extensions, "extensions")
    validate_plain(telegram_mode, "telegram_mode")
    validate_plain(time_mode, "time_mode")
    validate_plain(source_timezone, "source_timezone")
    validate_plain(display_timezone, "display_timezone")
    validate_plain(last_file, "last_file")
    validate_plain(bot_var, "bot_var")
    validate_plain(chat_var, "chat_var")
    validate_plain(tmp_log, "tmp_log")

    if bot_var not in available_bot_vars():
        raise ValueError("Unknown bot")

    if chat_var not in available_chat_vars():
        raise ValueError("Unknown chat")

    if not last_file:
        last_file = os.path.join(defaults["last_dir"], f"{source_id}.last")
    if not tmp_log:
        tmp_log = os.path.join(defaults["tmp_dir"], f"{source_id}.telegram.log")

    return {
        "id": source_id,
        "enabled": enabled,
        "profile": profile,
        "label": label,
        "pattern": pattern,
        "extensions": extensions,
        "telegram_mode": telegram_mode,
        "time_mode": time_mode,
        "source_timezone": source_timezone,
        "display_timezone": display_timezone,
        "last_file": last_file,
        "bot_var": bot_var,
        "chat_var": chat_var,
        "retries": retries,
        "wait": wait,
        "tmp_log": tmp_log,
    }


def status_text_from_status_data(data):
    if not isinstance(data, dict):
        return ""
    components = data.get("status_components", [])
    if not isinstance(components, list):
        return ""
    overall = data.get("overall", {})
    if isinstance(overall, dict):
        try:
            exitcode = int(overall.get("exitcode", 1))
        except Exception:
            exitcode = 1
    else:
        state = str(overall or data.get("overall_state") or "FAIL").upper()
        exitcode = 0 if state == "OK" else 2
    lines = ["=== vdisk-relay status ==="]
    for component in components:
        if not isinstance(component, dict):
            continue
        state = str(component.get("state") or "FAIL").upper()
        prefix = "OK    " if state == "OK" else "FAIL  "
        name = str(component.get("name") or "Unknown")
        message = str(component.get("message") or "-")
        lines.append(prefix + f"{name:<22} " + message)
    lines.append("exitcode=" + str(exitcode))
    lines.append("updated=" + str(data.get("generated_at") or ""))
    return "\n".join(lines) + "\n"


def status_text_cache_only():
    txt = read_file(STATUS_CACHE)
    age_seconds = status_text_age_seconds(txt)
    if txt:
        return txt, {
            "source": "cache",
            "age_seconds": age_seconds,
            "stale": age_seconds is None or age_seconds > STATUS_CACHE_MAX_AGE_SECONDS,
        }
    json_txt = status_text_from_status_data(load_status_json())
    if json_txt:
        json_age_seconds = status_text_age_seconds(json_txt)
        return json_txt, {
            "source": "cache-json",
            "age_seconds": json_age_seconds,
            "stale": json_age_seconds is None or json_age_seconds > STATUS_CACHE_MAX_AGE_SECONDS,
        }
    return "State cache missing. Check timer/cache service.", {"source": "missing", "age_seconds": None, "stale": True}


def status_text_with_meta():
    return status_text_cache_only()


def parse_status_exit_code(txt):
    if not txt:
        return None
    match = re.search(r"^exitcode=\s*(-?\d+)\s*$", txt, re.M)
    if not match:
        return None
    try:
        return int(match.group(1))
    except Exception:
        return None


def status_text_age_seconds(txt):
    if not txt:
        return None
    match = re.search(r"^updated=(.+)$", txt, re.M)
    if not match:
        return None
    raw = match.group(1).strip()
    if not raw:
        return None
    try:
        updated_at = datetime.fromisoformat(raw)
    except Exception:
        try:
            updated_at = datetime.strptime(raw, "%Y-%m-%d %H:%M:%S%z")
        except Exception:
            try:
                updated_at = datetime.strptime(raw, "%Y-%m-%d %H:%M:%S")
                updated_at = updated_at.replace(tzinfo=timezone.utc)
            except Exception:
                return None
    if updated_at.tzinfo is None:
        updated_at = updated_at.replace(tzinfo=timezone.utc)
    now = datetime.now(timezone.utc)
    return max(0.0, (now - updated_at.astimezone(timezone.utc)).total_seconds())


def status_badge(txt, stale=False):
    overall_state = ""
    components = status_components(txt)
    if "Overall" in components:
        overall_state = str(components["Overall"].get("state") or "").upper()
    if overall_state == "FAIL":
        return "FAIL", "bad"
    if overall_state in ("WARN", "PENDING", "UNKNOWN"):
        return overall_state, "warn"
    if overall_state == "DISABLED":
        return "DISABLED", "off"
    if overall_state == "OK" and not stale:
        return "OK", "ok"

    exit_code = parse_status_exit_code(txt)
    if exit_code not in (None, 0):
        return "FAIL", "bad"
    if "\nFAIL" in "\n" + txt:
        return "FAIL", "bad"
    if stale:
        return "STALE", "warn"
    if not txt:
        return "UNKNOWN", "warn"

    return "OK", "ok"


def status_components(txt):
    components = {}
    for line in txt.splitlines():
        clean = re.sub(r"\x1b\[[0-9;]*m", "", line).strip()
        match = re.match(r"^(OK|PEND|WARN|WATCH|FAIL|CRITICAL|OFF|UNKN)\s+(.+?)\s{2,}(.*)$", clean)
        if not match:
            continue
        state = {
            "PEND": "PENDING",
            "WATCH": "WARN",
            "CRITICAL": "FAIL",
            "OFF": "DISABLED",
            "UNKN": "UNKNOWN",
        }.get(match.group(1), match.group(1))
        name = match.group(2).strip()
        components[name] = {
            "id": status_component_id(name),
            "name": name,
            "state": state,
            "message": match.group(3).strip(),
        }
    return components


def status_component_id(name):
    value = (name or "").strip().lower()
    value = value.replace("/", "_")
    value = re.sub(r"[^a-z0-9]+", "_", value)
    return value.strip("_") or "unknown"


def status_component_maps(status_data=None, txt=""):
    if not isinstance(status_data, dict):
        status_data = {}
    by_name = {}
    by_id = {}
    raw_items = status_data.get("status_components", [])
    if isinstance(raw_items, list):
        for raw in raw_items:
            if not isinstance(raw, dict):
                continue
            name = str(raw.get("name") or "").strip()
            if not name:
                continue
            item = {
                "id": str(raw.get("id") or status_component_id(name)),
                "name": name,
                "state": str(raw.get("state") or "").strip().upper(),
                "message": str(raw.get("message") or "-"),
            }
            by_name[item["name"]] = item
            by_id[item["id"]] = item
    if not by_name and txt:
        for name, item in status_components(txt).items():
            by_name[name] = item
            by_id[item["id"]] = item
    return by_name, by_id


def maintenance_factor_map(status_data=None):
    if not isinstance(status_data, dict):
        return {}
    detection = status_data.get("maintenance_detection", {})
    factors = detection.get("factors", []) if isinstance(detection, dict) else []
    out = {}
    if isinstance(factors, list):
        for item in factors:
            if isinstance(item, dict) and item.get("id"):
                out[str(item["id"])] = item
    return out


def status_class_from_state(state):
    state = str(state or "").strip().upper()
    if state in ("FAIL", "CRITICAL", "ERROR", "FAILED", "BAD"):
        return "bad"
    if state in ("PENDING", "WARN", "WATCH", "STALE", "UNKNOWN", ""):
        return "warn"
    if state in ("DISABLED", "OFF"):
        return "off"
    if state in ("OK", "SUCCESS", "ACTIVE", "ENABLED"):
        return "ok"
    return "warn"


def status_priority(cls):
    return {"bad": 4, "warn": 3, "off": 2, "ok": 1}.get(cls, 3)


def overview_tile_items(tile, status_data=None, txt=""):
    by_name, by_id = status_component_maps(status_data, txt)
    factors = maintenance_factor_map(status_data)
    items = []
    seen = set()
    for name in tile.get("components", ()):
        item = by_name.get(name)
        if item and ("component", item.get("id")) not in seen:
            seen.add(("component", item.get("id")))
            items.append({"kind": "component", **item})
    for component_id in tile.get("component_ids", ()):
        item = by_id.get(component_id)
        if item and ("component", item.get("id")) not in seen:
            seen.add(("component", item.get("id")))
            items.append({"kind": "component", **item})
    for factor_id in tile.get("factors", ()):
        factor = factors.get(factor_id)
        if not factor or ("factor", factor_id) in seen:
            continue
        seen.add(("factor", factor_id))
        items.append(
            {
                "kind": "factor",
                "id": factor_id,
                "name": str(factor.get("label") or factor_id),
                "state": str(factor.get("status") or ""),
                "message": str(factor.get("meaning") or factor.get("detail") or "-"),
                "detail": str(factor.get("detail") or "-"),
            }
        )
    return items


def overview_tile_status(tile, status_data=None, txt=""):
    items = overview_tile_items(tile, status_data, txt)
    if not items:
        return status_step_class(txt, tile.get("components", ()), tile.get("log_terms", ()))
    best = "ok"
    detail = ""
    for item in items:
        cls = status_class_from_state(item.get("state"))
        if status_priority(cls) > status_priority(best):
            best = cls
            detail = item.get("message") or item.get("detail") or "-"
    if not detail:
        detail = items[0].get("message") or "ok"
    return best, detail



def maintenance_result_snippet_info(path, empty_log, max_chars=1400):
    info = maintenance_result_info(path, empty_log)
    log = str(info.get("log") or "")
    if len(log) > max_chars:
        info = dict(info)
        info["log"] = log[:500].rstrip() + "\n...\n" + log[-max_chars:].lstrip()
    return info


def render_status_details_overview():
    txt, _status_meta = status_text_cache_only()
    status_data = load_status_json()
    status_data = status_data if isinstance(status_data, dict) else {}
    perf = performance_debug_config_values()
    image_check = maintenance_result_snippet_info(
        MAINT_IMAGE_CHECK_RESULT,
        t("system_details.no_image_check_run"),
    )
    image_sync = maintenance_result_snippet_info(
        MAINT_IMAGE_SYNC_RESULT,
        t("system_details.no_image_import_run"),
    )
    archive_result = maintenance_result_snippet_info(
        MAINT_ARCHIVE_RESULT,
        t("system_details.no_archive_run"),
    )
    return (
        '<section class="panel">'
        '<div class="panel-head-inline"><h2>' + esc(t("system_details.title")) + '</h2>'
        '<a class="button secondary" href="/details">' + esc(t("system_details.open_diagnostics")) + '</a></div>'
        '<div class="grid-2">'
        '<section class="subpanel"><h3>' + esc(t("system_details.data_freshness")) + '</h3>'
        + render_status_value_table(status_details_freshness_rows(status_data, txt))
        + '</section>'
        '<section class="subpanel"><h3>' + esc(t("system_details.runtime_modes")) + '</h3>'
        + render_status_value_table(status_details_runtime_rows(perf))
        + '</section>'
        '<section class="subpanel"><h3>' + esc(t("system_details.timeline_diagnostics")) + '</h3>'
        + render_status_value_table(status_details_timeline_rows(perf))
        + '<div class="actions"><a class="button secondary" href="/timeline-log">' + esc(t("phrase.view_timeline")) + '</a></div>'
        + '</section>'
        '<section class="subpanel"><h3>' + esc(t("system_details.primary_links")) + '</h3>'
        + render_link_card_grid([
            ("/services", t("phrase.services"), t("settings.tab_system")),
            ("/diagnostics", t("phrase.diagnostics"), t("settings.tab_system")),
            ("/maintenance", t("phrase.stale_usb_path_detection"), t("settings.tab_system")),
            ("/update", t("phrase.update"), t("settings.tab_system")),
            ("/sources", t("phrase.sources"), t("system_details.sources_hint")),
            ("/wifi", t("phrase.wifi"), t("system_details.network_hint")),
            ("/archive", t("phrase.archive"), t("system_details.archive_hint")),
            ("/boot-notify", t("phrase.boot_notify"), t("settings.tab_telegram")),
        ])
        + '</section>'
        '</div>'
        '</section>'
        '<section class="panel">'
        '<h2>' + esc(t("system_details.last_jobs")) + '</h2>'
        '<div class="action-result-grid">'
        '<section class="subpanel">' + render_maintenance_result_panel(t("system_details.image_check"), image_check) + '</section>'
        '<section class="subpanel">' + render_maintenance_result_panel(t("system_details.image_import"), image_sync) + '</section>'
        '<section class="subpanel">' + render_maintenance_result_panel(t("system_details.archive_run"), archive_result) + '</section>'
        '</div>'
        '</section>'
    )



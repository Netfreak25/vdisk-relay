def app_manifest_json():
    manifest = {
        "id": APP_ID,
        "name": APP_NAME,
        "short_name": APP_SHORT_NAME,
        "description": t("manifest.description"),
        "start_url": "/",
        "scope": "/",
        "display": "standalone",
        "display_override": ["standalone", "minimal-ui"],
        "background_color": APP_BACKGROUND_COLOR,
        "theme_color": APP_THEME_COLOR,
        "orientation": "any",
        "categories": ["utilities"],
        "icons": [
            {
                "src": "/app-icon-192.png",
                "sizes": "192x192",
                "type": "image/png",
                "purpose": "any maskable",
            },
            {
                "src": "/app-icon-512.png",
                "sizes": "512x512",
                "type": "image/png",
                "purpose": "any maskable",
            },
        ],
        "shortcuts": [
            {
                "name": t("shortcut.data"),
                "short_name": t("shortcut.data"),
                "url": "/data",
                "icons": [{"src": "/app-icon-192.png", "sizes": "192x192"}],
            },
            {
                "name": t("shortcut.sources"),
                "short_name": t("shortcut.sources"),
                "url": "/sources",
                "icons": [{"src": "/app-icon-192.png", "sizes": "192x192"}],
            },
            {
                "name": t("shortcut.system"),
                "short_name": t("shortcut.system"),
                "url": "/maintenance/actions",
                "icons": [{"src": "/app-icon-192.png", "sizes": "192x192"}],
            },
        ],
    }
    return json.dumps(manifest, ensure_ascii=False, separators=(",", ":"))


def service_worker_js():
    return """
const CACHE = 'vdisk-relay-v4';
const STATIC_PATHS = ['/', '/manifest.webmanifest', '/favicon.svg', '/app-icon-192.png', '/app-icon-512.png'];
const STATIC_SET = new Set(STATIC_PATHS);
self.addEventListener('install', event => {
  event.waitUntil(caches.open(CACHE).then(cache => cache.addAll(STATIC_PATHS)).then(() => self.skipWaiting()));
});
self.addEventListener('activate', event => {
  event.waitUntil(
    caches.keys().then(keys => Promise.all(keys.filter(key => key !== CACHE).map(key => caches.delete(key))))
      .then(() => self.clients.claim())
  );
});
self.addEventListener('fetch', event => {
  const req = event.request;
  if (req.method !== 'GET') { return; }
  const url = new URL(req.url);
  if (url.origin !== self.location.origin) { return; }
  if (req.mode === 'navigate') {
    event.respondWith(
      caches.open(CACHE).then(cache => fetch(req).then(res => {
        cache.put(req, res.clone());
        return res;
      }).catch(() => cache.match(req).then(hit => hit || cache.match('/'))))
    );
    return;
  }
  if (STATIC_SET.has(url.pathname)) {
    event.respondWith(
      caches.open(CACHE).then(cache => cache.match(req).then(hit => {
        if (hit) { return hit; }
        return fetch(req).then(res => {
          cache.put(req, res.clone());
          return res;
        });
      }))
    );
  }
});
"""


def favicon_svg():
    return f"""<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64">
<rect width="64" height="64" rx="12" fill="#101418"/>
<circle cx="27" cy="34" r="17" fill="#111f28" stroke="#65c7f7" stroke-width="4"/>
<circle cx="27" cy="34" r="5" fill="#2dd4a3"/>
<path d="M38 23h12l-4-4m4 4-4 4" fill="none" stroke="#2dd4a3" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
<path d="M43 41H31l4 4m-4-4 4-4" fill="none" stroke="#65c7f7" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
<path d="M12 52c10 5 29 6 42-2" fill="none" stroke="#234a55" stroke-width="4" stroke-linecap="round"/>
</svg>"""


def png_chunk(tag, data):
    tag_b = tag.encode("ascii")
    return (
        struct.pack(">I", len(data))
        + tag_b
        + data
        + struct.pack(">I", binascii.crc32(tag_b + data) & 0xFFFFFFFF)
    )


def app_icon_png(size):
    if size in ICON_CACHE:
        return ICON_CACHE[size]

    size = int(size)
    raw = bytearray()
    center_x = size * 0.42
    center_y = size * 0.54
    platter_r = size * 0.28
    hub_r = size * 0.075
    ring_w = max(3, int(size * 0.018))

    def line_hit(px, py, x1, y1, x2, y2, width):
        dx = x2 - x1
        dy = y2 - y1
        if dx == 0 and dy == 0:
            return False
        t = max(0.0, min(1.0, ((px - x1) * dx + (py - y1) * dy) / (dx * dx + dy * dy)))
        lx = x1 + t * dx
        ly = y1 + t * dy
        return (px - lx) ** 2 + (py - ly) ** 2 <= width ** 2

    for y in range(size):
        raw.append(0)
        for x in range(size):
            t = (x + y) / max(1, (2 * size - 2))
            r = int(13 + 12 * (1 - t))
            g = int(18 + 36 * t)
            b = int(22 + 42 * t)

            dx = (x - size * 0.72) / size
            dy = (y - size * 0.28) / size
            glow = max(0.0, 1.0 - math.sqrt(dx * dx + dy * dy) * 3.0)
            r = min(255, int(r + glow * 18))
            g = min(255, int(g + glow * 88))
            b = min(255, int(b + glow * 74))

            dist = math.sqrt((x - center_x) ** 2 + (y - center_y) ** 2)
            if dist <= platter_r:
                shade = max(0.0, min(1.0, dist / max(1, platter_r)))
                r, g, b = int(18 + shade * 18), int(32 + shade * 42), int(42 + shade * 48)
            if abs(dist - platter_r) <= ring_w:
                r, g, b = 101, 199, 247
            if dist <= hub_r:
                r, g, b = 45, 212, 163

            w = max(2, int(size * 0.018))
            if line_hit(x, y, size * 0.58, size * 0.34, size * 0.83, size * 0.34, w):
                r, g, b = 45, 212, 163
            if line_hit(x, y, size * 0.62, size * 0.67, size * 0.34, size * 0.67, w):
                r, g, b = 101, 199, 247
            if line_hit(x, y, size * 0.79, size * 0.28, size * 0.86, size * 0.34, w) or line_hit(x, y, size * 0.79, size * 0.40, size * 0.86, size * 0.34, w):
                r, g, b = 45, 212, 163
            if line_hit(x, y, size * 0.38, size * 0.61, size * 0.30, size * 0.67, w) or line_hit(x, y, size * 0.38, size * 0.73, size * 0.30, size * 0.67, w):
                r, g, b = 101, 199, 247

            raw.extend((r, g, b, 255))

    ihdr = struct.pack(">IIBBBBB", size, size, 8, 6, 0, 0, 0)
    data = (
        b"\x89PNG\r\n\x1a\n"
        + png_chunk("IHDR", ihdr)
        + png_chunk("IDAT", zlib.compress(bytes(raw), 6))
        + png_chunk("IEND", b"")
    )
    ICON_CACHE[size] = data
    return data

def html_body_fragment(document):
    match = re.search(r"<body[^>]*>(.*)</body>", document, re.I | re.S)
    if match:
        return match.group(1)
    return document



ULTRA_FAST_REMAINDER_QUEUE_DELAY_SECONDS="2"

NETWORK_GUARDIAN_ENABLED="1"
NETWORK_GUARDIAN_CHECK_INTERVAL_SECONDS="300"
NETWORK_GUARDIAN_FAILS_BEFORE_AP="3"
NETWORK_GUARDIAN_RECONNECT_WAIT_SECONDS="90"

def read_file(path, default=""):
    try:
        with open(path, "r", encoding="utf-8", errors="replace") as f:
            return f.read()
    except FileNotFoundError:
        return default


def shell_quote(value):
    return "'" + str(value).replace("'", "'\"'\"'") + "'"


def parse_shell_assignment(line):
    stripped = line.strip()
    if not stripped or stripped.startswith("#"):
        return None

    try:
        parts = shlex.split(stripped, comments=True, posix=True)
    except ValueError:
        return None

    if len(parts) != 1 or "=" not in parts[0]:
        return None

    key, value = parts[0].split("=", 1)
    return key, value


def parse_shell_var(text, name, default):
    for line in text.splitlines():
        parsed = parse_shell_assignment(line)
        if not parsed:
            continue
        key, value = parsed
        if key == name:
            return value
    return default


def get_defaults():
    text = read_file(CONFIG)
    return {
        "retries": parse_shell_var(text, "SOURCE_DEFAULT_RETRIES", "4"),
        "wait": parse_shell_var(text, "SOURCE_DEFAULT_WAIT_SECONDS", "3"),
        "last_dir": parse_shell_var(text, "SOURCE_LAST_STATE_DIR", "/var/lib/vdisk-relay/last"),
        "tmp_dir": parse_shell_var(text, "SOURCE_TMP_LOG_DIR", "/run/vdisk-relay"),
        "ext": parse_shell_var(text, "SOURCE_DEFAULT_EXTENSION", "mp4"),
    }


def parse_env():
    env = {}
    for line in read_file(ENV_FILE).splitlines():
        parsed = parse_shell_assignment(line)
        if not parsed:
            continue

        key, val = parsed
        if not re.match(r"^[A-Z0-9_]+$", key):
            continue

        env[key] = val

    return env


def chat_type_var_from_chat_var(chat_var):
    if chat_var.endswith("_CHAT_ID"):
        return chat_var[:-8] + "_CHAT_TYPE"
    return chat_var + "_CHAT_TYPE"


def chat_type_from_id(chat_id):
    if chat_id.startswith("-100"):
        return "supergroup"
    if chat_id.startswith("-"):
        return "group"
    if not chat_id:
        return ""
    return "private"


def resolve_chat_type(env, chat_var, chat_id=""):
    chat_type_var = chat_type_var_from_chat_var(chat_var)
    chat_type = env.get(chat_type_var, "").strip()
    if chat_type:
        return chat_type
    if not chat_id:
        chat_id = env.get(chat_var, "")
    return chat_type_from_id(str(chat_id).strip())


def backup_file(path, label):
    os.makedirs(BACKUP_DIR, mode=0o700, exist_ok=True)

    import time
    dst = os.path.join(BACKUP_DIR, f"{label}.{time.strftime('%Y%m%d-%H%M%S')}")

    if os.path.exists(path):
        shutil.copy2(path, dst)
        os.chmod(dst, 0o600)

    return dst


def write_atomic(path, content, mode):
    directory = os.path.dirname(path)
    fd, tmp = tempfile.mkstemp(prefix=os.path.basename(path) + ".", dir=directory)

    try:
        with os.fdopen(fd, "w", encoding="utf-8") as f:
            f.write(content)
        os.chmod(tmp, mode)
        os.chown(tmp, 0, 0)
        os.replace(tmp, path)
    finally:
        if os.path.exists(tmp):
            os.unlink(tmp)


def write_env(env):
    backup_file(ENV_FILE, "vdisk-relay.env")

    bot_keys = sorted(k for k in env if k.endswith("_BOT_TOKEN"))
    chat_keys = sorted(k for k in env if k.endswith("_CHAT_ID"))
    chat_type_keys = sorted(k for k in env if k.endswith("_CHAT_TYPE"))
    other_keys = sorted(k for k in env if k not in bot_keys and k not in chat_keys and k not in chat_type_keys)

    lines = []

    if bot_keys:
        lines.append("# Telegram Bot Tokens")
        for k in bot_keys:
            lines.append(f"{k}={shell_quote(env[k])}")
        lines.append("")

    if chat_keys:
        lines.append("# Telegram Chat IDs")
        for k in chat_keys:
            lines.append(f"{k}={shell_quote(env[k])}")
        lines.append("")

    if chat_type_keys:
        lines.append("# Telegram Chat Types")
        for k in chat_type_keys:
            lines.append(f"{k}={shell_quote(env[k])}")
        lines.append("")

    if other_keys:
        lines.append("# Other")
        for k in other_keys:
            lines.append(f"{k}={shell_quote(env[k])}")
        lines.append("")

    write_atomic(ENV_FILE, "\n".join(lines).rstrip() + "\n", 0o600)


def boot_notify_info():
    env = parse_env()
    sources = []
    try:
        sources = parse_sources()
    except Exception:
        sources = []

    fallback_bot_var = ""
    fallback_chat_var = ""
    if sources:
        fallback_bot_var = sources[0].get("bot_var", "")
        fallback_chat_var = sources[0].get("chat_var", "")

    configured_bot_var = env.get(BOOT_NOTIFY_BOT_VAR, "").strip()
    configured_chat_var = env.get(BOOT_NOTIFY_CHAT_VAR, "").strip()

    bot_var = configured_bot_var or fallback_bot_var
    chat_var = configured_chat_var or fallback_chat_var
    bot_token = env.get(bot_var, "") if bot_var else ""
    chat_id = env.get(chat_var, "") if chat_var else ""
    chat_type = resolve_chat_type(env, chat_var, chat_id) if chat_var else ""

    return {
        "enabled": os.path.exists(BOOT_NOTIFY_ALLOW_FILE),
        "bot_var": bot_var,
        "chat_var": chat_var,
        "bot_token": bot_token,
        "chat_id": chat_id,
        "chat_type": chat_type,
        "configured_bot_var": configured_bot_var,
        "configured_chat_var": configured_chat_var,
        "fallback_bot_var": fallback_bot_var,
        "fallback_chat_var": fallback_chat_var,
        "ready": bool(bot_var and chat_var and bot_token and chat_id),
        "source": "custom" if configured_bot_var and configured_chat_var else ("first source" if bot_var and chat_var else "missing"),
    }


def boot_notify_set_enabled(enabled):
    if enabled:
        write_atomic(BOOT_NOTIFY_ALLOW_FILE, time.strftime("%Y-%m-%dT%H:%M:%S%z") + "\n", 0o644)
        return
    try:
        os.unlink(BOOT_NOTIFY_ALLOW_FILE)
    except FileNotFoundError:
        pass


def bool_config_value(value):
    if isinstance(value, bool):
        return value
    if isinstance(value, (int, float)):
        return value != 0
    return str(value).strip().lower() in ("1", "true", "yes", "on", "yes", "an")


def maintenance_notify_default_factors():
    return {factor_id: {"alert": False, "clear": False} for factor_id, _label in MAINTENANCE_NOTIFY_FACTORS}


def maintenance_notify_config():
    data = load_json_file(MAINT_NOTIFY_CONFIG, {})
    if not isinstance(data, dict):
        data = {}

    raw_factors = data.get("factors", {})
    if not isinstance(raw_factors, dict):
        raw_factors = {}

    factors = maintenance_notify_default_factors()
    for factor_id in factors:
        item = raw_factors.get(factor_id, {})
        if not isinstance(item, dict):
            item = {}
        alert = bool_config_value(item.get("alert", item.get("enabled", False)))
        clear = bool_config_value(item.get("clear", False)) and alert
        factors[factor_id] = {"alert": alert, "clear": clear}

    return {
        "bot_var": str(data.get("bot_var", "")).strip(),
        "chat_var": str(data.get("chat_var", "")).strip(),
        "factors": factors,
    }


def write_maintenance_notify_config(config):
    bot_var = str(config.get("bot_var", "")).strip()
    chat_var = str(config.get("chat_var", "")).strip()
    raw_factors = config.get("factors", {})
    factors = maintenance_notify_default_factors()

    if isinstance(raw_factors, dict):
        for factor_id in factors:
            item = raw_factors.get(factor_id, {})
            if not isinstance(item, dict):
                item = {}
            alert = bool_config_value(item.get("alert", False))
            clear = bool_config_value(item.get("clear", False)) and alert
            factors[factor_id] = {"alert": alert, "clear": clear}

    backup_file(MAINT_NOTIFY_CONFIG, "vdisk-relay-maintenance-notify.json")
    write_json_file_atomic(
        MAINT_NOTIFY_CONFIG,
        {
            "bot_var": bot_var,
            "chat_var": chat_var,
            "factors": factors,
        },
    )


def maintenance_notify_info():
    config = maintenance_notify_config()
    env = parse_env()
    bot_var = config["bot_var"]
    chat_var = config["chat_var"]
    bot_token = env.get(bot_var, "") if bot_var else ""
    chat_id = env.get(chat_var, "") if chat_var else ""
    chat_type = resolve_chat_type(env, chat_var, chat_id) if chat_var else ""
    state = load_json_file(MAINT_NOTIFY_STATE, {})
    if not isinstance(state, dict):
        state = {}

    return {
        "enabled": os.path.exists(MAINT_NOTIFY_ALLOW_FILE),
        "ready": bool(bot_var and chat_var and bot_token and chat_id),
        "bot_var": bot_var,
        "chat_var": chat_var,
        "bot_token": bot_token,
        "chat_id": chat_id,
        "chat_type": chat_type,
        "factors": config["factors"],
        "state": state,
    }


def maintenance_notify_set_enabled(enabled):
    gate_set(MAINT_NOTIFY_ALLOW_FILE, enabled)


def maintenance_notify_reset_check_clock():
    state = load_json_file(MAINT_NOTIFY_STATE, {})
    if not isinstance(state, dict):
        state = {}
    state["last_check_epoch"] = 0
    write_json_file_atomic(MAINT_NOTIFY_STATE, state)


def source_section(lines):
    start = None
    end = None

    for i, line in enumerate(lines):
        if line.strip() == "SOURCES=(":
            start = i
            continue

        if start is not None and line.strip() == ")":
            end = i
            break

    if start is None or end is None:
        raise RuntimeError("SOURCES=(...) not found in /etc/vdisk-relay.conf")

    return start, end


def parse_sources():
    text = read_file(CONFIG)
    lines = text.splitlines()
    start, end = source_section(lines)

    sources = []

    for line in lines[start + 1:end]:
        stripped = line.strip()

        if not stripped or stripped.startswith("#"):
            continue

        try:
            values = shlex.split(stripped, comments=True, posix=True)
        except ValueError:
            continue

        if not values:
            continue

        parts = values[0].split("|")
        while len(parts) < 16:
            parts.append("")

        sources.append({
            "id": parts[0],
            "enabled": parts[1],
            "profile": parts[2] or "blink-security-video",
            "label": parts[3] or parts[0],
            "pattern": parts[4] or "*",
            "extensions": parts[5] or "mp4",
            "telegram_mode": parts[6] or "auto",
            "time_mode": parts[7] or "mtime",
            "source_timezone": parts[8] or "UTC",
            "display_timezone": parts[9] or "Europe/Berlin",
            "last_file": parts[10],
            "bot_var": parts[11],
            "chat_var": parts[12],
            "retries": parts[13] or "4",
            "wait": parts[14] or "3",
            "tmp_log": parts[15],
        })

    return sources


def format_source(c):
    parts = [
        c["id"],
        c["enabled"],
        c.get("profile", "blink-security-video"),
        c.get("label", c["id"]),
        c["pattern"],
        c.get("extensions", "mp4"),
        c.get("telegram_mode", "auto"),
        c.get("time_mode", "mtime"),
        c.get("source_timezone", "UTC"),
        c.get("display_timezone", "Europe/Berlin"),
        c["last_file"],
        c["bot_var"],
        c["chat_var"],
        c["retries"],
        c["wait"],
        c["tmp_log"],
    ]
    return "  " + shell_quote("|".join(parts))


def write_sources(sources):
    text = read_file(CONFIG)
    lines = text.splitlines()
    start, end = source_section(lines)

    backup_file(CONFIG, "vdisk-relay.conf")

    new_lines = []
    new_lines.extend(lines[:start + 1])
    for c in sources:
        new_lines.append(format_source(c))
    new_lines.extend(lines[end:])

    write_atomic(CONFIG, "\n".join(new_lines) + "\n", 0o644)


def parse_int_config_value(text, name, default):
    raw = parse_shell_var(text, name, str(default))
    try:
        return int(raw)
    except Exception:
        return default


def preview_config_values():
    text = read_file(CONFIG)
    values = {}
    for key, _label, default, _min_value, _max_value, _help_text in PREVIEW_CONFIG_FIELDS:
        values[key] = parse_int_config_value(text, key, default)
    return values


def update_config_values(updates, section_label="WebUI", ordered_keys=None):
    allowed = CONFIG_UPDATE_KEYS
    if any(key not in allowed for key in updates):
        raise ValueError("Unknown configuration value")

    text = read_file(CONFIG)
    lines = text.splitlines()
    seen = set()
    out = []

    for line in lines:
        parsed = parse_shell_assignment(line)
        if parsed and parsed[0] in updates:
            key = parsed[0]
            out.append(key + '="' + str(updates[key]) + '"')
            seen.add(key)
        else:
            out.append(line)

    missing_order = ordered_keys or list(updates.keys())
    missing = [key for key in missing_order if key in updates and key not in seen]
    if missing:
        if out and out[-1].strip():
            out.append("")
        out.append("# " + section_label)
        for key in missing:
            out.append(key + '="' + str(updates[key]) + '"')

    backup_file(CONFIG, "vdisk-relay.conf")
    write_atomic(CONFIG, "\n".join(out).rstrip() + "\n", 0o644)


def config_value(name, default=""):
    return parse_shell_var(read_file(CONFIG), name, default)


def gate_set(path, enabled):
    if enabled:
        write_atomic(path, time.strftime("%Y-%m-%dT%H:%M:%S%z") + "\n", 0o644)
        return
    try:
        os.unlink(path)
    except FileNotFoundError:
        pass


def validate_single_line(value, name):
    if "\n" in value or "\r" in value:
        raise ValueError("Invalid line break in " + name)
    return value


def is_valid_timezone_name(value):
    value = str(value or "").strip()
    if not value or len(value) > WEB_DISPLAY_TIMEZONE_MAX_LEN:
        return False
    if not re.fullmatch(r"[A-Za-z0-9_+\-./]+", value):
        return False
    if value.upper() == "UTC":
        return True
    if ZoneInfo is None:
        return value == DEFAULT_WEB_DISPLAY_TIMEZONE
    try:
        ZoneInfo(value)
        return True
    except Exception:
        return value == DEFAULT_WEB_DISPLAY_TIMEZONE


def validate_web_display_timezone(value):
    value = validate_single_line(str(value or "").strip(), "web display time zone")
    if not is_valid_timezone_name(value):
        raise ValueError("Web display time zone must be a valid IANA time zone, for example Europe/Berlin or UTC")
    return value


def web_display_timezone_name():
    value = config_value("WEB_DISPLAY_TIMEZONE", DEFAULT_WEB_DISPLAY_TIMEZONE).strip()
    return value if is_valid_timezone_name(value) else DEFAULT_WEB_DISPLAY_TIMEZONE


def duration_hm(seconds):
    try:
        seconds = max(0, int(seconds))
    except Exception:
        seconds = 0
    minutes = (seconds + 59) // 60
    hours = minutes // 60
    rest_minutes = minutes % 60
    parts = []
    if hours:
        parts.append(str(hours) + " " + t("duration.hour_one" if hours == 1 else "duration.hour_many"))
    parts.append(str(rest_minutes) + " " + t("duration.minute_one" if rest_minutes == 1 else "duration.minute_many"))
    return " ".join(parts)


def load_git_credentials():
    data = load_json_file(GIT_CREDENTIALS_FILE, {})
    if not isinstance(data, dict):
        return {}
    return {
        "host": str(data.get("host", "")),
        "username": str(data.get("username", "")),
        "token": str(data.get("token", "")),
    }


def git_credentials_status():
    creds = load_git_credentials()
    return {
        "configured": bool(creds.get("username") and creds.get("token")),
        "host": creds.get("host", ""),
        "username": creds.get("username", ""),
        "token_present": bool(creds.get("token")),
        "file": GIT_CREDENTIALS_FILE,
        "askpass": GIT_ASKPASS,
        "askpass_exists": os.path.isfile(GIT_ASKPASS),
    }


def archive_config():
    text = read_file(CONFIG)
    return {
        "target": parse_shell_var(text, "ARCHIVE_RSYNC_TARGET", ""),
        "password_file": parse_shell_var(text, "ARCHIVE_RSYNC_PASSWORD_FILE", "/root/vdisk-relay-rsync.pass"),
        "max_seconds": parse_int_config_value(text, "ARCHIVE_RSYNC_MAX_SECONDS", 900),
        "contimeout": parse_int_config_value(text, "ARCHIVE_RSYNC_CONTIMEOUT", 10),
        "timeout": parse_int_config_value(text, "ARCHIVE_RSYNC_TIMEOUT", 60),
        "enabled": os.path.exists(ARCHIVE_ALLOW_FILE),
    }


def archive_password_status(path):
    try:
        st = os.stat(path)
        return {
            "exists": True,
            "file": path,
            "size": st.st_size,
            "mtime": datetime.fromtimestamp(st.st_mtime).strftime("%Y-%m-%d %H:%M:%S"),
            "readable": os.access(path, os.R_OK),
        }
    except Exception:
        return {"exists": False, "file": path, "size": 0, "mtime": "-", "readable": False}


def write_archive_password(path, password):
    validate_plain(path, "archive_password_file")
    validate_single_line(password, "archive_password")
    if not password:
        raise ValueError("Archive password missing")
    directory = os.path.dirname(path) or "/root"
    os.makedirs(directory, mode=0o700, exist_ok=True)
    write_atomic(path, password.rstrip("\n") + "\n", 0o600)


def set_archive_enabled(enabled):
    gate_set(ARCHIVE_ALLOW_FILE, enabled)
    if enabled:
        systemctl_quick(["enable", "--now", ARCHIVE_TIMER_UNIT], 20)
    else:
        systemctl_quick(["disable", "--now", ARCHIVE_TIMER_UNIT], 20)
        systemctl_quick(["stop", ARCHIVE_SERVICE_UNIT], 12)


def set_network_guardian_gate(enabled):
    gate_set(NETWORK_GUARDIAN_ALLOW_FILE, enabled)
    if enabled:
        rc, out = systemctl_quick(["enable", "--now", NETWORK_GUARDIAN_TIMER_UNIT], 20)
        if rc != 0:
            return rc, out
        return systemctl_quick(["start", "--no-block", NETWORK_GUARDIAN_SERVICE_UNIT], 8)

    rc, out = systemctl_quick(["disable", "--now", NETWORK_GUARDIAN_TIMER_UNIT], 20)
    stop_rc, stop_out = systemctl_quick(["stop", NETWORK_GUARDIAN_SERVICE_UNIT], 12)
    if rc != 0:
        return rc, out
    return stop_rc, stop_out


def live_gate_state_exists():
    if os.path.exists(LIVE_ENABLE_FILE):
        return True
    try:
        return any(name.startswith("vdisk-relay.allow-") for name in os.listdir("/etc"))
    except OSError:
        return False


def live_gate_enabled(path):
    return os.path.exists(LIVE_ENABLE_FILE) and os.path.exists(path)


def setup_requires_gate(path):
    if not live_gate_state_exists():
        return False
    return live_gate_enabled(path)


def setup_state():
    env = parse_env()
    missing = []
    sources = []
    requires_source_telegram = (
        setup_requires_gate(SYNC_ALLOW_FILE)
        or setup_requires_gate(HEALTH_ALLOW_FILE)
        or setup_requires_gate(BOOT_NOTIFY_ALLOW_FILE)
    )
    requires_archive = setup_requires_gate(ARCHIVE_ALLOW_FILE)

    if not os.path.exists(CONFIG):
        missing.append("Configuration file")
    try:
        sources = parse_sources()
    except Exception:
        missing.append("Source configuration")

    active = [c for c in sources if c.get("enabled") == "1"]
    if requires_source_telegram and not active:
        missing.append("at least one active source")

    for source in active:
        if not requires_source_telegram:
            continue
        bot_var = source.get("bot_var", "")
        chat_var = source.get("chat_var", "")
        if not bot_var or not env.get(bot_var):
            missing.append("Bot token for " + (source.get("id") or "Source"))
        if not chat_var or not env.get(chat_var):
            missing.append("Chat ID for " + (source.get("id") or "Source"))

    config_text = read_file(CONFIG)
    rsync_target = parse_shell_var(config_text, "ARCHIVE_RSYNC_TARGET", "")
    rsync_pass = parse_shell_var(config_text, "ARCHIVE_RSYNC_PASSWORD_FILE", "/root/vdisk-relay-rsync.pass")
    if requires_archive and not rsync_target:
        missing.append("Archive destination")
    if requires_archive and (not rsync_pass or not os.path.isfile(rsync_pass)):
        missing.append("Rsync password file")

    notify = boot_notify_info()
    if setup_requires_gate(BOOT_NOTIFY_ALLOW_FILE) and notify["enabled"] and not notify["ready"]:
        missing.append("Boot notify is enabled but configuration is incomplete")

    return {
        "ready": not missing,
        "missing": missing,
        "sources": sources,
        "active_sources": active,
        "rsync_target": rsync_target,
        "rsync_pass": rsync_pass,
    }


def runtime_units_for_pause():
    keep = {
        "vdisk-relay-web.service",
    }
    return [unit for unit in ALLOWED_SERVICE_UNITS if unit not in keep]


def pause_runtime_for_setup(force=False):
    state = setup_state()
    if state["ready"]:
        try:
            os.unlink(SETUP_PAUSE_MARKER)
        except FileNotFoundError:
            pass
        return state

    if not force and os.path.exists(SETUP_PAUSE_MARKER):
        return state

    for unit in runtime_units_for_pause():
        systemctl_quick(["disable", "--now", unit], 12)
        systemctl_quick(["stop", unit], 8)

    os.makedirs(os.path.dirname(SETUP_PAUSE_MARKER), mode=0o755, exist_ok=True)
    write_atomic(SETUP_PAUSE_MARKER, time.strftime("%Y-%m-%dT%H:%M:%S%z") + "\n", 0o644)
    return state


def write_initial_setup(form):
    image_file = form.get("image_file", ["/usbdisk.img"])[0].strip() or "/usbdisk.img"
    data_root = form.get("data_root", ["/files"])[0].strip() or "/files"
    rsync_target = form.get("rsync_target", [""])[0].strip()
    rsync_pass = form.get("rsync_password", [""])[0].strip()
    rsync_pass_file = form.get("rsync_pass_file", ["/root/vdisk-relay-rsync.pass"])[0].strip() or "/root/vdisk-relay-rsync.pass"
    source_id = form.get("source_id", ["source1"])[0].strip() or "source1"
    pattern = form.get("pattern", [""])[0].strip()
    bot_base = form.get("bot_id", ["PRIMARY"])[0].strip() or "PRIMARY"
    bot_token = form.get("bot_token", [""])[0].strip()
    chat_base = form.get("chat_id_name", [bot_base])[0].strip() or bot_base
    chat_id = form.get("telegram_chat_id", [""])[0].strip()

    if not ID_RE.match(source_id):
        raise ValueError("Invalid source ID")
    if not pattern:
        raise ValueError("File pattern missing")
    if not rsync_target:
        raise ValueError("Archive destination missing")
    if not rsync_pass:
        raise ValueError("rsync password missing")
    if not bot_token:
        raise ValueError("Bot token missing")
    if not chat_id:
        raise ValueError("Chat ID missing")

    validate_plain(image_file, "image_file")
    validate_plain(data_root, "data_root")
    validate_plain(rsync_target, "rsync_target")
    validate_plain(rsync_pass_file, "rsync_pass_file")
    validate_plain(pattern, "pattern")
    validate_plain(bot_token, "bot_token")
    validate_plain(chat_id, "chat_id")

    bot_var = env_var_from_base(bot_base, "_BOT_TOKEN")
    chat_var = env_var_from_base(chat_base, "_CHAT_ID")
    last_file = os.path.join("/var/lib/vdisk-relay/last", source_id + ".last")
    tmp_log = os.path.join("/run/vdisk-relay", source_id + ".telegram.log")

    config = f"""# vdisk-relay Configuration
# Secrets are stored in /etc/vdisk-relay.env and {rsync_pass_file}


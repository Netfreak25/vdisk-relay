def maintenance_tabs(active):
    items = [
        ("system", "/settings/system", t("phrase.overview")),
        ("services", "/services", t("phrase.services")),
        ("diagnostics", "/diagnostics", t("phrase.diagnostics")),
        ("maintenance", "/maintenance", t("phrase.stale_usb_path_detection")),
        ("update", "/update", t("phrase.update")),
    ]
    links = []
    for key, href, label in items:
        cls = " active" if key == active else ""
        links.append('<a class="' + cls.strip() + '" href="' + esc(href) + '">' + esc(label) + '</a>')
    return '<div class="tabbar section-tabs">' + ''.join(links) + '</div>'



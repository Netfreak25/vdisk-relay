def fmt_epoch_local(value):
    try:
        ts = int(str(value).strip())
        if ts <= 0:
            return ""
        return time.strftime("%Y-%m-%d %H:%M:%S", time.localtime(ts))
    except Exception:
        return ""


def fmt_age(seconds):
    try:
        seconds = int(seconds)
    except Exception:
        return ""

    if seconds < 60:
        return str(seconds) + " " + t("duration.second_one" if seconds == 1 else "duration.second_many")
    if seconds < 3600:
        minutes = seconds // 60
        return str(minutes) + " " + t("duration.minute_one" if minutes == 1 else "duration.minute_many")
    if seconds < 86400:
        hours = seconds // 3600
        return str(hours) + " " + t("duration.hour_one" if hours == 1 else "duration.hour_many")
    days = seconds // 86400
    return str(days) + " " + t("duration.day_one" if days == 1 else "duration.day_many")



def render_maintenance_notify_factor_actions(factor_id, notify):
    factors = notify.get("factors", {})
    factor = factors.get(factor_id, {"alert": False, "clear": False})
    alert_enabled = bool(factor.get("alert"))
    clear_enabled = bool(factor.get("clear")) and alert_enabled

    alert_next = "0" if alert_enabled else "1"
    clear_next = "0" if clear_enabled else "1"
    clear_disabled = "" if alert_enabled else " disabled"
    alert_class = "is-on" if alert_enabled else "is-off"
    clear_class = "is-on" if clear_enabled else "is-off"
    alert_title = "Disable failure notification" if alert_enabled else "Enable failure notification"
    clear_title = (
        "Entwarnung disable" if clear_enabled else "Entwarnung enable"
    ) if alert_enabled else (
        "All-clear is only possible while the fault alert is active"
    )
    clear_aria = (
        "Telegram-Entwarnung disable" if clear_enabled else "Telegram-Entwarnung enable"
    ) if alert_enabled else (
        "Telegram all-clear disabled because the fault alert is off"
    )

    def toggle_form(kind, next_value, icon_html, title, aria_label, state_class, disabled=""):
        return (
            '<form method="post" action="/maintenance-notify/toggle-factor" class="inline">'
            '<input type="hidden" name="factor" value="' + esc(factor_id) + '">'
            '<input type="hidden" name="kind" value="' + esc(kind) + '">'
            '<input type="hidden" name="enabled" value="' + esc(next_value) + '">'
            '<button type="submit" class="status-toggle has-action-icon ' + esc(state_class) + '" title="' + esc(title) + '" aria-label="' + esc(aria_label) + '"' + disabled + ">"
            '<span class="btn-icon" aria-hidden="true">' + icon_html + '</span>'
            "</button></form>"
        )

    return (
        toggle_form(
            "alert",
            alert_next,
            "&#x2197;",
            alert_title,
            "Telegram failure notification " + ("disable" if alert_enabled else "enable"),
            alert_class,
        )
        + toggle_form(
            "clear",
            clear_next,
            "&#x2713;",
            clear_title,
            clear_aria,
            clear_class,
            clear_disabled,
        )
    )


def render_global_maintenance_notify_toggle(notify):
    enable_action = "/maintenance-notify/disable" if notify["enabled"] else "/maintenance-notify/enable"
    enable_label = "Fully disable Maintenance Telegram" if notify["enabled"] else "Fully enable Maintenance Telegram"
    enable_disabled = "" if notify["enabled"] or notify["ready"] else " disabled"
    state_class = "is-on" if notify["enabled"] else "is-off"
    return (
        '<form method="post" action="' + enable_action + '" class="inline" onsubmit="return confirm(\'' + esc(enable_label) + '?\');">'
        '<button type="submit" class="status-toggle has-action-icon ' + state_class + '" title="' + esc(enable_label) + '" aria-label="' + esc(enable_label) + '"' + enable_disabled + '>'
        '<span class="btn-icon" aria-hidden="true">&#x23FB;</span>'
        '</button>'
        '</form>'
    )



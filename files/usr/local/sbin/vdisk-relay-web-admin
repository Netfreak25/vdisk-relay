def app_build_source_path():
    try:
        return os.path.realpath(__file__)
    except Exception:
        return "/usr/local/sbin/vdisk-relay-web-admin"


def app_build_snapshot():
    path = app_build_source_path()
    try:
        stat = os.stat(path)
        digest = hashlib.sha256()
        with open(path, "rb") as handle:
            for chunk in iter(lambda: handle.read(65536), b""):
                digest.update(chunk)
        build = digest.hexdigest()[:16]
        mtime = datetime.fromtimestamp(stat.st_mtime, timezone.utc).astimezone().isoformat(timespec="seconds")
        return {
            "build": build,
            "mtime": mtime,
            "size": stat.st_size,
        }
    except Exception as exc:
        fallback = hashlib.sha256((APP_NAME + ":" + str(exc)).encode("utf-8", errors="replace")).hexdigest()[:16]
        return {
            "build": fallback,
            "mtime": "",
            "size": 0,
        }


def app_version_info():
    if not APP_VERSION_CACHE:
        APP_VERSION_CACHE.update(app_build_snapshot())
        APP_VERSION_CACHE["started_at"] = datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds")
        APP_VERSION_CACHE["name"] = APP_NAME
    return dict(APP_VERSION_CACHE)


def first_existing_repo_root():
    candidates = []
    stored = read_file(UPDATE_REPO_ROOT, "").strip()
    if stored:
        candidates.append(stored)

    current = os.path.dirname(app_build_source_path())
    for _ in range(8):
        if not current or current == os.path.dirname(current):
            break
        candidates.append(current)
        current = os.path.dirname(current)

    seen = set()
    for candidate in candidates:
        candidate = os.path.realpath(candidate)
        if candidate in seen:
            continue
        seen.add(candidate)
        if os.path.exists(os.path.join(candidate, ".git")):
            return candidate
    return ""


def resolve_git_dir(repo_root):
    git_path = os.path.join(repo_root, ".git")
    if os.path.isdir(git_path):
        return git_path
    if os.path.isfile(git_path):
        line = read_file(git_path, "").strip()
        if line.startswith("gitdir:"):
            target = line.split(":", 1)[1].strip()
            if not os.path.isabs(target):
                target = os.path.join(repo_root, target)
            return os.path.realpath(target)
    return ""


def read_packed_git_ref(git_dir, ref):
    packed = os.path.join(git_dir, "packed-refs")
    for line in read_file(packed, "").splitlines():
        line = line.strip()
        if not line or line.startswith("#") or line.startswith("^"):
            continue
        parts = line.split(" ", 1)
        if len(parts) == 2 and parts[1].strip() == ref:
            return parts[0].strip()
    return ""


def current_git_commit_short():
    repo_root = first_existing_repo_root()
    if not repo_root:
        return "-"
    git_dir = resolve_git_dir(repo_root)
    if not git_dir:
        return "-"
    head = read_file(os.path.join(git_dir, "HEAD"), "").strip()
    if not head:
        return "-"
    if head.startswith("ref:"):
        ref = head.split(":", 1)[1].strip()
        commit = read_file(os.path.join(git_dir, ref), "").strip() or read_packed_git_ref(git_dir, ref)
    else:
        commit = head
    if re.match(r"^[0-9a-fA-F]{7,40}$", commit or ""):
        return commit[:12]
    return "-"


def current_git_branch():
    repo_root = first_existing_repo_root()
    if not repo_root:
        return "-"
    git_dir = resolve_git_dir(repo_root)
    if not git_dir:
        return "-"
    head = read_file(os.path.join(git_dir, "HEAD"), "").strip()
    if not head:
        return "-"
    if head.startswith("ref:"):
        ref = head.split(":", 1)[1].strip()
        prefix = "refs/heads/"
        if ref.startswith(prefix):
            return ref[len(prefix):] or "-"
        return ref or "-"
    if re.match(r"^[0-9a-fA-F]{7,40}$", head):
        return "detached"
    return "-"


def current_vdisk_relay_version():
    repo_root = first_existing_repo_root()
    candidates = ["/usr/local/sbin/vdisk-relay"]
    if repo_root:
        candidates.append(os.path.join(repo_root, "files", "usr", "local", "sbin", "vdisk-relay"))
    for path in candidates:
        text = read_file(path, "")
        match = re.search(r'^VERSION="([^"]+)"', text, re.MULTILINE)
        if match:
            return match.group(1)
    return "-"


def format_uptime_seconds(seconds):
    try:
        seconds = max(0, int(seconds))
    except Exception:
        return "-"
    days, rem = divmod(seconds, 86400)
    hours, rem = divmod(rem, 3600)
    minutes = rem // 60
    if days:
        return f"{days}d {hours}h"
    if hours:
        return f"{hours}h {minutes}m"
    if minutes:
        return f"{minutes}m"
    return "<1m"


def system_uptime_label():
    raw = read_file("/proc/uptime", "").split()
    if not raw:
        return "-"
    try:
        return format_uptime_seconds(float(raw[0]))
    except Exception:
        return "-"


def cached_wifi_signal_summary():
    data = load_json_file(WIFI_STATUS_CACHE, {})
    if not isinstance(data, dict):
        return {"label": "-", "class": "signal-unknown", "detail": ""}
    signal = data.get("signal", {})
    if not isinstance(signal, dict):
        signal = {}
    percent = wifi_signal_percent_value(signal.get("percent"))
    if percent is None:
        return {"label": "-", "class": "signal-unknown", "detail": signal.get("error", "") if isinstance(signal.get("error", ""), str) else ""}
    detail = signal.get("ssid") or ""
    return {
        "label": str(percent) + " %",
        "class": wifi_signal_quality_class(percent),
        "detail": detail,
    }


def sidebar_static_meta():
    now = time.time()
    if APP_SIDEBAR_META_CACHE.get("expires", 0) > now:
        return dict(APP_SIDEBAR_META_CACHE)
    APP_SIDEBAR_META_CACHE.update({
        "expires": now + 60,
        "version": current_vdisk_relay_version(),
        "commit": current_git_commit_short(),
    })
    return dict(APP_SIDEBAR_META_CACHE)


def sidebar_meta_html():
    meta = sidebar_static_meta()
    signal = cached_wifi_signal_summary()
    return (
        '<div class="sidebar-meta" aria-label="' + esc(t("meta.system_status")) + '">'
        '<div class="sidebar-meta-row"><span>' + esc(t("meta.version")) + '</span><b>' + esc(meta.get("version") or "-") + '</b></div>'
        '<div class="sidebar-meta-row"><span>' + esc(t("meta.commit")) + '</span><b>' + esc(meta.get("commit") or "-") + '</b></div>'
        '<div class="sidebar-meta-row"><span>' + esc(t("meta.uptime")) + '</span><b>' + esc(system_uptime_label()) + '</b></div>'
        '<div class="sidebar-meta-row"><span>' + esc(t("meta.wifi")) + '</span><b class="' + esc(signal.get("class", "signal-unknown")) + '" title="' + esc(signal.get("detail", "")) + '">' + esc(signal.get("label") or "-") + '</b></div>'
        '</div>'
    )


def language_settings_panel_html(return_to="/general#language-selection"):
    lang = current_language()
    english_selected = " selected" if lang == "en" else ""
    german_selected = " selected" if lang == "de" else ""
    return (
        '<div class="settings-control-row" id="language-selection">'
        '<div><b>' + esc(t("language.selection_title")) + '</b></div>'
        '<form method="post" action="/language" class="language-selection-form" aria-label="' + esc(t("language.switch")) + '">'
        '<input type="hidden" name="return_to" value="' + esc(return_to) + '">'
        '<select name="lang" class="language-select" aria-label="' + esc(t("language.switch")) + '" onchange="this.form.submit()">'
        '<option value="en"' + english_selected + '>' + esc(t("language.english")) + '</option>'
        '<option value="de"' + german_selected + '>' + esc(t("language.german")) + '</option>'
        '</select>'
        '</form>'
        '</div>'
    )


def prepare_language_runtime(lang):
    lang = normalize_language(lang)
    language_catalog(lang)
    i18n_replacement_items(lang, html=False)
    i18n_replacement_items(lang, html=True)


def update_banner_html(active):
    if active == "update":
        return ""
    data = load_json_file(UPDATE_CHECK_STATUS, {})
    if not isinstance(data, dict):
        return ""

    if data.get("available"):
        return (
            '<a class="update-banner update-banner-hot" href="/update">'
            '<b>Update available</b>'
            '<span>' + esc(data.get("message", "Remote-Version ist neuer")) + '</span>'
            '</a>'
        )

    job = load_json_file(UPDATE_STATUS, {})
    if isinstance(job, dict) and job.get("running"):
        return (
            '<a class="update-banner" href="/update">'
            '<b>Update running</b>'
            '<span>' + esc(job.get("phase", "running")) + ': ' + esc(job.get("message", "")) + '</span>'
            '</a>'
        )

    return ""



def status_details_freshness_rows(status_data, txt):
    seconds = parse_int_config_value(read_file(CONFIG), "MAX_DATA_AGE_SECONDS", 100800)
    by_name, by_id = status_component_maps(status_data, txt)
    factors = maintenance_factor_map(status_data)
    freshness = (
        by_id.get("video_freshness")
        or by_id.get("data_freshness")
        or by_name.get("Data-Freshness")
        or factors.get("video_freshness")
    )
    state = str(freshness.get("state") or freshness.get("status") or t("phrase.unknown")) if isinstance(freshness, dict) else t("phrase.unknown")
    detail = str(
        freshness.get("message")
        or freshness.get("meaning")
        or freshness.get("detail")
        or t("phrase.not_available_yet")
    ) if isinstance(freshness, dict) else t("phrase.not_available_yet")
    return [
        (
            t("system_details.effective_freshness_threshold"),
            state_badge_from_value("OK"),
            str(seconds) + "s / " + duration_hm(seconds),
        ),
        (
            t("system_details.fresh_stale_state"),
            state_badge_from_value(state),
            detail,
        ),
    ]


def status_details_runtime_rows(perf):
    fifo_enabled = int(perf.get("ULTRA_FAST_REMAINDER_QUEUE_ENABLED") or 0) == 1
    fifo_delay = str(perf.get("ULTRA_FAST_REMAINDER_QUEUE_DELAY_SECONDS") or 0) + "s"
    reply_body = int(perf.get("TELEGRAM_TRACE_REPLY_BODY") or 0) == 1
    reply_max = t("system_details.bytes_value", value=str(perf.get("TELEGRAM_TRACE_REPLY_MAX_BYTES") or 0))
    return [
        (
            t("phrase.ultra_fast_lane"),
            flag_badge(int(perf.get("ULTRA_FAST_LANE_ENABLED") or 0) == 1),
            t("system_details.delay_value", value=str(perf.get("ULTRA_FAST_LANE_DELAY_SECONDS") or 0) + "s"),
        ),
        (
            t("phrase.ultra_duplicate_protection"),
            state_badge_from_value("OK"),
            str(perf.get("ULTRA_FAST_DUPLICATE_MODE") or "-"),
        ),
        (
            t("phrase.ultra_fifo_remainder_queue"),
            flag_badge(fifo_enabled),
            t("system_details.delay_value", value=fifo_delay),
        ),
        (
            t("settings.delete_preview_with_video"),
            flag_badge(int(perf.get("DELETE_PREVIEW_WITH_VIDEO") or 0) == 1),
            "DELETE_PREVIEW_WITH_VIDEO",
        ),
        (
            t("settings.telegram_reply_body"),
            flag_badge(reply_body),
            reply_max,
        ),
    ]



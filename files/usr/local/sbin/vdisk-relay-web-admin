def render_bots(edit_var=""):
    env = parse_env()
    vars_ = available_bot_vars()
    used = used_bot_vars()
    in_use_label = t("phrase.in_use")
    actions_label = t("phrase.actions")
    edit_label = t("phrase.edit_lower")
    delete_label = t("phrase.delete")
    yes_label = t("phrase.yes")
    no_label = t("phrase.no")
    rows = []

    for var in vars_:
        val = env.get(var, "")
        in_use = yes_label if var in used else no_label

        rows.append(f"""
<tr>
  <td data-label="Bot"><b>{esc(env_base_from_var(var, "_BOT_TOKEN"))}</b><br><small>{esc(var)}</small></td>
  <td data-label="Token">{esc(mask_token(val))}</td>
  <td data-label="{esc(in_use_label)}">{esc(in_use)}</td>
  <td class="actions" data-label="{esc(actions_label)}">
    <a class="button" href="/telegram/bots?edit_bot={esc(var)}#bot-edit">{esc(edit_label)}</a>
    <form method="post" action="/bot/delete" class="inline" onsubmit="return confirm('Really delete bot?');">
      <input type="hidden" name="var" value="{esc(var)}">
      <button class="danger">{esc(delete_label)}</button>
    </form>
  </td>
</tr>
""")

    editor = bot_form(edit_var) if edit_var else ""
    add_dialog = render_add_item_dialog("bot-add-dialog", "Add bot", bot_form(None, "bot-add-form"))

    return f"""
<section class="panel" id="bots">

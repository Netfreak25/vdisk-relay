    <thead><tr><th>Bot</th><th>Token</th><th>{esc(in_use_label)}</th><th>{esc(actions_label)}</th></tr></thead>
    <tbody>{''.join(rows)}</tbody>
  </table>
  {editor}
  {add_dialog}
</section>
"""



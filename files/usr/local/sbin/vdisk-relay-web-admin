def nav_html(active):
    out = []
    for key, href, label_key, group_key in NAV_ITEMS:
        cls = "nav-item active" if key == active else "nav-item"
        icon = NAV_ICON_SVGS.get(key, "")
        out.append(
            '<a class="' + cls + '" href="' + esc(href) + '">'
            + '<span class="nav-icon" aria-hidden="true">' + icon + '</span>'
            + '<span class="nav-copy">'
            + '<span class="nav-label">' + esc(t(label_key)) + '</span>'
            + '<span class="nav-group">' + esc(t(group_key)) + '</span>'
            + '</span>'
            + '</a>'
        )
    return "".join(out)


def msg_html(message):
    if not message:
        return ""
    return '<p class="msg">' + esc(message) + '</p>'


def load_json_file(path, default=None):
    if default is None:
        default = {}
    try:
        with open(path, "r", encoding="utf-8", errors="replace") as handle:
            return json.load(handle)
    except Exception:
        return default


def json_write_atomic(path, payload, mode=0o644):
    directory = os.path.dirname(path)
    os.makedirs(directory, mode=0o755, exist_ok=True)
    fd, tmp = tempfile.mkstemp(prefix=os.path.basename(path) + ".", dir=directory)

    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            json.dump(payload, handle, ensure_ascii=False, separators=(",", ":"))
            handle.write("\n")
        os.chmod(tmp, mode)
        try:
            os.chown(tmp, 0, 0)
        except Exception:
            pass
        os.replace(tmp, path)
    finally:
        if os.path.exists(tmp):
            os.unlink(tmp)


def _normalize_video_delete_queue(data):
    if not isinstance(data, dict):
        return {"version": 1, "items": {}, "updated_at": ""}
    items = data.get("items")
    if not isinstance(items, dict):
        items = {}
    return {
        "version": data.get("version", 1),
        "items": items,
        "updated_at": data.get("updated_at", ""),
    }


def _load_video_delete_queue():
    return _normalize_video_delete_queue(load_json_file(VIDEO_DELETE_QUEUE_FILE, {"version": 1, "items": {}, "updated_at": ""}))


def _save_video_delete_queue(data):
    payload = _normalize_video_delete_queue(data)
    payload["updated_at"] = local_iso_now()
    json_write_atomic(VIDEO_DELETE_QUEUE_FILE, payload, 0o600)
    return payload


def read_video_delete_queue():
    with VIDEO_DELETE_QUEUE_LOCK:
        return _load_video_delete_queue()


def update_video_delete_queue(mutator):
    with VIDEO_DELETE_QUEUE_LOCK:
        data = _load_video_delete_queue()
        changed = mutator(data)
        if changed:
            return _save_video_delete_queue(data)
        return data


def load_video_delete_queue_status():
    data = read_video_delete_queue()
    return {
        rel: dict(item)
        for rel, item in data.get("items", {}).items()
        if isinstance(rel, str) and isinstance(item, dict)
    }


def _normalize_video_id_inputs(raw):
    if not raw:
        return []
    values = []
    for value in raw:
        if value is None:
            continue
        value = str(value).strip()
        if not value:
            continue
        if "," in value:
            parts = [part.strip() for part in value.split(",")]
        elif "|" in value:
            parts = [part.strip() for part in value.split("|")]
        else:
            parts = [value]
        for part in parts:
            if part:
                values.append(part)
    return values


def parse_video_delete_ids(form):
    if not isinstance(form, dict):
        return []
    rels = []
    rels.extend(form.get("video_ids", []))
    rels.extend(form.get("video_id", []))
    rels.extend(form.get("selected", []))
    rels.extend(form.get("ids", []))
    flat = []
    for rel in _normalize_video_id_inputs(rels):
        if rel not in flat:
            flat.append(rel)
    return flat


def queue_videos_delete_api(form):
    rels = parse_video_delete_ids(form)
    rels = [str(rel or "").strip().lstrip("/") for rel in rels if isinstance(rel, str)]
    rels = [rel for rel in rels if rel]
    queued, skipped = queue_videos_for_delete(rels)
    return {
        "ok": bool(queued),
        "queued": queued,
        "skipped": skipped,
        "queued_count": len(queued),
        "skipped_count": len(skipped),
    }


def _next_delete_retry_delay_seconds(attempt):
    attempt = max(0, int(attempt))
    delay = VIDEO_DELETE_QUEUE_MIN_RETRY_SECONDS * (2 ** min(attempt, 5))
    if delay < VIDEO_DELETE_QUEUE_MIN_RETRY_SECONDS:
        delay = VIDEO_DELETE_QUEUE_MIN_RETRY_SECONDS
    if delay > VIDEO_DELETE_QUEUE_MAX_RETRY_SECONDS:
        delay = VIDEO_DELETE_QUEUE_MAX_RETRY_SECONDS
    return delay


def _new_delete_queue_entry(rel, full_path, now_iso):
    try:
        mtime = int(os.path.getmtime(full_path))
    except Exception:
        mtime = 0
    return {
        "rel": rel,
        "status": "queued_for_delete",
        "attempts": 0,
        "queued_at": now_iso,
        "updated_at": now_iso,
        "next_attempt_at": now_iso,
        "last_error": "",
        "file_mtime": mtime,
        "file_size": int(os.path.getsize(full_path)) if os.path.isfile(full_path) else 0,
    }


def _parse_queue_retry_timestamp(value):
    if not value:
        return None
    try:
        parsed = parse_local_iso(str(value))
        if not parsed:
            return None
        return parsed.timestamp()
    except Exception:
        return None


def _is_file_deletable(rel):
    lowered = rel.lower()
    return lowered.endswith(".tmp") is False


def local_iso_now():
    return datetime.now(timezone.utc).astimezone().isoformat(timespec="seconds")


def parse_local_iso(value):
    if not value:
        return None
    try:
        parsed = datetime.fromisoformat(str(value))
    except Exception:
        return None
    if parsed.tzinfo is None:
        parsed = parsed.replace(tzinfo=datetime.now(timezone.utc).astimezone().tzinfo)
    return parsed


def seconds_since_iso(value):
    parsed = parse_local_iso(value)
    if parsed is None:
        return None
    return max(0, int((datetime.now(timezone.utc).astimezone() - parsed).total_seconds()))


def emergency_activity_info(grace_seconds=120):
    data = load_json_file(EMERGENCY_UI_ACTIVITY, {})
    if not isinstance(data, dict):
        data = {}
    age = seconds_since_iso(data.get("last_seen"))
    active = age is not None and age <= grace_seconds
    return {
        "active": active,
        "last_seen": data.get("last_seen", ""),
        "age_seconds": age,
        "grace_seconds": grace_seconds,
        "route": data.get("route", ""),
        "session_id": data.get("session_id", ""),
    }


def network_emergency_info():
    state = load_json_file(NETWORK_GUARDIAN_STATE, {})
    if not isinstance(state, dict):
        state = {}
    state_name = str(state.get("state") or "")
    config_text = read_file(CONFIG)
    heartbeat_seconds = parse_int_config_value(config_text, "NETWORK_GUARDIAN_UI_HEARTBEAT_SECONDS", 30)
    heartbeat_seconds = max(10, min(300, heartbeat_seconds))
    grace_seconds = parse_int_config_value(config_text, "NETWORK_GUARDIAN_UI_ACTIVE_GRACE_SECONDS", 120)
    grace_seconds = max(30, min(3600, grace_seconds))
    activity = emergency_activity_info(grace_seconds)
    return {
        "active": state_name in NETWORK_EMERGENCY_STATES,
        "state_name": state_name,
        "state": state,
        "activity": activity,
        "heartbeat_seconds": heartbeat_seconds,
        "grace_seconds": grace_seconds,
    }



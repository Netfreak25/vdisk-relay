    workspace = (
        '<div class="video-workspace">'
        + '<section class="panel video-list-panel video-list-panel--toolbar">'
        + '<div class="video-toolbar">'
        + search_form
        + '<div class="video-bulk-bar" role="status" aria-live="polite">'
        + '<div class="video-selected-meta"><span data-video-selected-count>0</span> <span data-video-selected-text>'
        + esc(t("bulkActions.selected"))
        + '</span></div>'
        + '<div class="video-bulk-actions">'
        + '<button type="button" class="button secondary" data-video-bulk-action="select-all-page">'
        + esc(t("bulkActions.select_page"))
        + '</button>'

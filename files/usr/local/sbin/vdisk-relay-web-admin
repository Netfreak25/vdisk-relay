        + '<div class="badge ' + cls + '">' + esc(cls.upper()) + '</div>'
        + '</section>'
        + '<section class="panel">'
        + '<div class="panel-head-inline"><h2>' + esc(t("overview.diagnosis")) + '</h2><div class="actions">' + ''.join(actions) + '</div></div>'
        + render_kv_table([
            (t("overview.cache_generated"), generated),
            (t("overview.status_source"), source_label),
            (t("overview.target_page"), tile["href"]),
        ])
        + render_status_item_table(items)
        + '</section>'
        + '<section class="panel">'

def network_guardian_status():
    config = network_guardian_config_values()
    state = load_json_file(NETWORK_GUARDIAN_STATE, {})
    if not isinstance(state, dict):
        state = {}

    enabled = int(config.get("NETWORK_GUARDIAN_ENABLED", 1) or 0) == 1
    state_name = str(state.get("state") or "phase-1-passiv")
    ap_password_set = bool(str(config.get("NETWORK_GUARDIAN_AP_PASSWORD", "")).strip())
    state_file_exists = os.path.exists(NETWORK_GUARDIAN_STATE)
    gate_exists = os.path.exists(NETWORK_GUARDIAN_ALLOW_FILE)

    if not enabled:
        badge = '<span class="badge off">disabled</span>'
        summary = "Network Guardian is disabled by configuration."
    elif not gate_exists:
        badge = '<span class="badge warn">Gate missing</span>'
        summary = "Configuration is prepared; the Guardian gate is not set yet."
    elif state_file_exists:
        cls = "ok" if state_name == "normal" else "warn"
        if state_name in ("emergency_ap", "recovery_test", "ap_blocked"):
            cls = "bad"
        badge = '<span class="badge ' + cls + '">' + esc(state_name) + '</span>'
        summary = state.get("failure_reason") or state.get("next_action") or "State-File available."
    else:
        badge = '<span class="badge warn">ready</span>'
        summary = "Guardian service is prepared; no run has been logged yet."

    return {
        "badge": badge,
        "summary": summary,
        "state": state,
        "config": config,
        "state_file_exists": state_file_exists,
        "gate_exists": gate_exists,
        "ap_password_set": ap_password_set,
    }


def render_network_guardian_panel():
    info = network_guardian_status()
    state = info["state"]
    config = info["config"]
    ap_info = state.get("ap", {})
    if not isinstance(ap_info, dict):
        ap_info = {}
    enabled_label = "yes" if int(config.get("NETWORK_GUARDIAN_ENABLED", 1) or 0) == 1 else "no"
    password_label = "set" if info["ap_password_set"] else "still missing"
    gate_enabled = info["gate_exists"]
    gate_target = "0" if gate_enabled else "1"
    gate_label = "Disarm" if gate_enabled else "Arm"
    gate_button_class = ' class="danger"' if gate_enabled else ""
    gate_confirm = (
        ' data-confirm-message="Really disarm Network Guardian?" data-danger-action="1"'
        if gate_enabled
        else ""
    )
    gate_form = (
        '<form method="post" action="/wifi/guardian-gate"' + gate_confirm + '>'
        '<input type="hidden" name="enabled" value="' + gate_target + '">'
        '<button type="submit"' + gate_button_class + ' data-icon="power">' + gate_label + '</button>'
        '</form>'
    )
    rows = [
        ("State", state.get("state", "ready")),
        ("Phase", str(state.get("phase", 3))),
        ("Latest check", state.get("last_check_at", "-")),
        ("Latest OK time", state.get("last_ok_at", "-")),
        ("Error class", state.get("failure_class", "-")),
        ("Error reason", state.get("failure_reason", "-")),
        ("Error counter", str(state.get("failure_count", 0))),
        ("Next action", state.get("next_action", "no Guardian run yet")),
        ("Next action not before", state.get("next_action_not_before", "-")),
        ("AP started", state.get("ap_started_at", "-")),
        ("Recovery due", state.get("recovery_due_at", "-")),
        ("AP cycles", str(state.get("ap_cycle_count", 0))),
        ("Normal Wi-Fi profile", state.get("normal_connection", "-")),
        ("Guardian enabled", enabled_label),
        ("Gate-File", "available" if info["gate_exists"] else "still missing"),
        ("State-File", "available" if info["state_file_exists"] else "still missing"),
        ("Check interval", format_duration(config.get("NETWORK_GUARDIAN_CHECK_INTERVAL_SECONDS", 300))),
        ("Errors before AP", str(config.get("NETWORK_GUARDIAN_FAILS_BEFORE_AP", 3))),
        ("AP minimum runtime", format_duration(config.get("NETWORK_GUARDIAN_AP_MIN_SECONDS", 600))),
        ("UI activity window", format_duration(config.get("NETWORK_GUARDIAN_UI_ACTIVE_GRACE_SECONDS", 120))),
        ("Auto-Reboot", "prepared (switch on)" if int(config.get("NETWORK_GUARDIAN_AUTO_REBOOT_ENABLED", 0) or 0) == 1 else "off"),
        ("AP-SSID-Prefix", config.get("NETWORK_GUARDIAN_AP_SSID_PREFIX", "VDiskRelay-Setup")),
        ("AP SSID active", ap_info.get("ssid", state.get("config", {}).get("ap_ssid", "-"))),
        ("AP-IPv4", config.get("NETWORK_GUARDIAN_AP_IPV4", "10.254.77.1/24")),
        ("AP password", password_label),
    ]
    return (
        '<section class="panel wifi-guardian-panel">'
        '<div class="panel-head-inline"><h2>Network Guardian</h2><div class="status-pills">'
        + info["badge"]
        + gate_form
        + '<button type="button" class="secondary" data-open-dialog="network-guardian-edit">Edit</button>'
        + '</div></div>'
        + '<p class="muted">' + esc(info["summary"]) + '</p>'
        + render_kv_table(rows)
        + network_guardian_config_dialog(config)
        + '</section>'
    )


def render_emergency_status_panel(info=None):
    info = info or network_emergency_info()
    if not info.get("active"):
        return ""
    state = info.get("state", {})
    if not isinstance(state, dict):
        state = {}
    activity = info.get("activity", {})
    if not isinstance(activity, dict):
        activity = {}
    state_config = state.get("config", {})
    if not isinstance(state_config, dict):
        state_config = {}
    ap_info = state.get("ap", {})
    if not isinstance(ap_info, dict):
        ap_info = {}
    active_label = "yes" if activity.get("active") else "no"
    activity_age = activity.get("age_seconds")
    activity_detail = "-" if activity_age is None else str(activity_age) + "s"
    rows = [
        ("State", state.get("state", info.get("state_name", "emergency_ap"))),
        ("AP-SSID", ap_info.get("ssid", state_config.get("ap_ssid", "-"))),
        ("AP-IP", ap_info.get("ipv4", state_config.get("ap_ipv4", "-"))),
        ("Error reason", state.get("failure_reason", "-")),
        ("Latest check", state.get("last_check_at", "-")),
        ("Recovery not before", state.get("recovery_due_at", "-")),
        ("Operator active", active_label),
        ("Latest heartbeat", activity.get("last_seen", "-")),
        ("Heartbeat age", activity_detail),
        ("Captive Portal", "HTTP endpoints active"),
    ]
    actions = (
        '<div class="actions">'
        '<form method="post" action="/emergency/hold" class="inline">'
        '<button type="submit" class="secondary" data-icon="power">Keep AP active</button>'
        '</form>'
        '<form method="post" action="/emergency/test-normal" class="inline" onsubmit="return confirm(\'Check normal mode now? The AP connection may briefly drop.\');">'
        '<button type="submit">Check normal mode</button>'
        '</form>'
        '</div>'
    )
    return (
        '<section class="panel emergency-panel">'
        '<div class="panel-head-inline"><h2>Emergency Wi-Fi</h2><span class="badge bad">AP mode</span></div>'
        '<p class="muted">This view remains limited to Wi-Fi configuration while the emergency AP is active.</p>'
        + render_kv_table(rows)
        + actions
        + '</section>'
    )


def render_wifi_settings_page(query=None, message=""):
    query = query or {}
    message = message or query.get("msg", [""])[0]
    force_refresh = query.get("refresh", ["0"])[0] == "1"
    show_scan = query.get("scan", ["0"])[0] == "1"
    emergency_info = network_emergency_info()
    status = wifi_status(force_refresh=force_refresh)
    cache = status.get("cache", {})
    cache_age = cache.get("age_seconds", 0)
    cache_state = "stale" if cache.get("stale") else "fresh"
    cache_source = "Live" if cache.get("source") == "live" else "Cache"
    cache_label = (
        cache_source
        + " / "
        + cache_state
        + " / "
        + str(cache_age)
        + "s alt / "
        + (cache.get("generated_at") or "-")
    )
    device_rows = []
    for item in status["devices"]:
        device_rows.append(
            "<tr>"
            '<th data-label="Device">' + esc(item.get("device", "")) + "</th>"
            '<td data-label="Type">' + esc(item.get("type", "")) + "</td>"
            '<td data-label="State">' + esc(item.get("state", "")) + "</td>"
            '<td data-label="Connection">' + esc(item.get("connection", "")) + "</td>"
            "</tr>"
        )
    if not device_rows:
        device_rows.append('<tr><td colspan="4">No Wi-Fi device through NetworkManager.</td></tr>')

    detail = status["device_detail"]
    signal = status.get("signal", {})
    current_connection = detail.get("GENERAL.CONNECTION", "")
    signal_percent = signal.get("percent", "")
    signal_percent_number = wifi_signal_percent_value(signal_percent)
    signal_width = str(signal_percent_number if signal_percent_number is not None else 0)
    signal_quality_class = wifi_signal_quality_class(signal_percent_number)
    signal_label = (signal_percent + " %") if signal_percent else "-"
    signal_detail = ", ".join(
        part for part in [
            signal.get("ssid", ""),
            ("Kanal " + signal.get("channel", "")) if signal.get("channel") else "",
            signal.get("rate", ""),
            signal.get("bars", ""),
        ]
        if part
    ) or "-"
    ip_label = detail.get("IP4.ADDRESS[1]", detail.get("IP4.ADDRESS", "-"))
    gateway_label = detail.get("IP4.GATEWAY", "-")
    connected = bool(current_connection and current_connection not in ("--", "-"))
    connection_badge = '<span class="badge ok">connected</span>' if connected else '<span class="badge warn">not connected</span>'
    cache_badge_class = "warn" if cache.get("stale") else "ok"
    cache_badge = '<span class="badge ' + cache_badge_class + '">' + esc(cache_state) + '</span>'
    error_text = status["error"] or signal.get("error") or ""
    error_html = (
        '<section class="panel"><p class="bad"><b>Wi-Fi-Error:</b> ' + esc(error_text) + '</p></section>'
        if error_text
        else ""
    )
    technical_details = add_disclosure(
        "Technische Details",
        '<section class="subpanel">'
        '<h3>NetworkManager</h3>'
        + render_kv_table([
            ("nmcli", "available" if status["nmcli"] else "missing"),
            ("NetworkManager", status["networkmanager"] + " / " + status["networkmanager_enabled"]),
            ("Cache", cache_label),
            ("Standard-Interface", WIFI_DEFAULT_IFACE),
            ("Active connection", current_connection or "-"),
            ("Signal strength", signal_label),
            ("Signaldetails", signal_detail),
            ("IPv4", ip_label),
            ("Gateway", gateway_label),
        ])
        + '</section>'
        + '<section class="subpanel">'
        + '<h3>Wi-Fi-Devicee</h3>'
        + '<table class="responsive-table"><thead><tr><th>Device</th><th>Type</th><th>State</th><th>Connection</th></tr></thead><tbody>'
        + ''.join(device_rows)
        + '</tbody></table>'
        + '</section>',
        "wifi-technical",
    )
    wifi_tabs = "" if emergency_info.get("active") else settings_tabs("wifi")
    wifi_technical_details = "" if emergency_info.get("active") else technical_details
    body = (
        msg_html(message)
        + wifi_tabs
        + render_emergency_status_panel(emergency_info)
        + '<section class="hero-status wifi-status">'
        + '<div><div class="status-title">Connection</div>'
        + '<div class="status-value">' + esc(current_connection or "not connected") + '</div>'
        + '<p class="muted">' + connection_badge + ' ' + esc(WIFI_DEFAULT_IFACE) + '</p></div>'
        + '<div class="wifi-signal-card"><div class="status-title">Signal</div>'
        + '<div class="status-value">' + esc(signal_label) + '</div>'
        + '<div class="wifi-signal-bar ' + esc(signal_quality_class) + '" role="img" aria-label="Signal strength ' + esc(signal_label) + '">'
        + '<span class="wifi-signal-fill" style="width:' + esc(signal_width) + '%"></span>'
        + '</div>'
        + '<p class="muted">' + esc(signal_detail) + '</p></div>'
        + '<div><div class="status-title">Adresse</div>'
        + '<div class="status-value">' + esc(ip_label) + '</div>'
        + '<p class="muted">Gateway ' + esc(gateway_label) + '</p></div>'
        + '<div><div class="status-title">Cache</div>'
        + '<div>' + cache_badge + '</div>'
        + '<p class="muted">' + esc(str(cache_age) + "s alt") + '</p></div>'
        + '</section>'
        + render_network_guardian_panel()
        + error_html
        + '<section class="panel wifi-actions-panel">'
        + '<div class="actions wifi-actions">'
        + '<form method="post" action="/wifi/connect" class="inline" onsubmit="return confirm(\'Reconnect Wi-Fi?\');">'
        + '<button type="submit" data-icon="refresh">Connect Wi-Fi</button>'
        + '</form>'
        + '<a class="button secondary" href="/wifi?refresh=1">Wi-Fi-Cache aktualisieren</a>'
        + '<form method="post" action="/wifi/scan" class="inline" onsubmit="return confirm(\'Start Wi-Fi scan? The connection may briefly become unstable.\');">'
        + '<button type="submit" class="secondary" data-icon="search">Scan Wi-Fi networks</button>'
        + '</form>'
        + '</div>'
        + '</section>'
        + render_wifi_scan_panel(show_scan)
        + wifi_technical_details
        + '<section class="panel">'
        + '<div class="panel-head-inline"><h2>Profile</h2><button type="button" class="secondary" data-open-dialog="wifi-profile-add">Add profile</button></div>'
        + '<table class="responsive-table wifi-profile-table"><thead><tr><th>Profile</th><th>SSID</th><th>IPv4</th><th>Autoconnect</th><th>Priority</th><th>Device</th><th>Powersave</th><th>Actions</th></tr></thead><tbody>'
        + render_wifi_profile_rows(status["profiles"], current_connection)
        + '</tbody></table>'
        + render_wifi_add_dialog()
        + render_wifi_profile_dialogs(status["profiles"])
        + '</section>'
    )
    return html_page("Wi-Fi", body, active="settings", subtitle="NetworkManager profiles and lightweight Wi-Fi actions.")


def render_general_settings_page(query=None, message="", section="general"):
    query = query or {}
    message = message or query.get("msg", [""])[0]
    section = (query.get("section", [section])[0] or section or "general").strip().lower()
    if section not in ("general", "display", "timeline", "performance", "previews", "telegram"):
        section = "general"
    seconds = parse_int_config_value(read_file(CONFIG), "MAX_DATA_AGE_SECONDS", 100800)
    display_timezone = web_display_timezone_name()
    saver_minutes = screensaver_idle_minutes()
    saver_mode = screensaver_mode()
    perf = performance_debug_config_values()
    if section == "display":
        return_to = "/settings/display#language-selection"
    elif section == "general":
        return_to = "/general"
    else:
        return_to = "/general"
    hours = max(1, (seconds + 3599) // 3600)
    section_title = t("settings.tab_" + section)
    section_subtitle = {
        "general": t("settings.subtitle_general"),
        "display": t("settings.subtitle_display"),
        "timeline": t("settings.subtitle_timeline"),
        "performance": t("settings.subtitle_performance"),
        "previews": t("settings.subtitle_previews"),
        "telegram": t("settings.subtitle_telegram"),
    }.get(section, "")
    section_extra = ""
    if section == "telegram":
        section_extra = telegram_tabs("settings") + render_telegram_cluster_panel()
    elif section == "previews":
        section_extra = (
            '<section class="panel">'
            '<h2>' + esc(t("previews_cluster.title")) + '</h2>'
            + render_link_card_grid([
                ("/previews", t("previews_cluster.cache_details"), t("previews_cluster.cache_details_hint")),
            ])
            + '</section>'
        )

    body = (
        msg_html(message)
        + settings_tabs(section)
        + settings_context(section_title)
        + section_extra
        + render_general_settings_form(hours, seconds, display_timezone, saver_minutes, saver_mode, perf, section)
        + (language_settings_panel_html(return_to) if section == "display" else "")
    )
    return html_page(section_title, body, active="settings", subtitle=section_subtitle)


def render_archive_settings_page(query=None, message=""):
    query = query or {}
    message = message or query.get("msg", [""])[0]
    edit = query.get("edit", ["0"])[0] == "1"
    cfg = archive_config()
    pass_status = archive_password_status(cfg["password_file"])
    configured = bool(cfg["target"] and pass_status["exists"] and pass_status["readable"])
    timer_active = systemctl_active(ARCHIVE_TIMER_UNIT)
    timer_enabled = systemctl_enabled(ARCHIVE_TIMER_UNIT)
    service_active = systemctl_active(ARCHIVE_SERVICE_UNIT)
    archive_result = maintenance_result_info(
        MAINT_ARCHIVE_RESULT,
        "No manual archive run has been executed via the WebUI yet.",
    )
    show_form = edit or not configured
    password_required = "required" if not pass_status["exists"] else ""
    password_hint = "leave empty to keep the existing password" if pass_status["exists"] else "rsync-daemon password"

    config_form = ""
    if show_form:
        config_form = (
            '<section class="panel" id="archive-edit">'
            '<h2>Archive edit</h2>'
            '<form method="post" action="/archive/save" class="form-grid">'
            + form_field(
                "Archive destination",
                '<input name="target" value="' + esc(cfg["target"]) + '" placeholder="user@host::module/path" required>',
                "Destination for rsync daemon. Source is always DATA_ROOT locally, not the USB image.",
            )
            + form_field(
                "Password file",
                '<input name="password_file" value="' + esc(cfg["password_file"]) + '" required>',
                "Local path for the rsync-daemon password.",
            )
            + form_field(
                "Password " + ("(empty = keep)" if pass_status["exists"] else ""),
                '<input type="password" name="password" value="" autocomplete="off" placeholder="' + esc(password_hint) + '" ' + password_required + '>',
                "Stored only locally in the password file.",
            )
            + form_field(
                "Max. runtime seconds",
                '<input type="number" name="max_seconds" value="' + esc(cfg["max_seconds"]) + '" min="30" max="86400" required>',
                "Maximum duration of an archive run.",
            )
            + form_field(
                "Connect timeout seconds",
                '<input type="number" name="contimeout" value="' + esc(cfg["contimeout"]) + '" min="1" max="300" required>',
                "Connection setup timeout.",
            )
            + form_field(
                "I/O timeout seconds",
                '<input type="number" name="timeout" value="' + esc(cfg["timeout"]) + '" min="1" max="3600" required>',
                "Timeout for rsync data transfer.",
            )
            + '<button type="submit">Save archive</button>'
            + '</form>'
            + '</section>'
        )

    enable_action = "/archive/disable" if cfg["enabled"] else "/archive/enable"
    enable_label = "Disable archive" if cfg["enabled"] else "Enable archive"
    enable_disabled = "" if cfg["enabled"] or configured else " disabled"

    body = (
        msg_html(message)
        + settings_tabs("archive")
        + '<section class="panel">'
        + '<h2>State</h2>'
        + render_kv_table([
            ("Archive function", "rsync from DATA_ROOT to the external archive destination"),
            ("Archive gate", "active" if cfg["enabled"] else "inactive"),
            ("Target", cfg["target"] or "-"),
            ("Password file", cfg["password_file"]),
            ("Password", "available" if pass_status["exists"] else "missing"),
            ("Password readable", "yes" if pass_status["readable"] else "no"),
            ("Timer", timer_active + " / " + timer_enabled),
            ("Service", service_active),
            ("Max. runtime", duration_hm(cfg["max_seconds"])),
            ("Connect/I/O Timeout", str(cfg["contimeout"]) + "s / " + str(cfg["timeout"]) + "s"),
        ])
        + '<div class="actions">'
        + '<a class="button secondary" href="/archive?edit=1#archive-edit">Edit</a>'
        + '<form method="post" action="' + enable_action + '" class="inline" onsubmit="return confirm(\'' + enable_label + '?\');">'
        + '<button type="submit" class="secondary"' + enable_disabled + '>' + enable_label + '</button>'
        + '</form>'
        + '<a class="button secondary" href="/service-journal?u=' + quote(ARCHIVE_SERVICE_UNIT) + '">Journal</a>'
        + '</div>'
        + '<p class="muted">Disable archive removes only the archive gate and stops the archive timer. Local copying from the image to DATA_ROOT remains unchanged.</p>'
        + '</section>'
        + '<section class="panel">'
        + '<h2>' + esc(t("overview.latest_archive_run")) + '</h2>'
        + render_maintenance_result_panel(t("overview.archive_status_log"), archive_result)
        + '<div class="actions"><a class="button secondary" href="/maintenance/actions">' + esc(t("overview.action.archive_run")) + '</a></div>'
        + '</section>'
        + config_form
    )
    return html_page("Archive", body, active="settings", subtitle="External rsync archive for locally stored data.")



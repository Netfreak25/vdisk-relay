  function actionPath(form) {
    try {
      return new URL(form.getAttribute('action') || window.location.href, window.location.href).pathname;
    } catch (error) {
      return '';
    }
  }

  function enhanceAyesxForms() {
    document.querySelectorAll('form[method="post"], form[method="POST"]').forEach(function(form){
      if (ayesxActionPaths[actionPath(form)]) {
        form.dataset.ayesx = '1';
      }
    });
  }

  function buttonText(button) {
    if (button.dataset && button.dataset.actionLabel) {
      return button.dataset.actionLabel;
    }
    return (button.textContent || '').replace(/\\s+/g, ' ').trim();
  }

  function iconFor(text) {
    for (var i = 0; i < buttonIcons.length; i += 1) {
      if (text.indexOf(buttonIcons[i][0]) !== -1) {
        return buttonIcons[i][1];
      }
    }
    return '';
  }

  function enhanceActionButtons(root) {
    root.querySelectorAll('button, .button').forEach(function(button){
      if (button.classList.contains('has-action-icon')) { return; }
      var text = buttonText(button);
      var icon = button.getAttribute('data-icon') || iconFor(text);
      if (!icon || !iconGlyphs[icon]) { return; }
      button.classList.add('has-action-icon');
      button.dataset.actionLabel = text;
      if (text === iconGlyphs[icon] || text === 'â†»') {
        button.setAttribute('aria-label', button.getAttribute('aria-label') || titleFromIcon(icon));
        button.innerHTML = '<span class="btn-icon" aria-hidden="true">' + iconGlyphs[icon] + '</span>';
        return;
      }
      button.innerHTML = '<span class="btn-icon" aria-hidden="true">' + iconGlyphs[icon] + '</span><span class="btn-text">' + escapeHtml(text) + '</span>';
    });
  }

  function titleFromIcon(icon) {
    var titles = {
      refresh: text('js.icon_refresh', 'Refresh'),
      restart: text('js.icon_restart', 'Restart'),
      delete: text('js.icon_delete', 'Delete'),
      close: text('js.icon_close', 'Close'),
      journal: text('js.icon_journal', 'Journal')
    };
    return titles[icon] || text('js.icon_action', 'Action');
  }

  function text(key, fallback) {
    return Object.prototype.hasOwnProperty.call(i18n, key) ? i18n[key] : fallback;
  }

  function escapeHtml(value) {
    return String(value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#039;');
  }

  function toastStack() {
    var stack = document.querySelector('.toast-stack');
    if (!stack) {
      stack = document.createElement('div');
      stack.className = 'toast-stack';
      stack.setAttribute('aria-live', 'polite');
      stack.setAttribute('aria-atomic', 'true');
      document.body.appendChild(stack);
    }
    return stack;
  }

  function showToast(message, kind) {
    var toast = document.createElement('div');
    toast.className = 'toast ' + (kind === 'bad' ? 'bad' : 'ok');
    toast.textContent = message || text('js.action_done', 'Action completed');
    toastStack().appendChild(toast);
    window.setTimeout(function(){ toast.classList.add('visible'); }, 20);
    window.setTimeout(function(){
      toast.classList.remove('visible');
      window.setTimeout(function(){ toast.remove(); }, 220);
    }, 2800);
  }

  function showReloadRequired(payload) {
    if (appReloadBannerShown) { return; }
    appReloadBannerShown = true;
    var frame = document.querySelector('.page-frame') || document.body;
    var banner = document.createElement('div');
    banner.className = 'reload-required';
    banner.setAttribute('role', 'status');
    banner.innerHTML = '<div><b>' + escapeHtml(text('js.reload_title', 'Web interface was updated')) + '</b><span>' + escapeHtml(text('js.reload_text', 'This open view is using an old version. Please reload.')) + '</span></div><button type="button">' + escapeHtml(text('js.reload_button', 'Reload')) + '</button>';
    var button = banner.querySelector('button');
    if (button) {
      button.addEventListener('click', function(){
        window.location.reload();
      });
    }
    var first = frame.firstElementChild;
    if (first) {
      frame.insertBefore(banner, first);
    } else {
      frame.appendChild(banner);
    }
    enhanceActionButtons(banner);
    showToast(text('js.reload_toast', 'New WebUI version detected. Please reload.'), 'ok');
  }

  function initDialogs(root) {
    root.querySelectorAll('[data-open-dialog]').forEach(function(trigger){
      if (trigger.dataset.dialogBound === '1') { return; }
      trigger.dataset.dialogBound = '1';
      trigger.addEventListener('click', function(){
        var dialog = document.getElementById(trigger.getAttribute('data-open-dialog') || '');
        if (!dialog) { return; }
        if (dialog.showModal) {
          dialog.showModal();
        } else {
          dialog.setAttribute('open', 'open');
        }
        var field = dialog.querySelector('input:not([type="hidden"]):not([readonly]), select, button');
        if (field && field.focus) {
          window.setTimeout(function(){ field.focus(); }, 30);
        }
      });
    });
    root.querySelectorAll('[data-dialog-close]').forEach(function(trigger){
      if (trigger.dataset.dialogCloseBound === '1') { return; }
      trigger.dataset.dialogCloseBound = '1';
      trigger.addEventListener('click', function(){
        var dialog = trigger.closest('dialog');
        if (!dialog) { return; }
        if (dialog.close) {
          dialog.close();
        } else {
          dialog.removeAttribute('open');
        }
      });
    });
    root.querySelectorAll('dialog.modal-dialog').forEach(function(dialog){
      if (dialog.dataset.backdropBound === '1') { return; }
      dialog.dataset.backdropBound = '1';
      dialog.addEventListener('click', function(event){
        if (event.target !== dialog) { return; }
        if (dialog.close) {
          dialog.close();
        } else {
          dialog.removeAttribute('open');
        }
      });
    });
  }

  function checkAppVersion() {
    if (!appBuild || !window.fetch) { return; }
    fetch('/app-version.json?_=' + Date.now(), {
      cache: 'no-store',
      headers: {
        'Accept': 'application/json',
        'X-Requested-With': 'fetch'
      }
    }).then(function(response){
      if (!response.ok) { return null; }
      return response.json();
    }).then(function(payload){
      if (!payload || !payload.build) { return; }
      if (payload.build !== appBuild) {
        showReloadRequired(payload);
      }
    }).catch(function(){});
  }

  function initAppVersionCheck() {
    if (!appBuild || !window.fetch) { return; }
    window.setTimeout(checkAppVersion, 8000);
    window.setInterval(checkAppVersion, appVersionCheckIntervalMs);
    window.addEventListener('focus', checkAppVersion);
    document.addEventListener('visibilitychange', function(){
      if (!document.hidden) {
        checkAppVersion();
      }
    });
  }

  function emergencySessionId() {
    var key = 'blinkSyncEmergencySession';
    try {
      var existing = window.localStorage ? window.localStorage.getItem(key) : '';
      if (existing) { return existing; }
      var generated = 's' + Math.random().toString(36).slice(2) + Date.now().toString(36);
      if (window.localStorage) {
        window.localStorage.setItem(key, generated);
      }
      return generated;
    } catch (error) {
      return 'volatile-' + Date.now().toString(36);
    }
  }

  function sendEmergencyHeartbeat(source) {
    if (!document.body || document.body.dataset.emergencyMode !== '1' || !window.fetch) { return; }
    var data = new URLSearchParams();
    data.set('route', window.location.pathname + window.location.search);
    data.set('session_id', emergencySessionId());
    data.set('source', source || 'heartbeat');
    fetch('/emergency/heartbeat', {
      method: 'POST',
      body: data,
      keepalive: true,
      headers: {
        'Accept': 'application/json',
        'X-Requested-With': 'fetch'
      }
    }).catch(function(){});
  }

  function initEmergencyHeartbeat() {
    if (!document.body || document.body.dataset.emergencyMode !== '1') { return; }
    var heartbeatMs = parseInt(document.body.dataset.emergencyHeartbeatMs || '30000', 10);
    if (!heartbeatMs || heartbeatMs < 10000) {
      heartbeatMs = 30000;
    }
    sendEmergencyHeartbeat('load');
    window.setInterval(function(){
      if (document.hidden) { return; }
      sendEmergencyHeartbeat('interval');
    }, heartbeatMs);
    window.addEventListener('focus', function(){
      sendEmergencyHeartbeat('focus');
    });
    document.addEventListener('visibilitychange', function(){
      if (!document.hidden) {
        sendEmergencyHeartbeat('visible');
      }
    });
  }

  function initScreensaver() {
    if (!screensaverIdleMs || screensaverIdleMs < 60000 || !window.fetch || !window.matchMedia) { return; }
    var desktopQuery = window.matchMedia('(min-width: 981px) and (hover: hover) and (pointer: fine)');
    if (!desktopQuery.matches) { return; }
    if (screensaverMode === 'legacy') {
      initLegacyScreensaver(desktopQuery);
      return;
    }
    initFloatingPhotoWallScreensaver(desktopQuery);
  }

  function initLegacyScreensaver(desktopQuery) {
    var timer = null;
    var overlay = null;
    var previews = [];
    var loaded = false;
    var clockTimer = null;

    function ensureOverlay() {
      if (overlay) { return overlay; }
      overlay = document.createElement('div');
      overlay.className = 'screensaver-overlay';
      overlay.setAttribute('aria-hidden', 'true');
      overlay.innerHTML = '<div class="screensaver-meta"><b>VDisk Relay</b><span>' + escapeHtml(text('js.preview_idle_mode', 'Preview idle mode')) + '</span></div><div class="screensaver-clock"></div><div class="screensaver-stage"></div>';
      overlay.addEventListener('click', resetScreensaverTimer);
      document.body.appendChild(overlay);
      return overlay;
    }

    function updateScreensaverClock() {
      if (!overlay) { return; }
      var clock = overlay.querySelector('.screensaver-clock');
      if (!clock) { return; }
      clock.textContent = new Date().toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit' });
    }

    function renderScreensaverTiles() {
      ensureOverlay();
      var stage = overlay.querySelector('.screensaver-stage');
      if (!stage) { return; }
      stage.innerHTML = '';
      if (!previews.length) {
        var empty = document.createElement('div');
        empty.className = 'screensaver-empty';
        empty.textContent = 'VDisk Relay';
        stage.appendChild(empty);
        return;
      }
      previews.slice(0, 18).forEach(function(item, index){
        var tile = document.createElement('figure');
        tile.className = 'screensaver-tile';
        tile.style.left = (4 + ((index * 23) % 82)) + 'vw';
        tile.style.top = (11 + ((index * 17) % 70)) + 'vh';
        tile.style.animationDuration = (26 + (index % 7) * 4) + 's';
        tile.style.animationDelay = '-' + ((index * 3) % 24) + 's';
        tile.innerHTML = '<img alt="" loading="lazy"><figcaption></figcaption>';
        var img = tile.querySelector('img');
        var caption = tile.querySelector('figcaption');
        img.src = item.url;
        caption.textContent = (item.title || 'File') + ' ? ' + (item.label || '');
        stage.appendChild(tile);
      });
    }

    function loadScreensaverPreviews() {
      if (loaded) {
        renderScreensaverTiles();
        return;
      }
      loaded = true;
      fetch('/screensaver-previews.json?_=' + Date.now(), {
        cache: 'no-store',
        headers: {
          'Accept': 'application/json',
          'X-Requested-With': 'fetch'
        }
      }).then(function(response){
        if (!response.ok) { return null; }
        return response.json();
      }).then(function(payload){
        previews = payload && Array.isArray(payload.items) ? payload.items : [];
        renderScreensaverTiles();
      }).catch(function(){
        previews = [];
        renderScreensaverTiles();
      });
    }

    function showScreensaver() {
      if (document.hidden || !desktopQuery.matches) {
        resetScreensaverTimer();
        return;
      }
      ensureOverlay();
      updateScreensaverClock();
      clockTimer = window.setInterval(updateScreensaverClock, 30000);
      overlay.classList.add('is-active');
      document.body.classList.add('screensaver-active');
      loadScreensaverPreviews();
    }

    function hideScreensaver() {
      if (!overlay || !overlay.classList.contains('is-active')) { return; }
      overlay.classList.remove('is-active');
      document.body.classList.remove('screensaver-active');
      if (clockTimer) {
        window.clearInterval(clockTimer);
        clockTimer = null;
      }
    }

    function resetScreensaverTimer() {
      hideScreensaver();
      window.clearTimeout(timer);
      if (!desktopQuery.matches || document.hidden) { return; }
      timer = window.setTimeout(showScreensaver, screensaverIdleMs);
    }

    ['mousemove', 'mousedown', 'keydown', 'wheel', 'scroll', 'pointerdown'].forEach(function(name){
      document.addEventListener(name, resetScreensaverTimer);
    });
    document.addEventListener('visibilitychange', resetScreensaverTimer);
    resetScreensaverTimer();
  }

  function initFloatingPhotoWallScreensaver(desktopQuery) {
    var timer = null;
    var rafId = 0;
    var overlay = null;
    var loaded = false;
    var stage = null;
    var previews = [];
    var sprites = [];
    var lastThumbUrl = "";
    var focusIndex = -1;
    var focusUntil = 0;
    var nextFocusAt = 0;
    var lastFrame = 0;
    var active = false;
    var viewport = { w: 0, h: 0 };
    var fallbackShown = false;
    var lastResizeW = 0;
    var lastResizeH = 0;

    function clampFocusIndex(nextIndex) {
      if (!sprites.length) {
        return -1;
      }
      if (sprites.length === 1) {
        return 0;
      }
      if (nextIndex >= 0 && nextIndex !== focusIndex) {
        return nextIndex;
      }
      return (nextIndex + 1) % sprites.length;
    }

    function ensureOverlay() {
      if (overlay) { return overlay; }
      overlay = document.createElement('div');
      overlay.className = 'screensaver-overlay';
      overlay.setAttribute('aria-hidden', 'true');
      overlay.innerHTML = '<div class="screensaver-meta"><b>VDisk Relay</b><span>Floating Photo Wall</span></div><div class="screensaver-stage"></div>';
      overlay.addEventListener('pointerdown', resetScreensaverTimer);
      document.body.appendChild(overlay);
      return overlay;
    }

    function viewportSize() {
      viewport.w = Math.max(1024, window.innerWidth || 1024);
      viewport.h = Math.max(600, window.innerHeight || 600);
      return viewport;
    }

    function scheduleNextFocus(now) {
      nextFocusAt = now + 8000 + Math.random() * 7000;
      focusUntil = 0;
    }

    function setFocus(now) {
      if (!sprites.length) {
        focusIndex = -1;
        focusUntil = 0;
        return;
      }
      var nextIndex = Math.floor(Math.random() * sprites.length);
      focusIndex = clampFocusIndex(nextIndex);
      nextFocusAt = now + 8000 + Math.random() * 7000;
      focusUntil = now + 3000 + Math.random() * 2000;
      sprites.forEach(function(sprite, index){
        var focused = index === focusIndex && now < focusUntil;
        sprite.el.classList.toggle('is-focus', focused);
      });
    }

    function updateFocusState(now) {
      if (!active) { return; }
      if (focusIndex === -1) {
        setFocus(now);
        return;
      }
      if (now >= focusUntil) {
        if (sprites[focusIndex] && sprites[focusIndex].el) {
          sprites[focusIndex].el.classList.remove('is-focus');
        }
        focusIndex = -1;
      }
      if (now >= nextFocusAt) {
        setFocus(now);
      }
    }

    function makeSprite(item, index) {
      if (!item || !item.url) { return null; }
      if (index > 0 && item.url === lastThumbUrl && previews.length > 1) {
        return null;
      }
      var sprite = {};
      var angle = (Math.random() * Math.PI * 2);
      var speed = 0.04 + (index % 4) * 0.014 + (Math.random() * 0.018);
      var direction = index % 2 ? 1 : -1;
      var speedX = Math.cos(angle) * speed * direction;
      var speedY = Math.sin(angle) * speed * 0.18;
      if (!speedX && !speedY) {
        speedX = 0.06 * direction;
      }
      if (Math.abs(speedX) < 0.022) {
        speedX = 0.022 * direction;
      }
      var width = 160 + Math.random() * 180;
      var figure = document.createElement('figure');
      var img = document.createElement('img');
      var caption = document.createElement('figcaption');
      var isPolaroid = Math.random() < 0.45;

      figure.className = 'screensaver-photo';
      if (isPolaroid) {
        figure.classList.add('is-polaroid');
      }
      figure.style.width = Math.round(width) + 'px';
      figure.style.setProperty('--start-tilt', (Math.random() * 14 - 7).toFixed(2) + 'deg');
      figure.style.setProperty('--base-scale', (0.68 + Math.random() * 0.38).toFixed(3));
      figure.style.setProperty('--focus-scale', (1.12 + Math.random() * 0.5).toFixed(3));
      figure.style.setProperty('--parallax', (0.75 + Math.random() * 0.35).toFixed(3));
      img.alt = '';
      img.loading = 'lazy';
      caption.textContent = (item.title || 'File') + ' - ' + (item.label || '');

      figure.appendChild(img);
      figure.appendChild(caption);

      viewportSize();
      sprite.x = Math.random() * viewport.w;
      sprite.y = Math.random() * viewport.h;
      figure.style.left = '0px';
      figure.style.top = '0px';
      sprite.el = figure;
      sprite.img = img;
      sprite.url = item.url;
      sprite.vx = speedX * (viewport.w / 1000);
      sprite.vy = speedY * (viewport.h / 700);
      sprite.floatAmp = 7 + Math.random() * 9;
      sprite.floatSpeed = 0.16 + Math.random() * 0.38;
      sprite.rotateBase = parseFloat(figure.style.getPropertyValue('--start-tilt'));
      sprite.focusBase = 1;
      sprite.focusScale = parseFloat(figure.style.getPropertyValue('--focus-scale')) || 1.28;
      sprite.seed = Math.random() * Math.PI * 2;
      sprite.id = Math.random() + '-' + index;
      sprite.loaded = false;
      sprite.visible = true;
      sprite.fade = 0.35 + Math.random() * 0.45;

      img.addEventListener('load', function(){
        sprite.loaded = true;
      }, { passive: true });
      img.addEventListener('error', function(){
        sprite.visible = false;
        sprite.loaded = false;
        if (sprite.el.parentNode) {
          sprite.el.parentNode.removeChild(sprite.el);
        }
        if (window.console && window.console.debug) {
          console.debug('Screen saver: preview could not be loaded', sprite.url);
        }
      }, { passive: true });
      img.src = item.url;
      return sprite;
    }

    function shuffle(items) {
      var i = items.length;
      while (i > 1) {
        i -= 1;
        var j = Math.floor(Math.random() * (i + 1));
        var tmp = items[i];
        items[i] = items[j];
        items[j] = tmp;
      }
      return items;
    }

    function renderFloatingScreensaver() {
      ensureOverlay();
      stage = overlay.querySelector('.screensaver-stage');
      if (!stage) { return; }
      stage.innerHTML = '';
      sprites = [];
      fallbackShown = false;
      lastThumbUrl = '';
      viewportSize();
      var available = previews.slice();
      if (!available.length) {
        showFloatingFallback();
        return;
      }
      shuffle(available);
      if (available.length > 1 && available[0].url === lastThumbUrl) {
        available.reverse();
      }
      var maxSprites = Math.min(14, Math.max(8, Math.round(Math.sqrt(viewport.w * viewport.h) / 150)));
      var target = Math.min(available.length, Math.max(1, maxSprites));
      for (var i = 0; i < target; i += 1) {
        var item = available[i];
        if (!item || !item.url) {
          continue;
        }
        if (item.url === lastThumbUrl && target > 1) {
          continue;
        }
        var sprite = makeSprite(item, i);
        if (!sprite) {
          continue;
        }
        sprites.push(sprite);
        stage.appendChild(sprite.el);
        if (sprite.url) {
          lastThumbUrl = sprite.url;
        }
      }
      if (!sprites.length) {
        showFloatingFallback();
        return;
      }
      window.setTimeout(function(){
        if (fallbackShown) { return; }
        var visibleItems = 0;
        for (var i = 0; i < sprites.length; i += 1) {
          if (sprites[i].visible && sprites[i].el) {
            visibleItems += 1;
          }
        }
        if (!visibleItems) {
          showFloatingFallback();
        }
      }, 500);
    }

    function showFloatingFallback() {
      if (!stage) {
        ensureOverlay();
        stage = overlay.querySelector('.screensaver-stage');
      }
      if (!stage) { return; }
      stage.innerHTML = '';
      var empty = document.createElement('div');
      empty.className = 'screensaver-empty';
      empty.textContent = text('js.no_images_available', 'No images available');
      stage.appendChild(empty);
      fallbackShown = true;
    }

    function startAnimationLoop() {
      if (!active) { return; }
      var now = window.performance && window.performance.now ? window.performance.now() : Date.now();
      if (!lastFrame) {
        lastFrame = now;
      }
      var delta = now - lastFrame;
      if (delta > 200) { delta = 16; }
      lastFrame = now;
      lastResizeW = window.innerWidth;
      lastResizeH = window.innerHeight;

      if (viewport.w !== lastResizeW || viewport.h !== lastResizeH) {
        viewportSize();
      }

      if (!fallbackShown) {
        updateFocusState(now);
        for (var i = 0; i < sprites.length; i += 1) {
          var sprite = sprites[i];
          if (!sprite.visible || !sprite.el) { continue; }
          sprite.x += sprite.vx * delta * 1.4;
          sprite.y += sprite.vy * delta * 1.4;
          var floatOffset = Math.sin((now * 0.001 * sprite.floatSpeed) + sprite.seed) * sprite.floatAmp;

          if (sprite.x < -window.innerWidth * 0.2) {
            sprite.x = window.innerWidth + Math.random() * 180;
          } else if (sprite.x > window.innerWidth + 180) {
            sprite.x = -window.innerWidth * 0.18 - Math.random() * 120;
          }

          if (sprite.y < -window.innerHeight * 0.28) {
            sprite.y = window.innerHeight + Math.random() * 130;
          } else if (sprite.y > window.innerHeight + 130) {
            sprite.y = -window.innerHeight * 0.25 - Math.random() * 120;
          }

          var isFocus = (i === focusIndex) && now <= focusUntil;
          var focusScale = isFocus ? sprite.focusScale : sprite.focusBase;
          var focusBoost = isFocus ? 0.12 : 0;
          var rotate = sprite.rotateBase + Math.sin(now * 0.00028 + sprite.seed) * 2.2;
          var parallax = parseFloat(sprite.el.style.getPropertyValue('--parallax')) || 1;
          var translateY = (floatOffset * parallax);
          sprite.el.style.transform = 'translate3d(' + sprite.x.toFixed(2) + 'px, ' + (sprite.y + translateY).toFixed(2) + 'px, 0) rotate(' + rotate.toFixed(2) + 'deg) scale(' + (focusScale + focusBoost).toFixed(3) + ')';
          sprite.el.style.opacity = Math.max(0.14, sprite.fade + (isFocus ? 0.3 : 0)).toFixed(3);
        }
      }

      rafId = window.requestAnimationFrame(startAnimationLoop);
    }

    function loadScreensaverPreviews() {
      if (loaded) {
        renderFloatingScreensaver();
        return;
      }
      loaded = true;
      fetch('/screensaver-previews.json?_=' + Date.now(), {
        cache: 'no-store',
        headers: {
          'Accept': 'application/json',
          'X-Requested-With': 'fetch'
        }
      }).then(function(response){
        if (!response.ok) { return null; }
        return response.json();
      }).then(function(payload){
        previews = payload && Array.isArray(payload.items) ? payload.items : [];
        renderFloatingScreensaver();
      }).catch(function(){
        previews = [];
        renderFloatingScreensaver();
      });
    }

    function showScreensaver() {
      if (document.hidden || !desktopQuery.matches) {
        resetScreensaverTimer();
        return;
      }
      ensureOverlay();
      overlay.classList.add('is-active');
      document.body.classList.add('screensaver-active');
      viewportSize();
      renderFloatingScreensaver();
      scheduleNextFocus(window.performance && window.performance.now ? window.performance.now() : Date.now());
      active = true;
      lastFrame = 0;
      if (!rafId) {
        rafId = window.requestAnimationFrame(startAnimationLoop);
      }
      loadScreensaverPreviews();
    }

    function hideScreensaver() {
      active = false;
      if (!overlay || !overlay.classList.contains('is-active')) { return; }
      overlay.classList.remove('is-active');
      document.body.classList.remove('screensaver-active');
      if (rafId) {
        window.cancelAnimationFrame(rafId);
        rafId = 0;
      }
      if (sprites.length) {
        sprites.forEach(function(sprite){
          if (sprite && sprite.el && sprite.el.parentNode) {
            sprite.el.parentNode.removeChild(sprite.el);
          }
        });
      }
      if (stage) {
        stage.innerHTML = '';
      }
      sprites = [];
      focusIndex = -1;
      focusUntil = 0;
      nextFocusAt = 0;
      lastFrame = 0;
    }

    function resetScreensaverTimer() {
      hideScreensaver();
      window.clearTimeout(timer);
      if (!desktopQuery.matches || document.hidden) { return; }
      timer = window.setTimeout(showScreensaver, screensaverIdleMs);
    }

    ['mousemove', 'mousedown', 'keydown', 'wheel', 'scroll', 'pointerdown', 'touchstart'].forEach(function(name){
      document.addEventListener(name, resetScreensaverTimer, { passive: true });
    });
    document.addEventListener('visibilitychange', resetScreensaverTimer);
    resetScreensaverTimer();
  }

  function setBusy(button, busy) {
    if (!button) { return; }
    button.disabled = busy;
    button.classList.toggle('is-busy', busy);
    if (busy) {
      button.dataset.busyText = buttonText(button);
      var text = button.dataset.busyText || 'Action';
      button.innerHTML = '<span class="btn-icon" aria-hidden="true">' + iconGlyphs.spinner + '</span><span class="btn-text">' + escapeHtml(text) + '</span>';
    } else {
      var oldText = button.dataset.busyText || buttonText(button);
      delete button.dataset.busyText;
      delete button.dataset.actionLabel;
      button.innerHTML = escapeHtml(oldText);
      button.classList.remove('has-action-icon');
      enhanceActionButtons(button.parentElement || document);
    }
  }

  function refreshLog(btn, section, targetId, options) {
    var pre = document.getElementById(targetId);
    var quiet = options && options.quiet;
    if (!pre) {
      return Promise.resolve(false);
    }
    setBusy(btn, true);
    return fetch('/update-log?section=' + encodeURIComponent(section) + '&_=' + Date.now(), {
      cache: 'no-store',
      headers: {
        'Accept': 'application/json',
        'X-Requested-With': 'fetch'
      }
    })
      .then(function(response){
        return response.text().then(function(rawText){
          if (!response.ok) {
            throw new Error('HTTP ' + response.status);
          }
          return rawText;
        });
      })
      .then(function(rawText){
        var text = '';
        try {
          text = JSON.parse(rawText).content || '';
        } catch (err) {
          text = rawText;
        }
        pre.textContent = text || text('js.no_log_output', 'No log output.');
        pre.scrollTop = pre.scrollHeight;
        return true;
      })
      .catch(function(err){
        if (!quiet) {
          pre.textContent = text('js.log_unreachable', 'Log is currently unreachable: ') + String(err.message || err);
        }
        return false;
      })
      .finally(function(){
        setBusy(btn, false);
        pre.scrollTop = pre.scrollHeight;
      });
  }

  function clearLog(btn, section, targetId) {
    var pre = document.getElementById(targetId);
    if (!pre) {
      return Promise.resolve(false);
    }
    var body = new URLSearchParams();
    body.set('section', section);
    setBusy(btn, true);
    return fetch('/log/clear', {
      method: 'POST',
      cache: 'no-store',
      headers: {
        'Accept': 'application/json',
        'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
        'X-Requested-With': 'fetch'
      },
      body: body.toString()
    })
      .then(function(response){
        return response.text().then(function(rawText){
          var payload = {};
          try {
            payload = JSON.parse(rawText);
          } catch (err) {
            payload = { message: rawText };
          }
          if (!response.ok || payload.ok === false) {
            throw new Error(payload.error || payload.message || ('HTTP ' + response.status));
          }
          return payload;
        });
      })
      .then(function(payload){
        pre.textContent = payload.message || 'Log cleared.';
        pre.scrollTop = pre.scrollHeight;
        showToast(payload.message || text('js.log_cleared', 'Log cleared.'), 'ok');
        return true;
      })
      .catch(function(err){
        pre.textContent = 'Could not clear log: ' + String(err.message || err);
        showToast(text('js.log_clear_failed', 'Could not clear log'), 'bad');
        return false;
      })
      .finally(function(){
        setBusy(btn, false);
      });
  }

  function initLogControls() {
    document.addEventListener('click', function(event){
      var btn = event.target.closest('[data-log-refresh]');
      if (!btn) {
        return;
      }
      event.preventDefault();
      event.stopImmediatePropagation();
      var section = btn.getAttribute('data-log-refresh');
      var targetId = btn.getAttribute('data-log-target');
      if (!section || !targetId) {
        return;
      }
      refreshLog(btn, section, targetId);
    });

    document.addEventListener('click', function(event){
      var btn = event.target.closest('[data-log-clear]');
      if (!btn) {
        return;
      }
      event.preventDefault();
      event.stopImmediatePropagation();
      var section = btn.getAttribute('data-log-clear');
      var targetId = btn.getAttribute('data-log-target');
      if (!section || !targetId) {
        return;
      }
      clearLog(btn, section, targetId);
    });
  }

  window.videoVdiskRefreshLog = refreshLog;
  window.videoVdiskClearLog = clearLog;

  function setVideoBusy(el, busy) {
    if (!el || !el.classList) { return; }
    if (el.tagName === "BUTTON" || el.classList.contains("button")) {
      setBusy(el, busy);
      return;
    }
    el.classList.toggle("is-busy", !!busy);
  }

  function setVideoFilterDetails(root) {
    var isMobile = window.matchMedia && window.matchMedia("(max-width: 680px)").matches;
    root.querySelectorAll(".video-filter-more").forEach(function(details){
      if (!isMobile) {
        details.open = true;
        return;
      }
      details.open = details.dataset.mobileOpen === "1";
    });
  }

  function currentVideoUrl() {
    return window.location.pathname + window.location.search;
  }

  function initVideoHistory() {
    if (window.location.pathname !== "/data" || !document.querySelector(".video-workspace")) {
      return;
    }
    if (window.history && window.history.replaceState) {
      window.history.replaceState({ videoWorkspace: true, url: currentVideoUrl() }, "", currentVideoUrl());
    }
  }

  function hydrateVideoSelectionControls(root) {
    root = root || document;
    var workspace = root.querySelector('.video-workspace');
    if (!workspace) {
      return;
    }
    var controls = workspace.querySelectorAll('.video-select-checkbox');
    for (var i = 0; i < controls.length; i += 1) {
      var checkbox = controls[i];
      var rel = checkbox.getAttribute('data-video-rel') || '';
      if (!rel) { continue; }
      checkbox.checked = selectedVideos.has(rel);
      var wrapper = checkbox.closest('.video-card-wrapper');
      if (wrapper) {
        if (selectedVideos.has(rel)) {
          wrapper.classList.add('is-selected');
        } else {
          wrapper.classList.remove('is-selected');
        }
      }
    }
    refreshVideoSelectionBar();
  }

  function findVideoSelectionNodes(rel, workspace) {
    workspace = workspace || document;
    rel = String(rel || '');
    var nodes = {
      checkboxes: [],
      wrappers: [],
    };
    if (!rel) {
      return nodes;
    }
    var controls = workspace.querySelectorAll('.video-select-checkbox[data-video-rel]');
    var i;
    for (i = 0; i < controls.length; i += 1) {
      if ((controls[i].getAttribute('data-video-rel') || '') !== rel) {
        continue;
      }
      nodes.checkboxes.push(controls[i]);
      var wrapper = controls[i].closest('.video-card-wrapper');
      if (wrapper && wrapper.getAttribute('data-video-rel') === rel) {
        nodes.wrappers.push(wrapper);
      }
    }
    return nodes;
  }

  function refreshVideoSelectionBar() {
    var bar = document.querySelector('.video-bulk-bar');
    if (!bar) { return; }
    var selectedCount = selectedVideos.size;
    var countNode = bar.querySelector('[data-video-selected-count]');
    if (countNode) {
      countNode.textContent = String(selectedCount);
    }
    var selectedNode = bar.querySelector('[data-video-selected-text]');
    if (selectedNode) {
      selectedNode.textContent = text('bulkActions.selected', 'Selected');
    }
    var buttons = bar.querySelectorAll('[data-video-bulk-action]');
    for (var i = 0; i < buttons.length; i += 1) {
      var button = buttons[i];
      if (button.getAttribute('data-video-bulk-action') === 'delete') {
        button.disabled = selectedCount === 0;
      }
    }
  }

  function setVideoSelection(rel, checked) {
    rel = String(rel || "");
    if (!rel) {
      return;
    }
    var workspace = document.querySelector('.video-workspace') || document;
    if (checked) {
      selectedVideos.add(rel);
    } else {
      selectedVideos.delete(rel);
    }
    refreshVideoSelectionBar();
    var nodes = findVideoSelectionNodes(rel, workspace);
    var n;
    for (n = 0; n < nodes.checkboxes.length; n += 1) {
      nodes.checkboxes[n].checked = selectedVideos.has(rel);
    }
    for (n = 0; n < nodes.wrappers.length; n += 1) {
      if (selectedVideos.has(rel)) {
        nodes.wrappers[n].classList.add('is-selected');
      } else {
        nodes.wrappers[n].classList.remove('is-selected');
      }
    }
  }

  function clearVideoSelection() {
    selectedVideos = new Set();
    hydrateVideoSelectionControls(document);
    refreshVideoSelectionBar();
  }

  function openVideoDeleteConfirm(payload) {
    var dialog = document.getElementById('video-delete-confirm-dialog');
    if (!dialog) {
      return;
    }
    var count = selectedVideos.size;
    var textNode = dialog.querySelector('[data-video-delete-confirm-text]');
    if (textNode) {
      var template = text('bulkActions.confirm_body', 'Delete {count} selected item(s)?');
      textNode.textContent = template.replace('{count}', String(count));
    }
    dialog.dataset.videoDeletePayload = payload || "";
    if (dialog.showModal) {
      dialog.showModal();
    } else {
      dialog.setAttribute('open', 'open');
    }
  }

  function closeVideoDeleteConfirm() {
    var dialog = document.getElementById('video-delete-confirm-dialog');
    if (!dialog) {
      return;
    }
    if (dialog.close) {
      dialog.close();
    } else {
      dialog.removeAttribute('open');
    }
  }

  function submitVideoDeleteSelection() {
    var ids = [];
    selectedVideos.forEach(function(rel){ ids.push(rel); });
    if (!ids.length) {
      showToast(text('bulkActions.no_videos_selected', 'No videos selected'), 'bad');
      return;
    }
    var body = new URLSearchParams();
    for (var i = 0; i < ids.length; i += 1) {
      body.append('video_ids', ids[i]);
    }
    var submitButton = document.querySelector('#video-delete-confirm-dialog [data-confirm-video-delete]');
    setBusy(submitButton, true);
    fetch('/data/delete', {
      method: 'POST',
      body: body,
      headers: {
        'Accept': 'application/json',
        'X-Requested-With': 'fetch'
      }
    }).then(function(response){
      return response.json().then(function(payload){
        payload.httpOk = response.ok;
        if (!payload || typeof payload !== 'object') {
          return { ok: false, httpOk: false, message: text('js.server_response_unreadable', 'Server response could not be read.') };
        }
        return payload;
      }).catch(function(){
        return { ok: false, httpOk: response.ok, message: text('js.server_response_unreadable', 'Server response could not be read.') };
      });
      }).then(function(payload){
        if (!payload) {
          showToast(text('js.action_failed', 'Action failed'), 'bad');
          return;
        }
        var ok = payload.ok && payload.httpOk !== false;
        var message = payload.message || (ok ? text('js.action_done', 'Action completed') : text('js.action_failed', 'Action failed'));
        showToast(message, ok ? 'ok' : 'bad');
        if (ok) {
          selectedVideos = new Set();
          loadVideoWorkspace(currentVideoUrl(), null, { history: 'none' });
        }
    }).catch(function(error){
      showToast(error && error.message ? error.message : text('js.action_failed', 'Action failed.'), 'bad');
    }).finally(function(){
      setBusy(submitButton, false);
      closeVideoDeleteConfirm();
    });
  }

  function initVideoPlayerAutoLoad(root) {
    root = root || document;
    var players = root.querySelectorAll(".video-player video[data-video-src]");
    players.forEach(function(video){
      if (!video || video.dataset.videoLazyInit === "1") { return; }
      video.dataset.videoLazyInit = "1";
      var sourceLoaded = false;

      function ensureSource() {
        if (sourceLoaded) {
          return;
        }
        var src = video.getAttribute("data-video-src");
        if (!src) {
          sourceLoaded = true;
          return;
        }
        video.setAttribute("src", src);
        video.removeAttribute("data-video-src");
        sourceLoaded = true;
        try {
          video.load();
        } catch (error) {}
      }

      video.addEventListener("play", function(){
        ensureSource();
        if (video.paused) {
          try {
            video.play();
          } catch (error) {}
        }
      });
      video.addEventListener("click", ensureSource, { passive: true });
      video.addEventListener("pointerdown", ensureSource, { passive: true });
      video.addEventListener("focus", ensureSource);
    });
  }

  function loadVideoWorkspace(url, trigger, options) {
    options = options || {};
    var target = url || "";
    if (!target) { return; }
    var focusPlayerAfterLoad = trigger && trigger.closest && trigger.closest(".video-card-click");
    setVideoBusy(trigger, true);
    fetch(target, {
      headers: {
        "Accept": "application/json",
        "X-Requested-With": "fetch"
      }
    }).then(function(response){
      return response.json().then(function(payload){
        return { ok: response.ok, payload: payload };
      }).catch(function(){
        return { ok: false, payload: { ok: false } };
      });
    }).then(function(reply){
      if (!reply || !reply.ok) {
        showToast(text('js.file_load_failed', 'File cannot be loaded'), 'bad');
        return;
      }
      try {
        var payload = reply.payload;
        if (!payload.ok) {
          showToast(payload.message || text('js.file_select_failed', 'File selection failed.'), 'bad');
          return;
        }
        if (!payload.workspace_html) {
          showToast(text('js.workspace_missing', 'Response does not contain workspace data.'), 'bad');
          return;
        }
        var holder = document.querySelector('.video-workspace');
        if (!holder) {
          return;
        }
        var wrapper = document.createElement('div');
        wrapper.innerHTML = payload.workspace_html;
        if (wrapper.firstElementChild) {
          holder.replaceWith(wrapper.firstElementChild);
        }
        hydrateVideoSelectionControls(document);
        initVideoPlayerAutoLoad(document);
        enhanceActionButtons(document);
        setVideoFilterDetails(document);
        if (focusPlayerAfterLoad && window.matchMedia && window.matchMedia("(max-width: 860px)").matches) {
          var playerShell = document.querySelector(".video-player-shell");
          if (playerShell && playerShell.scrollIntoView) {
            playerShell.scrollIntoView({ block: "start" });
          }
        }
        if (payload.current_url && window.history) {
          var state = { videoWorkspace: true, url: payload.current_url };
          if (options.history === "replace" && window.history.replaceState) {
            window.history.replaceState(state, "", payload.current_url);
          } else if (options.history !== "none" && window.history.pushState && payload.current_url !== currentVideoUrl()) {
            window.history.pushState(state, "", payload.current_url);
          }
        }
      } catch (error) {
        showToast(text('js.response_unreadable', 'Response could not be read.'), 'bad');
      }
    }).catch(function(){
      showToast(text('js.file_select_update_failed', 'File selection could not be updated.'), 'bad');
    }).finally(function(){
      setVideoBusy(trigger, false);
    });
  }

  document.addEventListener('click', function(event){
    var control = event.target.closest('.video-select-control');
    if (!control || !control.closest('.video-workspace')) {
      return;
    }
    var checkbox = control.querySelector('.video-select-checkbox');
    if (!checkbox) {
      return;
    }
    if (event.target === checkbox) {
      event.stopPropagation();
      // Let the native checkbox input fire change events normally.
      return;
    }
    event.preventDefault();
    event.stopPropagation();
    var rel = checkbox.getAttribute('data-video-rel') || checkbox.getAttribute('data-rel') || '';
    var nextChecked = !checkbox.checked;
    checkbox.checked = nextChecked;
    setVideoSelection(rel, nextChecked);
  });

  document.addEventListener("click", function(event){
    var trigger = event.target.closest("[data-video-load]");
    if (!trigger || !trigger.closest(".video-workspace")) {
      return;
    }
    var url = trigger.getAttribute("data-video-load") || trigger.getAttribute("href");
    if (!url) {
      return;
    }
    event.preventDefault();
    loadVideoWorkspace(url, trigger);
  });

  document.addEventListener('change', function(event){
    var input = event.target;
    if (!input || !input.classList || !input.classList.contains('video-select-checkbox')) {
      return;
    }
    event.stopPropagation();
    var rel = input.getAttribute('data-video-rel');
    if (!rel) {
      return;
    }
    setVideoSelection(rel, input.checked);
  });

  document.addEventListener('click', function(event){
    var bulkAction = event.target.closest('[data-video-bulk-action]');
    if (!bulkAction || !bulkAction.closest('.video-workspace')) {
      return;
    }
    event.preventDefault();
    if (bulkAction.getAttribute('data-video-bulk-action') === 'select-all-page') {
      var workspace = document.querySelector('.video-workspace');
      var checkboxes = workspace ? workspace.querySelectorAll('.video-select-checkbox') : [];
      for (var i = 0; i < checkboxes.length; i += 1) {
        setVideoSelection(checkboxes[i].getAttribute('data-video-rel'), true);
      }
      return;
    }
    if (bulkAction.getAttribute('data-video-bulk-action') === 'clear') {
      clearVideoSelection();
      return;
    }
    if (bulkAction.getAttribute('data-video-bulk-action') === 'delete') {
      if (!selectedVideos.size) {
        showToast(text('bulkActions.delete_failed', 'Delete failed'), 'bad');
        return;
      }
      openVideoDeleteConfirm();
      return;
    }
  });

  document.addEventListener('click', function(event){
    var close = event.target.closest('[data-close-video-delete-confirm]');
    if (!close) {
      return;
    }
    event.preventDefault();
    closeVideoDeleteConfirm();
  });

  document.addEventListener('click', function(event){
    var confirm = event.target.closest('[data-confirm-video-delete]');
    if (!confirm) {
      return;
    }
    if (!confirm.closest('#video-delete-confirm-dialog')) {
      return;
    }
    event.preventDefault();
    submitVideoDeleteSelection();
  });

  document.addEventListener("submit", function(event){
    var form = event.target;
    if (!form || !form.classList || !form.classList.contains("video-filterbar")) {
      return;
    }
    if (!form.closest(".video-workspace")) {
      return;
    }
    event.preventDefault();
    var submitter = event.submitter || form.querySelector('button[type="submit"], button:not([type])');
    var params = new URLSearchParams(new FormData(form));
    var action = form.getAttribute("action") || "/data";
    var query = params.toString();
    loadVideoWorkspace(action + (query ? "?" + query : ""), submitter);
  });

  window.addEventListener("popstate", function(){
    if (window.location.pathname !== "/data" || !document.querySelector(".video-workspace")) {
      return;
    }
    loadVideoWorkspace(currentVideoUrl(), null, { history: "none" });
  });

  document.addEventListener('submit', function(event){
    var form = event.target;
    if (!form || !form.getAttribute) { return; }
    var message = form.getAttribute('data-confirm-message');
    if (message && !window.confirm(message)) {
      event.preventDefault();
      return;
    }
    if (form.dataset.dangerAction === '1' && form.dataset.ayesx !== '1') {
      var submitter = event.submitter || form.querySelector('button[type="submit"], button:not([type])');
      setBusy(submitter, true);
    }
  });

  document.addEventListener('submit', function(event){
    var form = event.target;
    if (!form || form.dataset.ayesx !== '1') { return; }
    if (event.defaultPrevented) { return; }
    event.preventDefault();
    var formPath = actionPath(form);
    var submitter = event.submitter || form.querySelector('button[type="submit"], button:not([type])');
    var data = new URLSearchParams(new FormData(form));
    setBusy(submitter, true);
    fetch(form.action || window.location.href, {
      method: 'POST',
      body: data,
      headers: {
        'Accept': 'application/json',
        'X-Requested-With': 'fetch'
      }
    }).then(function(response){
      return response.json().then(function(payload){
        payload.httpOk = response.ok;
        return payload;
      }).catch(function(){
        return { ok: false, httpOk: response.ok, message: text('js.server_response_unreadable', 'Server response could not be read.') };
      });
    }).then(function(payload){
      var ok = payload.ok !== false && payload.httpOk !== false;
      showToast(payload.message || (ok ? text('js.action_done', 'Action completed') : text('js.action_failed', 'Action failed')), ok ? 'ok' : 'bad');
      if (ok && window.CustomEvent) {
        document.dispatchEvent(new CustomEvent('videoVdisk:ayesxAction', {
          detail: {
            path: formPath,
            payload: payload
          }
        }));
      }
      if (ok && form.dataset.ayesxReload !== '0') {
        window.setTimeout(function(){
          window.location.href = payload.redirect || window.location.href;
        }, 520);
      }
    }).catch(function(error){
      if ((formPath === '/update/check' || formPath === '/update/start') && window.CustomEvent) {
        document.dispatchEvent(new CustomEvent('videoVdisk:updateConnectionLost', {
          detail: {
            path: formPath,
            message: error && error.message ? error.message : ''
          }
        }));
        showToast(text('js.webserver_down_update', 'The web server is not responding. The update page keeps waiting.'), 'bad');
        return;
      }
      showToast(error && error.message ? error.message : text('js.action_failed', 'Action failed.'), 'bad');
    }).finally(function(){
      setBusy(submitter, false);
    });
  });
})();
</script>
"""
    return (
        script
        .replace("__APP_BUILD__", json.dumps(app_version_info().get("build", "")))
        .replace("__APP_VERSION_CHECK_INTERVAL_MS__", str(APP_VERSION_CHECK_INTERVAL_MS))
        .replace("__SCREENSAVER_IDLE_MS__", str(screensaver_idle_minutes() * 60 * 1000))
        .replace("__SCREENSAVER_MODE__", json.dumps(screensaver_mode()))
        .replace("__I18N_JSON__", js_i18n_json())
    )


def select_html(name, values, selected):
    values = list(values)

    if selected and selected not in values:
        values.insert(0, selected)

    out = [f'<select name="{esc(name)}">']

    for v in values:
        sel = " selected" if v == selected else ""
        out.append(f'<option value="{esc(v)}"{sel}>{esc(v)}</option>')

    out.append("</select>")
    return "\n".join(out)


def select_with_fallback(name, values, selected, empty_label):
    values = list(values)
    if not values:
        return (
            '<select name="' + esc(name) + '">'
            '<option value="" selected>' + esc(empty_label) + "</option>"
            "</select>"
        )

    return select_html(name, values, selected)


def form_field(label, control_html, help_text=""):
    hint = f'<div class="field-help">{esc(help_text)}</div>' if help_text else ""
    return (
        '<div class="form-field">'
        '<label>' + esc(label) + '</label>'
        + str(control_html)
        + hint
        + '</div>'
    )



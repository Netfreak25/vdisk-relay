#!/usr/bin/env python3
import fcntl
import hashlib
import json
import os
import re
import signal
import shlex
import shutil
import subprocess
import time
from datetime import datetime, timedelta, timezone
try:
    from zoneinfo import ZoneInfo
except Exception:
    ZoneInfo = None

CONFIG = "/etc/vdisk-relay.conf"
RUN_DIR = "/run/vdisk-relay"
PREVIEW_DIR = "/var/cache/vdisk-relay-previews"
INDEX = os.path.join(PREVIEW_DIR, "index.json")
DATA_INDEX = os.path.join(PREVIEW_DIR, "files.json")
BACKLOG = os.path.join(PREVIEW_DIR, "backlog.json")
LOCK = os.path.join(PREVIEW_DIR, "cache.lock")
SUSPEND_DIR = os.path.join(RUN_DIR, "preview-suspend.d")
FFMPEG_PID_FILE = os.path.join(RUN_DIR, "preview-ffmpeg.pid")

DEFAULT_SCAN_MAX_FILES = 5000
DEFAULT_CACHE_MAX_FILES = 5000
DEFAULT_NEW_PER_RUN = 3
DEFAULT_ATTEMPTS_PER_RUN = 4
DEFAULT_FFMPEG_TIMEOUT = 180
DEFAULT_LONG_FFMPEG_TIMEOUT = 600
DEFAULT_OFFSET_SECONDS = 1
DEFAULT_SMALL_VIDEO_BYTES = 150 * 1024
MAX_SMALL_VIDEO_BYTES = 5 * 1024 * 1024
MAX_STORED_STDERR = 500
LONG_ATTEMPT_START = 3
PERMANENT_IGNORE_FAILS = 4
VIDEO_DISPLAY_TZ_NAME = "Europe/Berlin"
PREVIEW_SUSPENDED_RC = 75

VIDEO_TIME_PATTERNS = [
    re.compile(
        r"(?P<y>20\d{2})[-_](?P<m>\d{2})[-_](?P<d>\d{2})"
        r"[ T_-]+(?P<h>\d{2})[-_:](?P<mi>\d{2})(?:[-_:](?P<s>\d{2}))?"
    ),
    re.compile(
        r"(?P<y>20\d{2})(?P<m>\d{2})(?P<d>\d{2})"
        r"[ T_-]?(?P<h>\d{2})(?P<mi>\d{2})(?P<s>\d{2})"
    ),
]


def log(msg):
    print(time.strftime("%F %T") + " " + msg, flush=True)


def ensure_run_dir():
    os.makedirs(RUN_DIR, mode=0o755, exist_ok=True)


def suspend_tokens():
    try:
        return sorted(
            name for name in os.listdir(SUSPEND_DIR)
            if name and not name.startswith(".")
        )
    except FileNotFoundError:
        return []
    except OSError as exc:
        log("WARN preview suspend check failed: {}".format(exc))
        return []


def preview_suspended():
    return bool(suspend_tokens())


def stop_if_suspended(stage):
    tokens = suspend_tokens()
    if not tokens:
        return False
    log("INFO preview suspended stage={} tokens={}".format(stage, ",".join(tokens)))
    return True


def read_file(path, default=""):
    try:
        with open(path, "r", encoding="utf-8", errors="replace") as f:
            return f.read()
    except FileNotFoundError:
        return default


def parse_shell_var(text, name, default):
    for line in text.splitlines():
        parsed = parse_shell_assignment(line)
        if not parsed:
            continue
        key, value = parsed
        if key == name:
            return value
    return default


def parse_shell_assignment(line):
    stripped = line.strip()
    if not stripped or stripped.startswith("#") or "=" not in stripped:
        return None

    key, _value = stripped.split("=", 1)
    key = key.strip()
    if not re.match(r"^[A-Z0-9_]+$", key):
        return None

    try:
        parts = shlex.split(stripped, comments=True, posix=True)
    except ValueError:
        return None

    if len(parts) != 1 or "=" not in parts[0]:
        return None

    parsed_key, parsed_value = parts[0].split("=", 1)
    if parsed_key != key:
        return None
    return parsed_key, parsed_value


def parse_int_config(name, default):
    raw = parse_shell_var(read_file(CONFIG), name, str(default))
    try:
        value = int(raw)
        if value < 0:
            return default
        return value
    except Exception:
        return default


def data_root():
    return parse_shell_var(read_file(CONFIG), "DATA_ROOT", "/files")


def rel_path(full, root):
    return os.path.relpath(os.path.realpath(full), os.path.realpath(root))


def load_index():
    try:
        with open(INDEX, "r", encoding="utf-8") as f:
            return json.load(f)
    except Exception:
        return {}


def int_value(value, default=0):
    try:
        return int(value)
    except Exception:
        return default


def trim_stderr(text):
    text = (text or "").strip()
    if len(text) > MAX_STORED_STDERR:
        return text[:MAX_STORED_STDERR]
    return text


def normalize_backlog_entry(rel, raw):
    entry = raw if isinstance(raw, dict) else {}
    fail_count = max(0, int_value(entry.get("fail_count"), 0))
    long_fail_count = max(0, int_value(entry.get("long_fail_count"), 0))
    ignored = bool(entry.get("ignored"))

    if fail_count >= PERMANENT_IGNORE_FAILS and long_fail_count >= 1:
        ignored = True

    entry["rel"] = rel
    entry["fail_count"] = fail_count
    entry["long_fail_count"] = long_fail_count
    entry["ignored"] = ignored
    if "last_stderr" in entry:
        entry["last_stderr"] = trim_stderr(entry.get("last_stderr", ""))
    return entry


def parse_video_utc_datetime(name):
    for pattern in VIDEO_TIME_PATTERNS:
        match = pattern.search(name)
        if not match:
            continue
        try:
            return datetime(
                int(match.group("y")),
                int(match.group("m")),
                int(match.group("d")),
                int(match.group("h")),
                int(match.group("mi")),
                int(match.groupdict().get("s") or "0"),
                tzinfo=timezone.utc,
            )
        except ValueError:
            continue
    return None


def last_sunday_utc(year, month):
    dt = datetime(year, month, 31, 1, 0, 0, tzinfo=timezone.utc)
    while dt.weekday() != 6:
        dt -= timedelta(days=1)
    return dt


def berlin_local_time(utc_dt):
    if ZoneInfo is not None:
        try:
            return utc_dt.astimezone(ZoneInfo(VIDEO_DISPLAY_TZ_NAME))
        except Exception:
            pass
    start = last_sunday_utc(utc_dt.year, 3)
    end = last_sunday_utc(utc_dt.year, 10)
    return utc_dt + timedelta(hours=2 if start <= utc_dt < end else 1)


def video_time_info(path, mtime):
    utc_dt = parse_video_utc_datetime(os.path.basename(path))
    if utc_dt is not None:
        local_dt = berlin_local_time(utc_dt)
        return {
            "sort_ts": int(utc_dt.timestamp()),
            "display": local_dt.strftime("%H:%M:%S %d.%m.%Y"),
            "date": local_dt.strftime("%d.%m.%Y"),
        }

    local_dt = datetime.fromtimestamp(mtime).astimezone()
    return {
        "sort_ts": int(mtime),
        "display": local_dt.strftime("%H:%M:%S %d.%m.%Y"),
        "date": local_dt.strftime("%d.%m.%Y"),
    }


def load_backlog():
    try:
        with open(BACKLOG, "r", encoding="utf-8") as f:
            data = json.load(f)
    except Exception:
        return {}

    if not isinstance(data, dict):
        return {}

    return {
        rel: normalize_backlog_entry(rel, entry)
        for rel, entry in data.items()
        if isinstance(rel, str)
    }


def write_json_atomic(path, data):
    tmp = path + ".tmp"
    with open(tmp, "w", encoding="utf-8") as f:
        json.dump(data, f, ensure_ascii=False, indent=2)
        f.write("\n")
    os.chmod(tmp, 0o644)
    os.replace(tmp, path)


def proc_start_time(pid):
    try:
        with open("/proc/{}/stat".format(pid), "r", encoding="utf-8", errors="replace") as f:
            stat = f.read()
    except OSError:
        return ""
    try:
        rest = stat.rsplit(") ", 1)[1].split()
        return rest[19]
    except Exception:
        return ""


def write_ffmpeg_pid_file(pid):
    ensure_run_dir()
    payload = {
        "pid": int(pid),
        "start_time": proc_start_time(pid),
        "written_at": time.strftime("%F %T%z"),
        "owner": "vdisk-relay-preview-cache",
    }
    write_json_atomic(FFMPEG_PID_FILE, payload)


def clear_ffmpeg_pid_file(pid=None):
    if pid is not None:
        try:
            with open(FFMPEG_PID_FILE, "r", encoding="utf-8") as f:
                payload = json.load(f)
            if int(payload.get("pid", -1)) != int(pid):
                return
        except Exception:
            pass
    try:
        os.unlink(FFMPEG_PID_FILE)
    except FileNotFoundError:
        pass


def low_priority_prefix():
    cmd = []
    nice = shutil.which("nice")
    ionice = shutil.which("ionice")
    if nice:
        cmd.extend([nice, "-n", "19"])
    if ionice:
        cmd.extend([ionice, "-c3"])
    return cmd


def media_type_for_path(path):
    ext = os.path.splitext(path)[1].lower().lstrip(".")
    if ext in {"mp4", "mov", "m4v", "avi", "mkv", "webm"}:
        return "video"
    if ext in {"jpg", "jpeg", "png", "gif", "webp", "bmp"}:
        return "image"
    if ext in {"mp3", "wav", "m4a", "aac", "flac", "ogg"}:
        return "audio"
    if ext in {"txt", "log", "json", "csv", "md", "xml", "yaml", "yml"}:
        return "text"
    if ext in {"pdf", "zip", "tar", "gz", "tgz", "7z", "rar", "doc", "docx", "xls", "xlsx"}:
        return "document"
    return "other"


def parse_sources(text):
    match = re.search(r"^SOURCES=\(\s*(.*?)^\)", text, re.M | re.S)
    if not match:
        return []
    sources = []
    for raw in match.group(1).splitlines():
        raw = raw.strip()
        if not raw or raw.startswith("#"):
            continue
        try:
            parts = raw.strip("'\"").split("|")
        except Exception:
            continue
        while len(parts) < 16:
            parts.append("")
        sources.append({
            "id": parts[0],
            "enabled": parts[1],
            "profile": parts[2] or "generic-media-drop",
            "match": parts[4] or "*",
            "extensions": parts[5] or "*",
            "telegram_mode": parts[6] or "auto",
        })
    return sources


def active_sources():
    return [s for s in parse_sources(read_file(CONFIG)) if s.get("enabled") == "1"]


def source_extension_allowed(source, path):
    raw = (source.get("extensions") or "*").replace(";", ",").lower()
    if raw.strip() == "*":
        return True
    ext = os.path.splitext(path)[1].lower().lstrip(".")
    allowed = {item.strip().lstrip(".") for item in raw.split(",") if item.strip()}
    return ext in allowed


def source_matches_path(source, path):
    pattern = (source.get("match") or "*").strip()
    if not source_extension_allowed(source, path):
        return False
    if not pattern or pattern == "*":
        return True
    return pattern.lower() in os.path.basename(path).lower()


def source_for_path(path, sources):
    for source in sources:
        if source_matches_path(source, path):
            return source
    return {
        "id": "",
        "profile": "generic-media-drop",
        "telegram_mode": "auto",
    }


def configured_extensions(sources):
    if not sources:
        return {"mp4"}
    extensions = set()
    for source in sources:
        raw = (source.get("extensions") or "*").replace(";", ",").lower()
        if raw.strip() == "*":
            return None
        for item in raw.split(","):
            item = item.strip().lstrip(".")
            if item:
                extensions.add(item)
    return extensions or None


def extension_allowed(path, extensions):
    if extensions is None:
        return True
    ext = os.path.splitext(path)[1].lower().lstrip(".")
    return ext in extensions


def write_file_index(files, root, sources):
    items = []
    for full in files:
        try:
            st = os.stat(full)
            tinfo = video_time_info(full, st.st_mtime)
            media_type = media_type_for_path(full)
            source = source_for_path(full, sources)
            items.append({
                "rel": rel_path(full, root),
                "name": os.path.basename(full),
                "extension": os.path.splitext(full)[1].lower().lstrip("."),
                "media_type": media_type,
                "source_id": source.get("id", ""),
                "profile": source.get("profile", "generic-media-drop"),
                "preview_kind": "video-frame" if media_type == "video" else ("image-direct" if media_type == "image" else "icon"),
                "telegram_mode": source.get("telegram_mode", "auto"),
                "mtime": int(st.st_mtime),
                "size": int(st.st_size),
                "sort_ts": tinfo["sort_ts"],
                "display": tinfo["display"],
                "date": tinfo["date"],
            })
        except Exception:
            continue

    write_json_atomic(DATA_INDEX, {
        "generated_at": time.strftime("%Y-%m-%dT%H:%M:%S%z"),
        "root": os.path.realpath(root),
        "count": len(items),
        "files": items,
    })


def list_recent(scan_max, sources):
    root = data_root()
    search_root = root
    extensions = configured_extensions(sources)

    cmd = [
        "find",
        search_root,
        "-type",
        "f",
        "-printf",
        "%T@\t%p\n",
    ]

    log("scan start root={} scan_max={}".format(search_root, scan_max))

    try:
        res = subprocess.run(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            text=True,
            timeout=120,
            check=False,
        )
    except subprocess.TimeoutExpired:
        log("WARN scan timeout")
        return []

    items = []
    for line in res.stdout.splitlines():
        if "\t" not in line:
            continue
        try:
            ts, path = line.split("\t", 1)
            if not extension_allowed(path, extensions):
                continue
            items.append((float(ts), path))
        except Exception:
            continue

    items.sort(reverse=True)

    if scan_max:
        items = items[:scan_max]

    log("scan done count={}".format(len(items)))
    return [path for _, path in items]


def prune_cache(cache_max):
    if cache_max <= 0:
        return

    jpgs = []
    for name in os.listdir(PREVIEW_DIR):
        if not name.endswith(".jpg"):
            continue
        path = os.path.join(PREVIEW_DIR, name)
        try:
            st = os.stat(path)
            jpgs.append((st.st_mtime, path))
        except Exception:
            continue

    if len(jpgs) <= cache_max:
        return

    jpgs.sort(reverse=True)
    for _, path in jpgs[cache_max:]:
        try:
            os.unlink(path)
        except Exception:
            pass


def attempt_mode_for(entry):
    fail_count = int_value(entry.get("fail_count"), 0) if entry else 0
    if fail_count >= LONG_ATTEMPT_START - 1:
        return "long"
    return "normal"


def record_failure(backlog, rel, full, rc, dur, timeout_sec, mode, stderr):
    entry = normalize_backlog_entry(rel, backlog.get(rel, {}))
    fail_count = entry["fail_count"] + 1
    long_fail_count = entry["long_fail_count"] + (1 if mode == "long" else 0)
    ignored = fail_count >= PERMANENT_IGNORE_FAILS and long_fail_count >= 1

    entry.update({
        "rel": rel,
        "full": full,
        "fail_count": fail_count,
        "long_fail_count": long_fail_count,
        "ignored": ignored,
        "last_rc": rc,
        "last_seconds": dur,
        "last_timeout": timeout_sec,
        "last_mode": mode,
        "last_stderr": trim_stderr(stderr),
        "last_failure_at": time.strftime("%F %T%z"),
    })

    if ignored:
        entry["ignored_at"] = entry.get("ignored_at") or time.strftime("%F %T%z")

    backlog[rel] = entry
    return entry


def use_second_frame_for_size(path, threshold_bytes):
    if threshold_bytes <= 0:
        return False
    try:
        return os.path.getsize(path) <= threshold_bytes
    except OSError:
        return False


def terminate_process_group(pid, sig=signal.SIGTERM):
    try:
        os.killpg(int(pid), sig)
        return True
    except ProcessLookupError:
        return False
    except Exception as exc:
        log("WARN ffmpeg process-group signal failed pid={} error={}".format(pid, exc))
        return False


def ffmpeg_preview(ffmpeg, full, tmp, timeout_sec, offset_seconds, use_second_frame=False):
    cmd = low_priority_prefix() + [
        ffmpeg,
        "-nostdin",
        "-hide_banner",
        "-loglevel", "error",
    ]

    if use_second_frame:
        cmd.extend([
            "-i", full,
            "-frames:v", "1",
            "-update", "1",
            "-vf", "select=eq(n\\,1),scale=320:-1",
            "-q:v", "6",
            "-y", tmp,
        ])
    else:
        cmd.extend([
            "-ss", str(offset_seconds),
            "-i", full,
            "-frames:v", "1",
            "-update", "1",
            "-vf", "scale=320:-1",
            "-q:v", "6",
            "-y", tmp,
        ])

    start = time.time()
    proc = subprocess.Popen(
        cmd,
        stdin=subprocess.DEVNULL,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.PIPE,
        text=True,
        errors="replace",
        start_new_session=True,
    )
    write_ffmpeg_pid_file(proc.pid)

    try:
        while True:
            if preview_suspended():
                terminate_process_group(proc.pid)
                try:
                    _, stderr = proc.communicate(timeout=3)
                except subprocess.TimeoutExpired:
                    terminate_process_group(proc.pid, signal.SIGKILL)
                    _, stderr = proc.communicate()
                dur = int(time.time() - start)
                return PREVIEW_SUSPENDED_RC, dur, stderr or ""

            rc = proc.poll()
            if rc is not None:
                _, stderr = proc.communicate()
                dur = int(time.time() - start)
                return rc, dur, stderr or ""

            if time.time() - start >= timeout_sec:
                terminate_process_group(proc.pid)
                try:
                    _, stderr = proc.communicate(timeout=3)
                except subprocess.TimeoutExpired:
                    terminate_process_group(proc.pid, signal.SIGKILL)
                    _, stderr = proc.communicate()
                dur = int(time.time() - start)
                return 124, dur, stderr or ""

            time.sleep(0.2)
    finally:
        clear_ffmpeg_pid_file(proc.pid)


def main():
    ensure_run_dir()
    os.makedirs(PREVIEW_DIR, mode=0o755, exist_ok=True)

    with open(LOCK, "w", encoding="utf-8") as lock:
        try:
            fcntl.flock(lock, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            log("INFO already running")
            return 0

        scan_max = min(parse_int_config("PREVIEW_SCAN_MAX_FILES", DEFAULT_SCAN_MAX_FILES), 20000)
        cache_max = min(parse_int_config("PREVIEW_CACHE_MAX_FILES", DEFAULT_CACHE_MAX_FILES), 20000)
        new_per_run = parse_int_config("PREVIEW_NEW_PER_RUN", DEFAULT_NEW_PER_RUN)
        attempts_per_run = parse_int_config("PREVIEW_ATTEMPTS_PER_RUN", DEFAULT_ATTEMPTS_PER_RUN)
        timeout_sec = min(max(1, parse_int_config("PREVIEW_FFMPEG_TIMEOUT", DEFAULT_FFMPEG_TIMEOUT)), 600)
        long_timeout_sec = min(
            max(timeout_sec, parse_int_config("PREVIEW_LONG_FFMPEG_TIMEOUT", DEFAULT_LONG_FFMPEG_TIMEOUT)),
            3600,
        )
        offset_seconds = parse_int_config("PREVIEW_OFFSET_SECONDS", DEFAULT_OFFSET_SECONDS)
        small_video_bytes = min(
            parse_int_config("PREVIEW_SMALL_VIDEO_BYTES", DEFAULT_SMALL_VIDEO_BYTES),
            MAX_SMALL_VIDEO_BYTES,
        )

        root = data_root()
        sources = active_sources()
        if stop_if_suspended("before-scan"):
            return 0
        files = list_recent(scan_max, sources)
        write_file_index(files, root, sources)

        ffmpeg = shutil.which("ffmpeg")
        if not ffmpeg:
            log("WARN ffmpeg missing")
            write_json_atomic(INDEX, {})
            return 0

        index = load_index()
        backlog = load_backlog()

        generated = 0
        attempts = 0
        failed = 0
        existing = 0
        ignored = 0

        write_json_atomic(INDEX, index)

        for full in files:
            if media_type_for_path(full) != "video":
                continue
            rel = rel_path(full, root)
            key = hashlib.sha1(rel.encode("utf-8")).hexdigest()
            out = os.path.join(PREVIEW_DIR, key + ".jpg")
            tmp = os.path.join(PREVIEW_DIR, key + ".tmp.jpg")

            if os.path.exists(out) and os.path.getsize(out) > 0:
                index[rel] = "/preview/" + key + ".jpg"
                if rel in backlog:
                    del backlog[rel]
                    write_json_atomic(BACKLOG, backlog)
                existing += 1
                continue

            backlog_entry = normalize_backlog_entry(rel, backlog.get(rel, {}))
            if backlog_entry.get("ignored"):
                backlog[rel] = backlog_entry
                ignored += 1
                continue

            if new_per_run > 0 and generated >= new_per_run:
                break

            if attempts_per_run > 0 and attempts >= attempts_per_run:
                break

            if stop_if_suspended("before-ffmpeg"):
                write_json_atomic(INDEX, index)
                write_json_atomic(BACKLOG, backlog)
                return 0

            attempts += 1

            if os.path.exists(tmp):
                try:
                    os.unlink(tmp)
                except Exception:
                    pass

            mode = attempt_mode_for(backlog_entry)
            active_timeout = long_timeout_sec if mode == "long" else timeout_sec
            attempt_no = int_value(backlog_entry.get("fail_count"), 0) + 1
            use_second_frame = use_second_frame_for_size(full, small_video_bytes)
            frame_mode = "second-frame" if use_second_frame else "offset-" + str(offset_seconds) + "s"

            log("ffmpeg start attempt={} mode={} timeout={}s frame={} rel={}".format(
                attempt_no, mode, active_timeout, frame_mode, rel
            ))

            rc, dur, stderr = ffmpeg_preview(
                ffmpeg,
                full,
                tmp,
                active_timeout,
                offset_seconds,
                use_second_frame,
            )

            if rc == PREVIEW_SUSPENDED_RC:
                if os.path.exists(tmp):
                    try:
                        os.unlink(tmp)
                    except Exception:
                        pass
                write_json_atomic(INDEX, index)
                write_json_atomic(BACKLOG, backlog)
                log("INFO ffmpeg stopped because preview is suspended rel={} seconds={}".format(rel, dur))
                return 0

            if rc == 0 and os.path.exists(tmp) and os.path.getsize(tmp) > 0:
                os.replace(tmp, out)
                os.chmod(out, 0o644)
                index[rel] = "/preview/" + key + ".jpg"
                if rel in backlog:
                    del backlog[rel]
                    write_json_atomic(BACKLOG, backlog)
                generated += 1
                write_json_atomic(INDEX, index)
                log("OK generated rel={} seconds={}".format(rel, dur))
            else:
                failed += 1
                if os.path.exists(tmp):
                    try:
                        os.unlink(tmp)
                    except Exception:
                        pass
                entry = record_failure(backlog, rel, full, rc, dur, active_timeout, mode, stderr)
                write_json_atomic(BACKLOG, backlog)
                log("WARN failed rel={} rc={} seconds={} fail_count={} long_fail_count={} ignored={}".format(
                    rel, rc, dur, entry["fail_count"], entry["long_fail_count"], entry["ignored"]
                ))

        prune_cache(cache_max)
        write_json_atomic(INDEX, index)
        write_json_atomic(BACKLOG, backlog)

        # Backoff is disabled; old failures.json is no longer used.
        old_failures = os.path.join(PREVIEW_DIR, "failures.json")
        if os.path.exists(old_failures):
            try:
                os.unlink(old_failures)
            except Exception:
                pass

        log("done scanned={} indexed={} backlog={} existing={} ignored={} generated={} failed={} attempts={} scan_max={} cache_max={} new_per_run={} attempts_per_run={} timeout={}s long_timeout={}s small_video_bytes={}".format(
            len(files), len(index), len(backlog), existing, ignored, generated, failed, attempts,
            scan_max, cache_max, new_per_run, attempts_per_run, timeout_sec, long_timeout_sec, small_video_bytes
        ))

    return 0


if __name__ == "__main__":
    raise SystemExit(main())

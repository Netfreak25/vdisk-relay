[ -r "$CONFIG_FILE" ] && . "$CONFIG_FILE"
[ -r "$ENV_FILE" ] && . "$ENV_FILE"

CONFIG_BACKUP_GIT_CREDENTIALS="/var/lib/vdisk-relay/git-credentials.json"
CONFIG_BACKUP_NM_CONNECTION_DIR="/etc/NetworkManager/system-connections"
CONFIG_BACKUP_SEND_STATE_DIR="/var/lib/vdisk-relay/last"

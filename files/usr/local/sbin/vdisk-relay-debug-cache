def main():
    os.makedirs(RUN_DIR, mode=0o755, exist_ok=True)
    os.makedirs(WWW_DIR, mode=0o755, exist_ok=True)

    status = build_status()

    write_atomic(DEBUG_JSON_OUT, json.dumps(status, ensure_ascii=False, indent=2) + "\n", 0o644)
    write_atomic(HTML_OUT, render_html(status), 0o644)


if __name__ == "__main__":
    main()

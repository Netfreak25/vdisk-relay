#!/usr/bin/env python3
import html
import json
import os
import re
import shlex
import socket
import subprocess
import time
from datetime import datetime

RUN_DIR = "/run/vdisk-relay"
WWW_DIR = "/run/vdisk-relay-www"
STATUS_JSON = f"{RUN_DIR}/status.json"
DEBUG_JSON_OUT = f"{WWW_DIR}/debug.json"
HTML_OUT = f"{WWW_DIR}/debug.html"
LOG_FILE = "/var/log/vdisk-relay.log"
CONFIG_FILE = "/etc/vdisk-relay.conf"
IMAGE_FILE = "/usbdisk.img"
MOUNTPOINT = "/run/vdisk-relay/mnt"

UNITS = [
    "vdisk-relay-gadget-live.service",
    "vdisk-relay-watch-live.path",
    "vdisk-relay-trigger-live.service",
    "vdisk-relay-fast-sync.service",
    "vdisk-relay-ultra-fast-sync.service",
    "vdisk-relay-sync-live.service",
    "vdisk-relay-telegram-queue.service",
    "vdisk-relay-telegram-queue.timer",
    "vdisk-relay-retry-live.service",
    "vdisk-relay-retry-live.timer",
    "vdisk-relay-image-mtime-watch.service",

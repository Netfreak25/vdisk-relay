[Unit]
Description=vdisk-relay lightweight image mtime fallback
After=local-fs.target
ConditionPathExists=/usr/local/sbin/vdisk-relay
ConditionPathExists=/usbdisk.img
ConditionPathExists=/etc/vdisk-relay.live-enabled
ConditionPathExists=/etc/vdisk-relay.allow-sync

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/vdisk-relay image-mtime-watch
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7

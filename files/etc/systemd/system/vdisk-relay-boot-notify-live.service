[Unit]
Description=vdisk-relay live boot notification
After=network-online.target nss-lookup.target
Wants=network-online.target
ConditionPathExists=/usr/local/sbin/vdisk-relay
ConditionPathExists=/etc/vdisk-relay.live-enabled
ConditionPathExists=/etc/vdisk-relay.allow-boot-notify

[Service]
Type=oneshot
ExecStart=/usr/local/sbin/vdisk-relay boot-notify --send
Restart=no
RestartSec=30
TimeoutStartSec=10min

[Install]
WantedBy=multi-user.target
